-- ═══════════════════════════════════════
--  配置序列化/反序列化
-- ═══════════════════════════════════════
local function moonSerialize(v)
    if v == nil then return nil end
    local vt = typeof(v)
    if vt == "Color3" then return { _m = "C", R = v.R, G = v.G, B = v.B } end
    if vt == "EnumItem" then return { _m = "E", t = tostring(v.EnumType), n = v.Name } end
    if vt == "boolean" or vt == "number" or vt == "string" then return v end
    if type(v) ~= "table" then return tostring(v) end
    if v.kind == "key" and typeof(v.code) == "EnumItem" then
        return { kind = "key", code = moonSerialize(v.code) }
    end
    if v.kind == "mouse" and typeof(v.code) == "EnumItem" then
        return { kind = "mouse", code = moonSerialize(v.code) }
    end
    local len = #v
    local isArray = len > 0
    if isArray then
        for k in pairs(v) do
            if type(k) ~= "number" or k < 1 or k > len or math.floor(k) ~= k then
                isArray = false
                break
            end
        end
    end
    if isArray then
        local t = {}
        for i = 1, len do t[i] = moonSerialize(v[i]) end
        return t
    end
    local out = {}
    for k, x in pairs(v) do out[tostring(k)] = moonSerialize(x) end
    return out
end

local function moonDeserialize(v)
    if v == nil then return nil end
    if type(v) == "table" and v._m == "C" then return Color3.new(v.R or 0, v.G or 0, v.B or 0) end
    if type(v) == "table" and v._m == "E" then
        local bucket = (Enum)[v.t]
        if type(bucket) == "table" and v.n then return bucket[v.n] end
        return nil
    end
    if type(v) == "table" and v.kind == "key" then
        local code = moonDeserialize(v.code)
        if typeof(code) == "EnumItem" and code.EnumType == Enum.KeyCode then return { kind = "key", code = code } end
        return nil
    end
    if type(v) == "table" and v.kind == "mouse" then
        local code = moonDeserialize(v.code)
        if typeof(code) == "EnumItem" and code.EnumType == Enum.UserInputType then return { kind = "mouse", code = code } end
        return nil
    end
    if type(v) == "table" then
        local arr, maxk = true, 0
        for k in pairs(v) do
            if type(k) ~= "number" then arr = false break end
            if k > maxk then maxk = k end
        end
        if arr and maxk > 0 then
            local t = {}
            for i = 1, maxk do t[i] = moonDeserialize(v[i]) end
            return t
        end
    end
    return v
end

local function configEnsureFolder(f)
    if type(f) == "string" and f ~= "" and isfolder and makefolder and not isfolder(f) then
        pcall(makefolder, f)
    end
end

local function configRead(path)
    local ok, data = pcall(function()
        if not readfile then return nil end
        return readfile(path)
    end)
    if ok and type(data) == "string" then return true, data end
    return false, nil
end

local function configWrite(path, data)
    if not writefile then return false end
    return pcall(writefile, path, data) == true
end

function UiLib:_registerConfigEntry(id, get, set)
    if type(id) ~= "string" or id == "" then return end
    self._configEntries = self._configEntries or {}
    for i = #self._configEntries, 1, -1 do
        if self._configEntries[i].Id == id then table.remove(self._configEntries, i) end
    end
    table.insert(self._configEntries, { Id = id, Get = get, Set = set })
end

function UiLib:RegisterConfigEntry(entry)
    if type(entry) ~= "table" or type(entry.Id) ~= "string" then return end
    self:_registerConfigEntry(entry.Id, entry.Get, entry.Set)
end

function UiLib:ExportConfigTable()
    local out = {}
    for _, e in ipairs(self._configEntries or {}) do
        local ok, v = pcall(e.Get)
        if ok and v ~= nil then out[e.Id] = moonSerialize(v) end
    end
    return { _mc = 1, entries = out }
end

function UiLib:ImportConfigTable(root)
    if type(root) ~= "table" then return false, "not_table" end
    local map = type(root.entries) == "table" and root.entries or root
    for _, e in ipairs(self._configEntries or {}) do
        local raw = map[e.Id]
        if raw ~= nil then pcall(e.Set, moonDeserialize(raw)) end
    end
    return true, nil
end

function UiLib:GetConfigJson()
    local ok, s = pcall(function() return HttpService:JSONEncode(self:ExportConfigTable()) end)
    return ok and type(s) == "string" and s or "{}"
end

function UiLib:SetConfigJson(json)
    local ok, data = pcall(function() return HttpService:JSONDecode(json) end)
    if not ok or type(data) ~= "table" then return false, "json" end
    return self:ImportConfigTable(data)
end

function UiLib:SaveConfigToFile(path)
    local p = path or self._configFilePath
    if type(p) ~= "string" or p == "" then return false, "no_path" end
    local folder = string.match(p, "^(.*)/[^/]+$")
    if folder then configEnsureFolder(folder) end
    if configWrite(p, self:GetConfigJson()) then return true, nil end
    return false, "writefile"
end

function UiLib:LoadConfigFromFile(path)
    local p = path or self._configFilePath
    if type(p) ~= "string" or p == "" then return false, "no_path" end
    local okR, data = configRead(p)
    if not okR then return false, "readfile" end
    return self:SetConfigJson(data)
end

function UiLib:InstallConfigHub(opts)
    if self._configHubInstalled then return self._configHubHandle end
    opts = opts or {}
    local tabTitle = opts.TabTitle or opts.Title or "Config"
    local folder = opts.Folder or "PurpleUi"
    local profileDefault = opts.ProfileDefault or "default"
    self._configFolder = folder
    self._configHubInstalled = true
    local tabApi = self:CreateTab(tabTitle)
    local statusLbl = tabApi:Label({ Title = opts.StatusDefault or "Config: add ConfigId to controls." })
    local profileInput = tabApi:Input({
        Title = opts.ProfileTitle or "配置名",
        Placeholder = opts.ProfilePlaceholder or "default",
        Default = profileDefault,
        Callback = function() end,
    })
    local function profilePath()
        local name = tostring(profileInput:Get()):gsub("[^%w%-_%.]", "_")
        if name == "" then name = "default" end
        return folder .. "/" .. name .. ".json"
    end
    local function setStatus(t)
        if statusLbl and statusLbl.SetText then statusLbl:SetText(t) end
    end
    local function refreshPath()
        self._configFilePath = profilePath()
    end
    refreshPath()
    tabApi:Button({
        Title = opts.TitleSave or "保存配置",
        Callback = function()
            refreshPath()
            local ok, err = self:SaveConfigToFile(profilePath())
            if ok then
                setStatus("已保存: " .. profilePath())
                UiLib.Notify({ Title = "配置", Content = "保存成功", Type = "success" })
            else
                setStatus("保存失败: " .. tostring(err))
                UiLib.Notify({ Title = "配置", Content = "保存失败", Type = "error" })
            end
        end,
    })
    tabApi:Button({
        Title = opts.TitleLoad or "加载配置",
        Callback = function()
            refreshPath()
            local okR = configRead(profilePath())
            if not okR then
                setStatus("文件不存在: " .. profilePath())
                UiLib.Notify({ Title = "配置", Content = "文件不存在", Type = "error" })
                return
            end
            local ok = self:LoadConfigFromFile(profilePath())
            if ok then
                setStatus("已加载: " .. profilePath())
                UiLib.Notify({ Title = "配置", Content = "加载成功", Type = "success" })
            else
                setStatus("加载失败")
                UiLib.Notify({ Title = "配置", Content = "加载失败", Type = "error" })
            end
        end,
    })
    tabApi:Button({
        Title = opts.TitleCopy or "复制JSON",
        Callback = function()
            local json = self:GetConfigJson()
            if setclipboard then
                pcall(setclipboard, json)
                setStatus("已复制 (" .. tostring(#json) .. " bytes)")
            else
                setStatus("剪贴板不可用")
            end
        end,
    })
    tabApi:Button({
        Title = opts.TitlePaste or "粘贴JSON",
        Callback = function()
            if not getclipboard then setStatus("剪贴板不可用") return end
            local okc, clip = pcall(getclipboard)
            if not okc or type(clip) ~= "string" or clip == "" then setStatus("剪贴板为空") return end
            local ok = self:SetConfigJson(clip)
            if ok then
                setStatus("导入成功")
                UiLib.Notify({ Title = "配置", Content = "导入成功", Type = "success" })
            else
                setStatus("导入失败")
            end
        end,
    })
    if type(opts.Entries) == "table" then
        for _, e in ipairs(opts.Entries) do
            if type(e) == "table" and type(e.Id) == "string" then
                self:RegisterConfigEntry(e)
            end
        end
    end
    if opts.AutoLoad ~= false then
        task.defer(function()
            refreshPath()
            local okR = configRead(profilePath())
            if okR then
                if self:LoadConfigFromFile(profilePath()) then
                    setStatus("自动加载: " .. profilePath())
                else
                    setStatus("自动加载解析失败")
                end
            else
                setStatus("无存档 (正常)")
            end
        end)
    end
    self._configHubHandle = {
        TabTitle = tabTitle,
        ProfileInput = profileInput,
        Status = statusLbl,
        SetStatus = setStatus,
        ProfilePath = profilePath,
        Save = function() return self:SaveConfigToFile(profilePath()) end,
        Load = function() return self:LoadConfigFromFile(profilePath()) end,
    }
    return self._configHubHandle
end

