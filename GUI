		end

		local function bindMap(map)
			local dragging = false
			local heartCon
			local function set(mousePos)
				local rx = math.clamp((mousePos.X - map.AbsolutePosition.X) / map.AbsoluteSize.X, 0, 1)
				local ry = math.clamp((mousePos.Y - map.AbsolutePosition.Y) / map.AbsoluteSize.Y, 0, 1)
				sat, val = rx, 1 - ry
				updateBars()
			end
			map.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					local inset = GuiService:GetGuiInset()
					set(Vector2.new(input.Position.X, input.Position.Y) - inset)
					if heartCon then heartCon:Disconnect() end
					heartCon = RunService.Heartbeat:Connect(function()
						if dragging then set(UserInputService:GetMouseLocation() - GuiService:GetGuiInset()) end
					end)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
					if heartCon then heartCon:Disconnect() heartCon = nil end
				end
			end)
		end
		local function bindHue(bar)
			local dragging = false
			local heartCon
			local function set(mousePos)
				local y = math.clamp((mousePos.Y - bar.AbsolutePosition.Y) / bar.AbsoluteSize.Y, 0, 1)
				hue = y
				updateBars()
			end
			bar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					local inset = GuiService:GetGuiInset()
					set(Vector2.new(input.Position.X, input.Position.Y) - inset)
					if heartCon then heartCon:Disconnect() end
					heartCon = RunService.Heartbeat:Connect(function()
						if dragging then set(UserInputService:GetMouseLocation() - GuiService:GetGuiInset()) end
					end)
				end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
					if heartCon then heartCon:Disconnect() heartCon = nil end
				end
			end)
		end

		bindMap(svMap)
		bindHue(hueBar)
		headerBtn.MouseButton1Click:Connect(function() setExpanded(not expanded) end)

		updateBars()
		setExpanded(false)

		return {
			Set = function(_, col) hue, sat, val = col:ToHSV() updateBars() end,
			Get = function() return Color3.fromHSV(hue, sat, val) end
		}
	end

