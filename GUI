-- 销毁方法保持不变
function UiLib:Destroy()
	if self._isDestroying then return end
	if self.Window and self.RootGui and self.RootGui.Enabled then
		self._isDestroying = true
		if self._showGui then self._showGui.Enabled = false end
		local finalSize = UDim2.new(
			self.Window.Size.X.Scale, math.floor(self.Window.Size.X.Offset * 0.3),
			self.Window.Size.Y.Scale, math.floor(self.Window.Size.Y.Offset * 0.3)
		)
		local finalPos = UDim2.new(
			self.Window.Position.X.Scale, self.Window.Position.X.Offset,
			self.Window.Position.Y.Scale, self.Window.Position.Y.Offset + 24
		)
		local closeTween = tween(self.Window, TweenInfo.new(0.46, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
			Position = finalPos,
			Size = finalSize,
			BackgroundTransparency = 1
		})
		closeTween.Completed:Connect(function()
			if self._connections then
				for _, con in ipairs(self._connections) do
					if con and con.Disconnect then con:Disconnect() end
				end
				self._connections = nil
			end
			if self.RootGui then self.RootGui:Destroy() end
			if self._showGui then self._showGui:Destroy() end
		end)
		return
	end
	if self._connections then
		for _, con in ipairs(self._connections) do
			if con and con.Disconnect then con:Disconnect() end
		end
		self._connections = nil
	end
	if self.RootGui then self.RootGui:Destroy() end
	if self._showGui then self._showGui:Destroy() end
end

