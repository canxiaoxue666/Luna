local ANIM = {
	Fast = TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	Normal = TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	Slow = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
}

local function tween(instance: Instance, info: TweenInfo, props: {[string]: any})
	local t = TweenService:Create(instance, info, props)
	t:Play()
	return t
end

local function createCorner(parent: Instance, radius: number)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
	return corner
end

local function createStroke(parent: Instance, color: Color3, thickness: number, transparency: number?)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Transparency = transparency or THEME.StrokeTransparency
	stroke.Parent = parent
	return stroke
end

local function createPadding(parent: Instance, px: number)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, px)
	p.PaddingBottom = UDim.new(0, px)
	p.PaddingLeft = UDim.new(0, px)
	p.PaddingRight = UDim.new(0, px)
	p.Parent = parent
	return p
end

local function createList(parent: Instance, pad: number, align: Enum.HorizontalAlignment?)
	local list = Instance.new("UIListLayout")
	list.Padding = UDim.new(0, pad)
	list.FillDirection = Enum.FillDirection.Vertical
	list.HorizontalAlignment = align or Enum.HorizontalAlignment.Left
	list.SortOrder = Enum.SortOrder.LayoutOrder
	list.Parent = parent
	return list
end

local function isMouseInside(gui: GuiObject)
	local absPos = gui.AbsolutePosition
	local absSize = gui.AbsoluteSize
	local inset = GuiService:GetGuiInset()
	local mousePos = UserInputService:GetMouseLocation() - inset
	return mousePos.X >= absPos.X and mousePos.X <= absPos.X + absSize.X and mousePos.Y >= absPos.Y and mousePos.Y <= absPos.Y + absSize.Y
end

local function ensurePlayerGui()
	local player = game:GetService("Players").LocalPlayer
	return player:WaitForChild("PlayerGui")
end

-- 水印（保持不变，增加透明度微调）
function UiLib:CreateWatermark(opts)
	opts = opts or {}
	local existingGlobal = nil
	pcall(function()
		existingGlobal = CoreGui:FindFirstChild("MoonLuaWatermark", true)
	end)
	if existingGlobal and existingGlobal:IsA("Frame") then
		self._watermark = existingGlobal
		return existingGlobal
	end
	if self._watermark and self._watermark.Parent then
		self._watermark:Destroy()
	end
	local frame = Instance.new("Frame")
	frame.Name = "MoonLuaWatermark"
	frame.AnchorPoint = Vector2.new(0.5, 0)
	frame.Position = opts.Position or UDim2.new(0.8, 0, 0, 10)
	frame.Size = UDim2.new(0, 150, 0, 30)
	frame.BackgroundColor3 = THEME.Bg2
	frame.BackgroundTransparency = THEME.Bg2Transparency
	frame.Parent = self.RootGui
	createCorner(frame, 9)
	createStroke(frame, THEME.Stroke, 1, 0.35)
	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 8, 0, 0)
	label.Size = UDim2.new(1, -14, 1, 0)
	label.Font = Enum.Font.GothamSemibold
	label.TextSize = 12
	label.TextColor3 = THEME.Text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "FPS: -- | Ping: -- ms"
	label.Parent = frame
	local drag = false
	local dragStart = Vector2.zero
	local startPos = frame.Position
	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			drag = true
			dragStart = input.Position
			startPos = frame.Position
		end
	end)
	table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			drag = false
		end
	end))
	table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
		if drag and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end))
	local fpsCounter = 0
	local fpsValue = 0
	local fpsTick = os.clock()
	local pingTick = 0
	local pingText = "-- ms"
	table.insert(self._connections, RunService.RenderStepped:Connect(function()
		fpsCounter += 1
		local now = os.clock()
		local elapsed = now - fpsTick
		if elapsed >= 0.5 then
			fpsValue = math.floor((fpsCounter / elapsed) + 0.5)
			fpsCounter = 0
			fpsTick = now
		end
		if now - pingTick >= 0.25 then
			pingTick = now
			local ok, text = pcall(function()
				return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
			end)
			if ok and text then
				local numeric = tonumber(string.match(tostring(text), "%d+%.?%d*"))
				if numeric then
					pingText = string.format("%d ms", math.floor(numeric + 0.5))
				else
					pingText = "-- ms"
				end
			else
				pingText = "-- ms"
			end
		end
		if label.Parent then
			label.Text = string.format("FPS: %d | Ping: %s", fpsValue, pingText)
		end
	end))
	self._watermark = frame
	return frame
end

-- 通知系统（微调透明度）
function UiLib:_getNotifyTargetPositions()
	local cards = self._notifyCards
	local out = {}
	if not cards then return out end
	local gap = 8
	local padBottom = 4
	local acc = padBottom
	for idx = #cards, 1, -1 do
		local c = cards[idx]
		if c and c.Parent then
			local h = c.AbsoluteSize.Y
			if h < 24 then h = 72 end
			local safeH = math.max(h, 48)
			out[c] = UDim2.new(0, 0, 1, -acc - safeH)
			acc += safeH + gap
		end
	end
	return out
end

function UiLib:_tweenNotifyStackToTargets(except)
	local targets = self:_getNotifyTargetPositions()
	for c, tgt in pairs(targets) do
		if (not except or c ~= except) and c.Parent then
			c.AnchorPoint = Vector2.new(0, 1)
			TweenService:Create(
				c,
				TweenInfo.new(0.26, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
				{Position = tgt}
			):Play()
		end
	end
end

function UiLib:Notify(opts)
	opts = opts or {}
	local title = opts.Title or "通知"
	local content = opts.Content or ""
	local duration = opts.Duration or 3
	local kind = opts.Type or "info"

	local holder = self._notifyHolder
	if not holder then
		holder = Instance.new("ScreenGui")
