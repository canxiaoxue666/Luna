        local hw = showBtn.AbsoluteSize.X / 2
        local hh = showBtn.AbsoluteSize.Y / 2
        return math.clamp(x, hw, vp.X - hw), math.clamp(y, hh, vp.Y - hh)
    end

    -- 隐藏窗口时，将缩小按钮放在窗口位置附近
    hideBtn.MouseButton1Click:Connect(function()
        self:Hide()
    end)

    showInputBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            showMouseDown = true
            showDragging = true
            showDidDrag = false
            showStartOffset = Vector2.new(showBtn.Position.X.Offset, showBtn.Position.Y.Offset)
            showDragStart = input.Position
            if input.UserInputType == Enum.UserInputType.Touch then
                showActiveTouch = input
            else
                showActiveTouch = nil
            end
        end
    end)

    table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- 窗口拖拽结束 (在titleBar处理)
        end
        if not showMouseDown then return end
        if input.UserInputType == Enum.UserInputType.Touch then
            if showActiveTouch ~= input then return end
        elseif input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return
        end
        showActiveTouch = nil
        showMouseDown = false
        showDragging = false
        local shouldOpen = not showDidDrag
        showDidDrag = false
        local ptr = Vector2.new(input.Position.X, input.Position.Y)
        if shouldOpen and self._showGui and self._showGui.Enabled and not self.Visible then
            if isPointerInsideGuiObject(showBtn, ptr) then
                self:Show()
            end
        end
    end))

    table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
        if not (showDragging and showMouseDown) then return end
        local d = nil
        if IsOnMobile then
            if input.UserInputType == Enum.UserInputType.Touch and showActiveTouch == input then
                d = input.Position - showDragStart
            end
        elseif input.UserInputType == Enum.UserInputType.MouseMovement then
            d = input.Position - showDragStart
        end
        if not d then return end
        if d.Magnitude > showDragThreshold then showDidDrag = true end
        local tx = showStartOffset.X + d.X
        local ty = showStartOffset.Y + d.Y
        local cx, cy = clampShowPos(tx, ty)
        showBtn.Position = UDim2.new(0, cx, 0, cy)
    end))

    -- 窗口拖拽
    local dragging = false
    local dragStart = Vector2.zero
    local startPos = window.Position
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = window.Position
        end
    end)

    table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end))

    table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        local isMove = input.UserInputType == Enum.UserInputType.MouseMovement
        local isTouch = input.UserInputType == Enum.UserInputType.Touch
        if not isMove and not isTouch then return end
        local delta = input.Position - dragStart
        window.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end))

    -- ═══ 主体区域 ═══
    local body = Instance.new("Frame")
    body.Name = "Body"
    body.Position = UDim2.new(0, 0, 0, titleBarHeight)
    body.Size = UDim2.new(1, 0, 1, -titleBarHeight)
    body.BackgroundTransparency = 1
    body.Parent = window

    -- Tab列表
    local tabList = Instance.new("ScrollingFrame")
    tabList.Name = "TabList"
    tabList.Size = UDim2.new(0, tabWidth, 1, 0)
    tabList.BackgroundTransparency = 1
    tabList.BorderSizePixel = 0
    tabList.ScrollBarThickness = 3
    tabList.ScrollBarImageColor3 = th.Stroke
    tabList.ScrollingDirection = Enum.ScrollingDirection.Y
    tabList.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabList.AutomaticCanvasSize = Enum.AutomaticSize.Y
    tabList.HorizontalScrollBarInset = Enum.ScrollBarInset.ScrollBar
    tabList.VerticalScrollBarInset = Enum.ScrollBarInset.ScrollBar
    tabList.Parent = body
    createPadding(tabList, 8)
    createList(tabList, tabGap)

    -- 分隔线 (Tab列表右侧)
    local tabDivider = Instance.new("Frame")
    tabDivider.Size = UDim2.new(0, 1, 1, 0)
    tabDivider.Position = UDim2.new(0, tabWidth, 0, 0)
    tabDivider.BackgroundColor3 = th.Stroke
    tabDivider.BackgroundTransparency = 0.4
    tabDivider.BorderSizePixel = 0
    tabDivider.Parent = body

    -- 页面容器
    local pageHolder = Instance.new("Frame")
    pageHolder.Name = "PageHolder"
    pageHolder.Position = UDim2.new(0, tabWidth + 1, 0, 0)
    pageHolder.Size = UDim2.new(1, -tabWidth - 1, 1, 0)
    pageHolder.BackgroundTransparency = 1
    pageHolder.ClipsDescendants = true
    pageHolder.Parent = body

    local pages = Instance.new("Frame")
    pages.Name = "Pages"
    pages.BackgroundTransparency = 1
    pages.BorderSizePixel = 0
    pages.Size = UDim2.new(1, 0, 1, 0)
    pages.ClipsDescendants = true
    pages.Parent = pageHolder

    self._tabButtons = {}
    self._pages = {}
    self._activeTab = nil
    self._tabPageTweens = {}
    self._tabAnimSeq = 0
    self._tabListFrame = tabList
    self._pagesFrame = pages
    self._titleBarHeight = titleBarHeight
    self._tabWidth = tabWidth
    self._tabBtnH = tabBtnH
    self._tabGap = tabGap
    self._tabIconSize = tabIconSize
    self._tabFontSize = tabFontSize
    self._tabFont = tabFont
    self._elGap = elGap
    self._elPad = elPad
    self._elCorner = elCorner
    self._btnHeight = btnHeight
    self._noBorder = noBorder
    self._noWmBorder = noWmBorder
    self._noMinBorder = noMinBorder
    self._cornerRadius = cornerRadius

    -- Watermark
    if opts.Watermark ~= false then
        local wmOpts = {}
        if opts.WatermarkPosition then wmOpts.Position = opts.WatermarkPosition end
        self:CreateWatermark(wmOpts)
    end

    -- 鼠标光标点
    if opts.CursorDot ~= false and not IsOnMobile and UserInputService.MouseEnabled then
        local cursorDot = Instance.new("Frame")
        cursorDot.Name = "CursorDot"
        cursorDot.AnchorPoint = Vector2.new(0.5, 0.5)
        cursorDot.Size = UDim2.fromOffset(4, 4)
        cursorDot.BackgroundColor3 = th.Accent
        cursorDot.BackgroundTransparency = 0.2
        cursorDot.BorderSizePixel = 0
        cursorDot.Visible = false
        cursorDot.ZIndex = 2147483647
        cursorDot.Active = false
        cursorDot.Selectable = false
        cursorDot.Parent = screenGui
        createCorner(cursorDot, 2)
        self._cursorDot = cursorDot
        table.insert(self._connections, RunService.Heartbeat:Connect(function()
            local dot = self._cursorDot
            if not dot or not dot.Parent then return end
            if not self.Visible or not screenGui.Enabled then dot.Visible = false return end
            local mouse = UserInputService:GetMouseLocation()
            if isPointerOverLayerCollector(screenGui, mouse, dot) then
                dot.Visible = true
                dot.Position = UDim2.fromOffset(mouse.X, mouse.Y)
            else
                dot.Visible = false
            end
        end))
    end

    -- ═══ 开场动画 ═══
    local tw0 = self._targetWindowSize.X.Offset
    local th0 = self._targetWindowSize.Y.Offset
    local startW = math.max(math.floor(tw0 * 0.2), 40)
    local startH = math.max(math.floor(th0 * 0.2), 30)
    local camInit = Workspace.CurrentCamera
    local yInit = math.floor(((camInit and camInit.ViewportSize.Y) or 800) * 0.1 + 0.5)
    window.Size = UDim2.new(self._targetWindowSize.X.Scale, startW, self._targetWindowSize.Y.Scale, startH)
    window.Position = UDim2.new(0.5, 0, 0, yInit)
    tw(window, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = self._targetWindowSize,
        Position = self._targetWindowPosition,
        GroupTransparency = 0,
    })

    return self
end

-- ═══════════════════════════════════════
--  SetWindowBackground
-- ═══════════════════════════════════════
function UiLib:SetWindowBackground(opts)
    opts = opts or {}
    local img = self._windowBgImage
    local win = self.Window
    if opts.Image ~= nil then
        if opts.Image == false then
            if img then img.Visible = false end
        else
            local id = normalizeBackdropImage(opts.Image)
            if img and id then
                img.Visible = true
                img.Image = id
            end
        end
    end
    if opts.ImageTransparency ~= nil and img then
        img.ImageTransparency = opts.ImageTransparency
    end
    if opts.ImageColor ~= nil and img then
        img.ImageColor3 = opts.ImageColor
    end
    if opts.ScaleType ~= nil and img then
        img.ScaleType = opts.ScaleType
    end
    if opts.WindowTransparency ~= nil and win then
        self._windowFrameTransparency = opts.WindowTransparency
        win.BackgroundTransparency = opts.WindowTransparency
    end
    if opts.WindowColor ~= nil and win then
        win.BackgroundColor3 = opts.WindowColor
    end
end

-- ═══════════════════════════════════════
--  SetTitle / SetTitleIcon
-- ═══════════════════════════════════════
function UiLib:SetTitle(text)
    if self._titleLabel then
        self._titleLabel.Text = text or ""
    end
end

function UiLib:SetTitleIcon(icon)
    if not self._titleIconContainer then return end
    local info = resolveIcon(icon)
    applyIconToContainer(self._titleIconContainer, info, UDim2.new(0, 20, 0, 20), self.Theme.Accent, 14)
    -- 调整标题文本偏移
    if self._titleLabel then
        self._titleLabel.Position = UDim2.new(0, info.type ~= "none" and 38 or 16, 0, 0)
    end
end

-- ═══════════════════════════════════════
--  SetMinimizedIcon
-- ═══════════════════════════════════════
function UiLib:SetMinimizedIcon(icon)
    if not self._showBtn then return end
    for _, child in self._showBtn:GetChildren() do
        if child.Name == "_MinIcon" then child:Destroy() end
    end
    local info = resolveIcon(icon)
    if info.type == "image" then
        local img = Instance.new("ImageLabel")
        img.Name = "_MinIcon"
        img.BackgroundTransparency = 1
        img.Size = UDim2.new(0.7, 0, 0.7, 0)
        img.Position = UDim2.new(0.15, 0, 0.15, 0)
        img.Image = info.url
        img.ImageColor3 = self._opts.MinimizedIconTextColor or self.Theme.Accent
        img.ScaleType = Enum.ScaleType.Fit
        img.Parent = self._showBtn
    elseif info.type == "text" then
        local txt = Instance.new("TextLabel")
        txt.Name = "_MinIcon"
        txt.BackgroundTransparency = 1
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.Text = info.text
        txt.TextColor3 = self._opts.MinimizedIconTextColor or self.Theme.Accent
        txt.TextSize = self._opts.MinimizedIconTextSize or 16
        txt.Font = FONTS.Bold
        txt.Parent = self._showBtn
    else
        local dot = Instance.new("Frame")
        dot.Name = "_MinIcon"
        dot.Size = UDim2.new(0, 16, 0, 16)
        dot.Position = UDim2.new(0.5, -8, 0.5, -8)
        dot.BackgroundColor3 = self.Theme.Accent
        dot.Parent = self._showBtn
        createCorner(dot, 8)
    end
end

-- ═══════════════════════════════════════
--  Tab页面动画辅助
-- ═══════════════════════════════════════
local function tabPageEnsureScale(page)
    local s = page:FindFirstChild("_TPScale")
    if s and s:IsA("UIScale") then return s end
    local us = Instance.new("UIScale")
    us.Name = "_TPScale"
    us.Scale = 1
    us.Parent = page
    return us
end

local function cancelTabTweens(self)
    for _, t in ipairs(self._tabPageTweens or {}) do
        pcall(function() (t)::Cancel() end)
    end
    self._tabPageTweens = {}
end

local function regTabTween(self, t)
    if not self._tabPageTweens then self._tabPageTweens = {} end
    table.insert(self._tabPageTweens, t)
end

-- ═══════════════════════════════════════
--  CreateTab
-- ═══════════════════════════════════════
function UiLib:CreateTab(tabOpts)
    tabOpts = tabOpts or {}
    local tabTitle = tabOpts.Title or "Tab"
    local iconInfo = resolveIcon(tabOpts.Icon)
    local th = self.Theme

    local btn = Instance.new("TextButton")
    btn.Name = "Tab_" .. tabTitle
    btn.Size = UDim2.new(1, -8, 0, self._tabBtnH)
    btn.BackgroundColor3 = th.Card
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.Text = ""
    btn.Parent = self._tabListFrame
    createCorner(btn, self._elCorner)

    -- Tab图标
    local iconOffset = 0
    if iconInfo.type ~= "none" then
        local iconCont = Instance.new("Frame")
        iconCont.Name = "IconCont"
        iconCont.BackgroundTransparency = 1
        iconCont.Size = self._tabIconSize
        iconCont.Position = UDim2.new(0, 8, 0.5, -(self._tabIconSize.Y.Offset / 2))
        iconCont.Parent = btn
        applyIconToContainer(iconCont, iconInfo, self._tabIconSize,
            iconInfo.type == "text" and th.Accent or th.Text,
            math.min(self._tabFontSize - 1, 12))
        iconOffset = self._tabIconSize.X.Offset + 14
    end

    -- Tab文本
    local tabLabel = Instance.new("TextLabel")
    tabLabel.Name = "TabLabel"
    tabLabel.BackgroundTransparency = 1
    tabLabel.Position = UDim2.new(0, iconOffset, 0, 0)
    tabLabel.Size = UDim2.new(1, -iconOffset - 8, 1, 0)
    tabLabel.Text = tabTitle
    tabLabel.Font = self._tabFont
    tabLabel.TextSize = self._tabFontSize
    tabLabel.TextColor3 = th.TextSoft
    tabLabel.TextXAlignment = Enum.TextXAlignment.Left
    tabLabel.Parent = btn

    -- 页面
    local page = Instance.new("Frame")
    page.Name = "Page_" .. tabTitle
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.Size = UDim2.new(1, 0, 1, 0)
    page.Position = UDim2.new(0, 0, 0, 0)
    page.Visible = false
    page.Parent = self._pagesFrame

    local pageScroll = Instance.new("ScrollingFrame")
    pageScroll.Name = "Content"
    pageScroll.BackgroundTransparency = 1
    pageScroll.BorderSizePixel = 0
    pageScroll.Size = UDim2.new(1, 0, 1, 0)
    pageScroll.ScrollBarThickness = 4
    pageScroll.ScrollBarImageColor3 = th.Stroke
    pageScroll.ScrollingDirection = Enum.ScrollingDirection.Y
    pageScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    pageScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    pageScroll.VerticalScrollBarInset = Enum.ScrollBarInset.ScrollBar
    pageScroll.Parent = page
    createPadding(pageScroll, 8)
    createList(pageScroll, self._elGap)

    table.insert(self._tabButtons, btn)
    table.insert(self._pages, page)

    -- 切换逻辑
    local function activate()
        if self._activeTab == btn then return end
        self._tabAnimSeq += 1
        local seq = self._tabAnimSeq

        -- 取消旧页面动画
        cancelTabTweens(self)

        -- 旧页面淡出
        if self._activeTab then
            local oldIdx = table.find(self._tabButtons, self._activeTab)
            if oldIdx then
                local oldPage = self._pages[oldIdx]
                if oldPage then
                    local sc = tabPageEnsureScale(oldPage)
                    local t1 = tw(sc, ANIM.TabShrink, { Scale = 0.92 })
                    regTabTween(self, t1)
                    local t2 = tw(oldPage, ANIM.TabShrink, { BackgroundTransparency = 1 })
                    regTabTween(self, t2)
                    task.delay(TAB_SHRINK_SEC, function()
                        if self._tabAnimSeq ~= seq then return end
                        oldPage.Visible = false
                    end)
                end
            end
            -- 旧按钮样式
            self._activeTab.BackgroundColor3 = th.Card
            local oldLbl = self._activeTab:FindFirstChild("TabLabel")
            if oldLbl then oldLbl.TextColor3 = th.TextSoft end
        end

        -- 新按钮样式
        btn.BackgroundColor3 = th.AccentDark
        tabLabel.TextColor3 = th.Text

        -- 新页面淡入
        page.Visible = true
        page.BackgroundTransparency = 1
        local sc = tabPageEnsureScale(page)
        sc.Scale = 0.92
        task.defer(function()
            if self._tabAnimSeq ~= seq then return end
            local t1 = tw(sc, ANIM.TabGrow, { Scale = 1 })
            regTabTween(self, t1)
            local t2 = tw(page, ANIM.TabGrow, { BackgroundTransparency = 1 })
            regTabTween(self, t2)
        end)

        self._activeTab = btn
    end

    btn.MouseButton1Click:Connect(activate)

    -- 悬浮效果
    btn.MouseEnter:Connect(function()
        if self._activeTab ~= btn then
            tw(btn, ANIM.Fast, { BackgroundColor3 = th.CardHover })
        end
    end)
    btn.MouseLeave:Connect(function()
        if self._activeTab ~= btn then
            tw(btn, ANIM.Fast, { BackgroundColor3 = th.Card })
        end
    end)

    -- 如果是第一个Tab，自动激活
    if #self._tabButtons == 1 then
        task.defer(activate)
    end

    -- ═══ Tab API ═══
    local api = {}

    function api:Button(elOpts)
        elOpts = elOpts or {}
        local card = Instance.new("Frame")
        card.Size = UDim2.new(1, 0, 0, self._btnHeight)
        card.BackgroundColor3 = th.Card
        card.BorderSizePixel = 0
        card.Parent = pageScroll
        createCorner(card, self._elCorner)
        createPadding(card, self._elPad)

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.Text = elOpts.Title or "Button"
        lbl.Font = FONTS.Default
        lbl.TextSize = 13
        lbl.TextColor3 = th.Text
        lbl.TextXAlignment = Enum.TextXAlignment.Center
        lbl.Parent = card

        local input = Instance.new("TextButton")
        input.BackgroundTransparency = 1
        input.Size = UDim2.new(1, 0, 1, 0)
        input.Text = ""
        input.AutoButtonColor = false
        input.ZIndex = 5
        input.Parent = card

        input.MouseEnter:Connect(function() tw(card, ANIM.Fast, { BackgroundColor3 = th.AccentDark }) end)
        input.MouseLeave:Connect(function() tw(card, ANIM.Fast, { BackgroundColor3 = th.Card }) end)
        input.MouseButton1Click:Connect(function()
            tw(card, ANIM.Fast, { BackgroundColor3 = th.Accent })
            task.delay(0.15, function()
                if card.Parent then tw(card, ANIM.Fast, { BackgroundColor3 = th.Card }) end
            end)
            if type(elOpts.Callback) == "function" then elOpts.Callback() end
        end)

        if elOpts.ConfigId and type(elOpts.Callback) == "function" then
            -- ConfigId仅用于标识，按钮不需要Get/Set
        end
        return self
    end

    function api:Toggle(elOpts)
        elOpts = elOpts or {}
        local defaultVal = elOpts.Default ~= nil and elOpts.Default or false
        local currentVal = defaultVal

        local card = Instance.new("Frame")
        card.Size = UDim2.new(1, 0, 0, self._btnHeight)
        card.BackgroundColor3 = th.Card
        card.BorderSizePixel = 0
        card.Parent = pageScroll
        createCorner(card, self._elCorner)
        createPadding(card, self._elPad)

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, -54, 1, 0)
        lbl.Text = elOpts.Title or "Toggle"
        lbl.Font = FONTS.Default
        lbl.TextSize = 13
        lbl.TextColor3 = th.Text
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = card

        local toggleBg = Instance.new("Frame")
        toggleBg.Size = elOpts.ToggleSize or UDim2.new(0, 40, 0, 22)
        toggleBg.Position = UDim2.new(1, -48, 0.5, -(elOpts.ToggleSize and elOpts.ToggleSize.Y.Offset or 11))
        toggleBg.BackgroundColor3 = th.Stroke
        toggleBg.BorderSizePixel = 0
        toggleBg.Parent = card
        createCorner(toggleBg, 11)

        local toggleDot = Instance.new("Frame")
        toggleDot.Size = UDim2.new(0, 16, 0, 16)
        toggleDot.Position = UDim2.new(0, 3, 0.5, -8)
        toggleDot.BackgroundColor3 = th.TextSoft
        toggleDot.BorderSizePixel = 0
        toggleDot.Parent = toggleBg
        createCorner(toggleDot, 8)

        local function updateVisual(val)
            currentVal = val
            if val then
                tw(toggleBg, ANIM.Fast, { BackgroundColor3 = th.Accent })
                tw(toggleDot, ANIM.Fast, { Position = UDim2.new(0, 21, 0.5, -8), BackgroundColor3 = th.Text })
            else
                tw(toggleBg, ANIM.Fast, { BackgroundColor3 = th.Stroke })
                tw(toggleDot, ANIM.Fast, { Position = UDim2.new(0, 3, 0.5, -8), BackgroundColor3 = th.TextSoft })
            end
        end
        updateVisual(defaultVal)

        local input = Instance.new("TextButton")
        input.BackgroundTransparency = 1
        input.Size = UDim2.new(1, 0, 1, 0)
        input.Text = ""
        input.AutoButtonColor = false
        input.ZIndex = 5
        input.Parent = card
        input.MouseButton1Click:Connect(function()
            currentVal = not currentVal
            updateVisual(currentVal)
            if type(elOpts.Callback) == "function" then elOpts.Callback(currentVal) end
        end)

        local ctrl = {}
        function ctrl:Get() return currentVal end
        function ctrl:Set(v) updateVisual(v) end
        function ctrl:Toggle() updateVisual(not currentVal) return currentVal end

        if elOpts.ConfigId then
            self:_registerConfigEntry(elOpts.ConfigId, function() return ctrl:Get() end, function(v) ctrl:Set(v) end)
        end
        return ctrl
    end

    function api:Slider(elOpts)
        elOpts = elOpts or {}
        local minVal = elOpts.Min or 0
        local maxVal = elOpts.Max or 100
        local defaultVal = elOpts.Default or minVal
        local step = elOpts.Step or 1
        local currentVal = defaultVal

        local card = Instance.new("Frame")
        card.Size = UDim2.new(1, 0, 0, self._btnHeight + 18)
        card.BackgroundColor3 = th.Card
        card.BorderSizePixel = 0
        card.Parent = pageScroll
        createCorner(card, self._elCorner)
        createPadding(card, self._elPad)

        local topRow = Instance.new("Frame")
        topRow.BackgroundTransparency = 1
        topRow.Size = UDim2.new(1, 0, 0, 18)
        topRow.Parent = card

        local lbl = Instance.new("TextLabel")
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, -50, 1, 0)
        lbl.Text = elOpts.Title or "Slider"
        lbl.Font = FONTS.Default
        lbl.TextSize = 13
        lbl.TextColor3 = th.Text
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = topRow

        local valLabel = Instance.new("TextLabel")
        valLabel.BackgroundTransparency = 1
        valLabel.Size = UDim2.new(0, 50, 1, 0)
        valLabel.Position = UDim2.new(1, -50, 0, 0)
        valLabel.Text = tostring(defaultVal)
        valLabel.Font = FONTS.Bold
        valLabel.TextSize = 13
        valLabel.TextColor3 = th.Accent
        valLabel.TextXAlignment = Enum.TextXAlignment.Right
        valLabel.Parent = topRow

        local sliderBg = Instance.new("Frame")
        sliderBg.Size = UDim2.new(1, 0, 0, 8)
        sliderBg.Position = UDim2.new(0, 0, 0, 22)
        sliderBg.BackgroundColor3 = th.Stroke
        sliderBg.BorderSizePixel = 0
        sliderBg.Parent = card
        createCorner(sliderBg, 4)

        local sliderFill = Instance.new("Frame")
        sliderFill.Size = UDim2.new(0, 0, 1, 0)
        sliderFill.BackgroundColor3 = th.Accent
        sliderFill.BorderSizePixel = 0
        sliderFill.Parent = sliderBg
        createCorner(sliderFill, 4)

        local sliderInput = Instance.new("TextButton")
        sliderInput.BackgroundTransparency = 1
        sliderInput.Size = UDim2.new(1, 0, 0, 30)
        sliderInput.Position = UDim2.new(0, 0, 0, 12)
        sliderInput.Text = ""
        sliderInput.AutoButtonColor = false
        sliderInput.ZIndex = 5
        sliderInput.Parent = card

        local function formatVal(v)
            if elOpts.Format and type(elOpts.Format) == "function" then
                return elOpts.Format(v)
            end
            if step >= 1 then return tostring(math.floor(v + 0.5)) end
            return string.format("%.2f", v)
        end

        local function updateVisual(val)
            currentVal = math.clamp(val, minVal, maxVal)
            local pct = (currentVal - minVal) / (maxVal - minVal)
            pct = math.clamp(pct, 0, 1)
            sliderFill.Size = UDim2.new(pct, 0, 1, 0)
            valLabel.Text = formatVal(currentVal)
        end
        updateVisual(defaultVal)

        local sliding = false
        sliderInput.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                sliding = true
                local rel = input.Position.X - sliderBg.AbsolutePosition.X
                local pct = math.clamp(rel / sliderBg.AbsoluteSize.X, 0, 1)
                local raw = minVal + pct * (maxVal - minVal)
                if step > 0 then raw = math.round(raw / step) * step end
                updateVisual(raw)
            end
        end)

        table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                if sliding then
                    sliding = false
                    if type(elOpts.Callback) == "function" then elOpts.Callback(currentVal) end
                end
            end
        end))

        table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
            if not sliding then return end
            if input.UserInputType ~= Enum.UserInputType.MouseMovement
                and input.UserInputType ~= Enum.UserInputType.Touch then return end
            local rel = input.Position.X - sliderBg.AbsolutePosition.X
            local pct = math.clamp(rel / sliderBg.AbsoluteSize.X, 0, 1)
            local raw = minVal + pct * (maxVal - minVal)
            if step > 0 then raw = math.round(raw / step) * step end
            updateVisual(raw)
        end))

        local ctrl = {}
        function ctrl:Get() return currentVal end
        function ctrl:Set(v) updateVisual(v) end

        if elOpts.ConfigId then
            self:_registerConfigEntry(elOpts.ConfigId, function() return ctrl:Get() end, function(v) ctrl:Set(v) end)
        end
        return ctrl
    end

