					b.Button.BackgroundColor3 = isSel and THEME.AccentSoft or THEME.Bg2
					b.Button.TextColor3 = isSel and THEME.Text or THEME.TextSoft
				end
			end,
			Get = function() return selected end,
		}
	end

	-- 新增：热键设置控件
	function api:HotkeySetting(opts)
		opts = opts or {}
		local title = opts.Title or "显示热键"
		local currentKey = self._hotkey or Enum.KeyCode.RightShift
		local card = Instance.new("Frame")
		card.Size = UDim2.new(1,0,0,42)
		card.BackgroundColor3 = THEME.Card
		card.BackgroundTransparency = THEME.CardTransparency
		card.Parent = page
		corner(card, 12)
		stroke(card, THEME.Stroke, 1, 0.4)

		local titleLabel = Instance.new("TextLabel")
		titleLabel.BackgroundTransparency = 1
		titleLabel.Position = UDim2.new(0,12,0,0)
		titleLabel.Size = UDim2.new(1,-120,1,0)
		titleLabel.TextXAlignment = Enum.TextXAlignment.Left
		titleLabel.Font = Enum.Font.GothamMedium
		titleLabel.TextSize = 13
		titleLabel.Text = title
		titleLabel.TextColor3 = THEME.Text
		titleLabel.Parent = card

		local keyButton = Instance.new("TextButton")
		keyButton.AnchorPoint = Vector2.new(1,0.5)
		keyButton.Position = UDim2.new(1,-10,0.5,0)
		keyButton.Size = UDim2.new(0,90,0,28)
		keyButton.BackgroundColor3 = THEME.Bg2
		keyButton.BackgroundTransparency = 0.2
		keyButton.Text = currentKey.Name
		keyButton.TextColor3 = THEME.Text
		keyButton.Font = Enum.Font.Gotham
		keyButton.TextSize = 12
		keyButton.AutoButtonColor = false
		keyButton.Parent = card
		corner(keyButton, 8)
		stroke(keyButton, THEME.Stroke, 1, 0.3)

		local listening, conn = false, nil
		local function start()
			if listening then return end
			listening = true
			keyButton.Text = "..."
			conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
				if gameProcessed then return end
				if input.UserInputType == Enum.UserInputType.Keyboard then
					currentKey = input.KeyCode
					self._hotkey = currentKey
					listening = false
					keyButton.Text = currentKey.Name
					if conn then conn:Disconnect() conn = nil end
					if opts.Callback then opts.Callback(currentKey) end
				end
			end)
		end
		keyButton.MouseButton1Click:Connect(function()
			if listening then
				listening = false
				if conn then conn:Disconnect() conn = nil end
				keyButton.Text = currentKey.Name
			else
				start()
			end
		end)

		return {
			Set = function(_, k) currentKey = k self._hotkey = k keyButton.Text = k.Name end,
			Get = function() return currentKey end,
		}
	end

	-- ########## 控件结束 ##########
	return api
end

-- 销毁
function UiLib:Destroy()
	if self._isDestroying then return end
	if self.Window and self.RootGui and self.RootGui.Enabled then
		self._isDestroying = true
		if self._showGui then self._showGui.Enabled = false end
		local finalSize = UDim2.new(self.Window.Size.X.Scale, math.floor(self.Window.Size.X.Offset*0.3), self.Window.Size.Y.Scale, math.floor(self.Window.Size.Y.Offset*0.3))
		local finalPos = UDim2.new(self.Window.Position.X.Scale, self.Window.Position.X.Offset, self.Window.Position.Y.Scale, self.Window.Position.Y.Offset + 24)
		local ct = tween(self.Window, TweenInfo.new(0.46, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Position = finalPos, Size = finalSize, BackgroundTransparency = 1})
		ct.Completed:Connect(function()
			for _, con in ipairs(self._connections or {}) do if con and con.Disconnect then con:Disconnect() end end
			if self.RootGui then self.RootGui:Destroy() end
			if self._showGui then self._showGui:Destroy() end
		end)
	else
		for _, con in ipairs(self._connections or {}) do if con and con.Disconnect then con:Disconnect() end end
		if self.RootGui then self.RootGui:Destroy() end
		if self._showGui then self._showGui:Destroy() end
	end
end

UiLib.Theme = THEME
UiLib.Anim = ANIM
pcall(setfpscap, math.huge)
