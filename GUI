			mapCursor.Position = UDim2.new(sat, 0, 1 - val, 0)
			hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
			valueText.Text = ("HSV: %.2f, %.2f, %.2f"):format(hue, sat, val)
			hexText.Text = "HEX: #" .. out:ToHex()
			rgbText.Text = ("RGB: %d, %d, %d"):format(math.floor(out.R*255+0.5), math.floor(out.G*255+0.5), math.floor(out.B*255+0.5))
