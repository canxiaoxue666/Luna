local TAB_SHRINK_SEC = 0.26
local TAB_GROW_SEC = 0.32

local ANIM = {
	Fast = TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	Normal = TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	Slow = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	TabShrink = TweenInfo.new(TAB_SHRINK_SEC, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
	TabGrow = TweenInfo.new(TAB_GROW_SEC, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
	TabButton = TweenInfo.new(TAB_SHRINK_SEC + TAB_GROW_SEC, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
}

local function tween(instance: Instance, info: TweenInfo, props: {[string]: any})
	local t = TweenService:Create(instance, info, props)
	t:Play()
	return t
end

local function tabPageEnsureScale(page: GuiObject): UIScale
	local s = page:FindFirstChild("_TabPageScale")
	if s and s:IsA("UIScale") then
		return s :: UIScale
	end
	local us = Instance.new("UIScale")
	us.Name = "_TabPageScale"
	us.Scale = 1
	us.Parent = page
	return us
end

local function cancelTabPageTweens(self: any)
	for _, tw in ipairs(self._tabPageTweens or {}) do
		pcall(function()
			(tw :: Tween):Cancel()
		end)
	end
	self._tabPageTweens = {}
end

local function registerTabTween(self: any, tw: Tween)
	if not self._tabPageTweens then
		self._tabPageTweens = {}
	end
	table.insert(self._tabPageTweens, tw)
end

local function normalizeBackdropImage(input: any): string?
	if input == nil or input == false then
		return nil
	end
	if type(input) == "number" then
		return "rbxassetid://" .. tostring(input)
	end
	local s = tostring(input)
	if s == "" then
		return nil
	end
	if string.find(s, "rbxasset", 1, true) then
		return s
	end
	if string.match(s, "^%d+$") then
		return "rbxassetid://" .. s
	end
	return s
end

local function createCorner(parent: Instance, radius: number)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
	return corner
end

local function createStroke(parent: Instance, color: Color3, thickness: number, transparency: number?)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Transparency = transparency or 0
	stroke.Parent = parent
	return stroke
end

local function createPadding(parent: Instance, px: number)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, px)
	p.PaddingBottom = UDim.new(0, px)
	p.PaddingLeft = UDim.new(0, px)
	p.PaddingRight = UDim.new(0, px)
	p.Parent = parent
	return p
end

local function createList(parent: Instance, pad: number, align: Enum.HorizontalAlignment?)
	local list = Instance.new("UIListLayout")
	list.Padding = UDim.new(0, pad)
	list.FillDirection = Enum.FillDirection.Vertical
	list.HorizontalAlignment = align or Enum.HorizontalAlignment.Left
	list.SortOrder = Enum.SortOrder.LayoutOrder
	list.Parent = parent
	return list
end

local function getGuiPointerPosition(): Vector2
	local inset = GuiService:GetGuiInset()
	return UserInputService:GetMouseLocation() - inset
end

local function isPointerInsideGuiObject(gui: GuiObject, pointer: Vector2): boolean
	local absPos = gui.AbsolutePosition
	local absSize = gui.AbsoluteSize
	return pointer.X >= absPos.X
		and pointer.X <= absPos.X + absSize.X
		and pointer.Y >= absPos.Y
		and pointer.Y <= absPos.Y + absSize.Y
end

local function isMouseInside(gui: GuiObject)
	return isPointerInsideGuiObject(gui, getGuiPointerPosition())
end

local function isPointerOverLayerCollectorSubtree(
	collector: LayerCollector,
	screenPos: Vector2,
	exclude: GuiObject?
): boolean
	if not collector.Enabled then
		return false
	end
	local ok, list = pcall(function()
		return GuiService:GetGuiObjectsAtPosition(screenPos.X, screenPos.Y)
	end)
	if not ok or type(list) ~= "table" then
		return false
	end
	for _, inst in ipairs(list :: { Instance }) do
		if exclude and (inst == exclude or inst:IsDescendantOf(exclude)) then
			continue
		end
		if inst:IsDescendantOf(collector) and inst:IsA("GuiObject") then
			local g = inst :: GuiObject
			local visOk = true
			local w: Instance? = g
			while w and w ~= collector do
				if w:IsA("GuiObject") and not (w :: GuiObject).Visible then
					visOk = false
					break
				end
				w = w.Parent
			end
			if visOk then
				return true
			end
		end
	end
	return false
end

local function trySetToolTip(gui: GuiObject, text: string?)
	if type(text) ~= "string" or text == "" then
		return
	end
	pcall(function()
		(gui :: any).ToolTip = text
	end)
end

local function tweenWatermarkIn(gui: GuiObject)
	if gui:IsA("CanvasGroup") then
		local cg = gui :: CanvasGroup
		cg.GroupTransparency = 1
		local sc = gui:FindFirstChildOfClass("UIScale")
		if not sc then
			sc = Instance.new("UIScale")
			sc.Parent = gui
		end
		sc.Scale = 0.96
		task.defer(function()
			if not gui.Parent then
				return
			end
			tween(cg, TweenInfo.new(0.42, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { GroupTransparency = 0 })
			tween(sc, TweenInfo.new(0.42, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Scale = 1 })
		end)
		return
	end
	local frame = gui :: Frame
	local sc = frame:FindFirstChildOfClass("UIScale")
	if not sc then
		sc = Instance.new("UIScale")
		sc.Parent = frame
	end
	sc.Scale = 0.88
	frame.BackgroundTransparency = 1
	for _, d in frame:GetDescendants() do
		if d:IsA("TextLabel") or d:IsA("TextButton") then
			d.TextTransparency = 1
		end
		if d:IsA("UIStroke") then
			d.Transparency = 1
		end
	end
	task.defer(function()
		if not frame.Parent then
			return
		end
		TweenService:Create(
			frame,
			TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ BackgroundTransparency = 0 }
		):Play()
		TweenService:Create(sc, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 }):Play()
		for _, d in frame:GetDescendants() do
			if d:IsA("TextLabel") or d:IsA("TextButton") then
				TweenService:Create(d, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextTransparency = 0 })
					:Play()
			end
			if d:IsA("UIStroke") then
				TweenService:Create(d, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Transparency = 0.35 })
					:Play()
			end
		end
	end)
end

local function tweenWatermarkOutBlocking(gui: GuiObject)
	if not gui or not gui.Parent then
		return
	end
	if gui:IsA("CanvasGroup") then
		local t = TweenService:Create(
			gui,
			TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{ GroupTransparency = 1 }
		)
		t:Play()
		t.Completed:Wait()
		task.wait(0.03)
		if gui.Parent then
			gui:Destroy()
		end
		return
	end
	local frame = gui :: Frame
	local sc = frame:FindFirstChildOfClass("UIScale")
	if not sc then
		sc = Instance.new("UIScale")
		sc.Scale = 1
		sc.Parent = frame
	end
	local ti = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	TweenService:Create(sc, ti, { Scale = 0.86 }):Play()
	for _, d in frame:GetDescendants() do
		if d:IsA("TextLabel") or d:IsA("TextButton") then
			TweenService:Create(d, ti, { TextTransparency = 1 }):Play()
		end
		if d:IsA("UIStroke") then
			TweenService:Create(d, ti, { Transparency = 1 }):Play()
		end
	end
	local t = TweenService:Create(frame, ti, { BackgroundTransparency = 1 })
	t:Play()
	t.Completed:Wait()
	task.wait(0.03)
	if frame.Parent then
		frame:Destroy()
	end
end

