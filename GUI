function UiLib:Hide()
    if not self.Visible then return end
    self.Visible = false
    local win = self.Window
    local showBtn = self._showBtn
    local showGui = self._showGui

    -- 动画缩小窗口
    local targetSize = win.Size
    local targetPos = win.Position
    tw(win, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 60, 0, 24),
        GroupTransparency = 1,
    })

    task.delay(0.28, function()
        if not win.Parent then return end
        win.Visible = false
        win.Size = targetSize
        win.Position = targetPos
        win.GroupTransparency = 0

        -- 修复：将缩小按钮放在窗口原来的屏幕位置附近
        if showBtn and showGui then
            showGui.Enabled = true
            -- 使用窗口当前位置来设置缩小按钮位置
            local absPos = win.AbsolutePosition
            local absSize = win.AbsoluteSize
            local vp = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
            local cx = math.clamp(absPos.X + absSize.X / 2, 30, vp.X - 30)
            local cy = math.clamp(absPos.Y + 20, 30, vp.Y - 30)
            showBtn.Position = UDim2.new(0, cx, 0, cy)
        end
    end)
end

function UiLib:Show()
    if self.Visible then return end
    self.Visible = true
    local win = self.Window
    local showGui = self._showGui

    if showGui then
        showGui.Enabled = false
    end

    if not win.Visible then
        win.Visible = true
        win.GroupTransparency = 1
        local smallSize = UDim2.new(0, 60, 0, 24)
        win.Size = smallSize

        tw(win, TweenInfo.new(0.32, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = self._targetWindowSize,
            GroupTransparency = 0,
        })
    end
end

function UiLib:Toggle()
    if self.Visible then
        self:Hide()
    else
        self:Show()
    end
end

function UiLib:Destroy()
    -- 清理连接
    for _, conn in ipairs(self._connections or {}) do
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        end
    end
    self._connections = {}

    -- 销毁所有GUI
    local gui = self.RootGui
    if gui then
        pcall(function() gui:Destroy() end)
    end

    local showGui = self._showGui
    if showGui then
        pcall(function() showGui:Destroy() end)
    end

    -- 销毁watermark
    if self._watermark and self._watermark.Parent then
        pcall(function() self._watermark:Destroy() end)
    end

    -- 从全局移除引用
    pcall(function()
        local mt = getmetatable(self)
        if mt then setmetatable(self, nil) end
    end)
end

-- ═══════════════════════════════════════
--  导出
-- ═══════════════════════════════════════
return UiLib
