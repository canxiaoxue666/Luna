			keyLabel.Text = current == Enum.KeyCode.Unknown and "None" or current.Name
		end
		local function startListening()
			if listening then return end
			listening = true
			keyLabel.Text = "..."
			conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
				if gameProcessed then return end
				if input.UserInputType == Enum.UserInputType.Keyboard or input.UserInputType == Enum.UserInputType.MouseButton1 then
					current = input.KeyCode
					listening = false
					updateDisplay()
					if conn then conn:Disconnect() conn = nil end
					if opts.Callback then opts.Callback(current) end
				end
			end)
		end
		keyLabel.MouseButton1Click:Connect(function()
			if listening then
				listening = false
				if conn then conn:Disconnect() conn = nil end
				updateDisplay()
			else
				startListening()
			end
		end)
		return {
			Set = function(_, k) current = k updateDisplay() end,
			Get = function() return current end,
		}
