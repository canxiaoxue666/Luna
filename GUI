		valueLabel.Font = Enum.Font.Gotham
		valueLabel.TextSize = 12
		valueLabel.TextColor3 = THEME.TextSoft
		valueLabel.Parent = card

		local bar = Instance.new("Frame")
		bar.Position = UDim2.new(0, 12, 1, -22)
		bar.Size = UDim2.new(1, -24, 0, 20)
		bar.BackgroundColor3 = Color3.fromRGB(58, 63, 79)
		bar.Parent = card
		createCorner(bar, 999)

		local dragHitbox = Instance.new("TextButton")
		dragHitbox.Name = "DragHitbox"
		dragHitbox.BackgroundTransparency = 1
		dragHitbox.Text = ""
		dragHitbox.AutoButtonColor = false
		dragHitbox.Position = UDim2.new(0, 0, 0.5, -16)
		dragHitbox.Size = UDim2.new(1, 0, 0, 32)
		dragHitbox.ZIndex = 5
		dragHitbox.Parent = bar

		local fill = Instance.new("Frame")
		fill.Size = UDim2.new(0, 0, 1, 0)
		fill.BackgroundColor3 = THEME.Accent
		fill.Parent = bar
		createCorner(fill, 999)

		local dragging = false
		local activeInput: InputObject?

		local function setByX(mouseX: number)
			local startX = bar.AbsolutePosition.X
			local width = bar.AbsoluteSize.X
			local alpha = math.clamp((mouseX - startX) / width, 0, 1)
			local raw = min + (max - min) * alpha
			local snapped = math.floor(raw / step + 0.5) * step
			value = normalizeNumber(math.clamp(snapped, min, max))
			local percent = (value - min) / (max - min)
			fill.Size = UDim2.new(percent, 0, 1, 0)
			valueLabel.Text = formatValue(value)
			if opts.Callback then opts.Callback(value) end
		end

		local function updateVisual()
			local percent = (value - min) / (max - min)
			fill.Size = UDim2.new(percent, 0, 1, 0)
			value = normalizeNumber(value)
			valueLabel.Text = formatValue(value)
		end
		updateVisual()

		local function isDragInput(input: InputObject): boolean
			return input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch
		end

		dragHitbox.InputBegan:Connect(function(input)
			if not isDragInput(input) then return end
			dragging = true
			activeInput = input
			setByX(input.Position.X)
		end)

		UserInputService.InputChanged:Connect(function(input)
			if not dragging then return end
			if activeInput and input ~= activeInput then return end
			if not isDragInput(input) then return end
			setByX(input.Position.X)
		end)

		UserInputService.InputEnded:Connect(function(input)
			if not dragging then return end
			if activeInput and input ~= activeInput then return end
			if not isDragInput(input) then return end
			dragging = false
			activeInput = nil
		end)

		return {
			Set = function(_, val) value = math.clamp(val, min, max) updateVisual() end,
			Get = function() return value end
		}
	end

