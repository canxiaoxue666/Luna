	function api:Slider(opts)
		api._embedColorTarget = nil
		opts = opts or {}
		local title = opts.Title or "Slider"
		local min = opts.Min or 0
		local max = opts.Max or 100
		local value = math.clamp(opts.Default or min, min, max)
		local step = opts.Step or 1
		local stepStr = tostring(step)
		local dotIndex = string.find(stepStr, "%.")
		local decimals = dotIndex and (#stepStr - dotIndex) or 0

		local function normalizeNumber(n: number)
			if decimals <= 0 then
				return math.floor(n + 0.5)
			end
			local mul = 10 ^ decimals
			return math.floor(n * mul + 0.5) / mul
		end

		local function formatValue(n: number)
			local fixed = normalizeNumber(n)
			if decimals <= 0 then
				return tostring(fixed)
			end
			local s = string.format("%." .. tostring(decimals) .. "f", fixed)
			s = s:gsub("0+$", ""):gsub("%.$", "")
			return s
		end

