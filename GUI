				task.spawn(opts.Callback, ...)
			end
		end

		local inputBeganConn: RBXScriptConnection? = nil
		local inputEndedConn: RBXScriptConnection? = nil

		local function disconnectInputs()
			if inputBeganConn then
				inputBeganConn:Disconnect()
				inputBeganConn = nil
			end
			if inputEndedConn then
				inputEndedConn:Disconnect()
				inputEndedConn = nil
			end
		end

		local function wireInputs()
			disconnectInputs()
			inputBeganConn = UserInputService.InputBegan:Connect(function(input: InputObject, gameProcessedEvent: boolean)
				if waitingForKey then
					if input.UserInputType == Enum.UserInputType.Keyboard then
						if input.KeyCode == Enum.KeyCode.Escape then
							waitingForKey = false
							updateKeyLabel()
							return
						end
						if input.KeyCode == Enum.KeyCode.Backspace or input.KeyCode == Enum.KeyCode.Delete then
							binding = nil
							waitingForKey = false
							updateKeyLabel()
							return
						end
						if input.KeyCode ~= Enum.KeyCode.Unknown then
							binding = { kind = "key", code = input.KeyCode }
							waitingForKey = false
							updateKeyLabel()
						end
						return
					end
					if
						input.UserInputType == Enum.UserInputType.MouseButton1
						or input.UserInputType == Enum.UserInputType.MouseButton2
						or input.UserInputType == Enum.UserInputType.MouseButton3
					then
						binding = { kind = "mouse", code = input.UserInputType }
						waitingForKey = false
						updateKeyLabel()
					end
					return
				end

				if not enabled or not binding then
					return
				end
				if gameProcessedEvent then
					return
				end
				if UserInputService:GetFocusedTextBox() then
					return
				end
				if not bindingMatchesInput(input, binding) then
					return
				end

				if mode == "hold" then
					if holdActive then
						return
					end
					holdActive = true
					fireCallback(true)
					return
				end

				toggleLatch = not toggleLatch
				fireCallback(toggleLatch)
			end)

			inputEndedConn = UserInputService.InputEnded:Connect(function(input: InputObject, gameProcessedEvent: boolean)
				if waitingForKey then
					return
				end
				if not enabled or not binding or mode ~= "hold" then
					return
				end
				if gameProcessedEvent then
					return
				end
				if not bindingMatchesInput(input, binding) then
					return
				end
				if holdActive then
					holdActive = false
					fireCallback(false)
				end
			end)
		end

		updateKeyLabel()
		updateModeLabel()
		applyEnabledVisual()
		wireInputs()

		keyButton.MouseButton1Click:Connect(function()
			if not enabled then
				return
			end
			task.delay(0.12, function()
				if not card.Parent then
					return
				end
				waitingForKey = true
				updateKeyLabel()
			end)
		end)

		modeToggle.MouseButton1Click:Connect(function()
			if not enabled then
				return
			end
			mode = if mode == "hold" then "toggle" else "hold"
			holdActive = false
			toggleLatch = false
			updateModeLabel()
			if opts.ModeChanged then
				task.spawn(opts.ModeChanged, mode)
			end
		end)

		local kbApi = {
			Set = function(_, val: any)
				waitingForKey = false
				if type(val) == "table" and (val.kind == "key" or val.kind == "mouse") and typeof(val.code) == "EnumItem" then
					binding = val
				else
					binding = normalizeDefault(val)
				end
				updateKeyLabel()
			end,
			Get = function()
				return binding
			end,
			GetKeyCode = function()
				return binding and binding.kind == "key" and binding.code or nil
			end,
			GetUserInputType = function()
				return binding and binding.kind == "mouse" and binding.code or nil
			end,
			SetMode = function(_, m: string)
				mode = (m == "hold" and "hold") or "toggle"
				holdActive = false
				toggleLatch = false
				updateModeLabel()
			end,
			GetMode = function()
				return mode
			end,
			SetEnabled = function(_, v: boolean)
				enabled = v == true
				if not enabled then
					waitingForKey = false
					if holdActive and opts.Callback then
						holdActive = false
						task.spawn(opts.Callback, false)
					end
					updateKeyLabel()
				end
				applyEnabledVisual()
			end,
			Trigger = function()
				if not binding then
					return
				end
				if mode == "hold" then
					fireCallback(true)
					task.defer(function()
						fireCallback(false)
					end)
					return
				end
				toggleLatch = not toggleLatch
				fireCallback(toggleLatch)
			end,
			Destroy = function()
				waitingForKey = false
				disconnectInputs()
				if card and card.Parent then
					card:Destroy()
				end
			end,
			Instance = card,
		}
		registerConfigIfAny(opts, kbApi)
		return kbApi
	end

