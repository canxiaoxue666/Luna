    local function applyScale()
        if opts.Responsive == false then uiScale.Scale = 1 return end
        local vp = getViewport()
        local bx = window.Size.X.Offset > 0 and window.Size.X.Offset or 620
        local by = window.Size.Y.Offset > 0 and window.Size.Y.Offset or 430
