-- ═══════════════════════════════════════
--  工具函数
-- ═══════════════════════════════════════
local function tw(instance, info, props)
    local t = TweenService:Create(instance, info, props)
    t:Play()
    return t
end

local function createCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius)
    c.Parent = parent
    return c
end

local function createStroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0
    s.Parent = parent
    return s
end

local function createPadding(parent, px)
    local p = Instance.new("UIPadding")
    p.PaddingTop = UDim.new(0, px)
    p.PaddingBottom = UDim.new(0, px)
    p.PaddingLeft = UDim.new(0, px)
    p.PaddingRight = UDim.new(0, px)
    p.Parent = parent
    return p
end

local function createList(parent, pad, align)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, pad)
    l.FillDirection = Enum.FillDirection.Vertical
    l.HorizontalAlignment = align or Enum.HorizontalAlignment.Left
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

local function normalizeBackdropImage(input)
    if input == nil or input == false then return nil end
    if type(input) == "number" then return "rbxassetid://" .. tostring(input) end
    local s = tostring(input)
    if s == "" then return nil end
    if string.find(s, "rbxasset", 1, true) then return s end
    if string.match(s, "^%d+$") then return "rbxassetid://" .. s end
    return s
end

local function getGuiPointerPosition()
    local inset = GuiService:GetGuiInset()
    return UserInputService:GetMouseLocation() - inset
end

local function isPointerInsideGuiObject(gui, pointer)
    local ap = gui.AbsolutePosition
    local as = gui.AbsoluteSize
    return pointer.X >= ap.X and pointer.X <= ap.X + as.X
        and pointer.Y >= ap.Y and pointer.Y <= ap.Y + as.Y
end

local function isMouseInside(gui)
    return isPointerInsideGuiObject(gui, getGuiPointerPosition())
end

local function isPointerOverLayerCollector(collector, screenPos, exclude)
    if not collector.Enabled then return false end
    local ok, list = pcall(function()
        return GuiService:GetGuiObjectsAtPosition(screenPos.X, screenPos.Y)
    end)
    if not ok or type(list) ~= "table" then return false end
    for _, inst in ipairs(list) do
        if exclude and (inst == exclude or inst:IsDescendantOf(exclude)) then continue end
        if inst:IsDescendantOf(collector) and inst:IsA("GuiObject") then
            local visOk = true
            local w = inst
            while w and w ~= collector do
                if w:IsA("GuiObject") and not w.Visible then
                    visOk = false
                    break
                end
                w = w.Parent
            end
            if visOk then return true end
        end
    end
    return false
end

local function ensurePlayerGui()
    return game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
end

-- ═══════════════════════════════════════
--  图标解析器
-- ═══════════════════════════════════════
local function resolveIcon(icon)
    if icon == nil then return { type = "none" } end
    if type(icon) == "table" then
        if icon.Type == "text" then
            return { type = "text", text = tostring(icon.Text or "") }
        end
        if icon.Type == "image" or icon.Image or icon.Url then
            local url = tostring(icon.Image or icon.Url or "")
            if url ~= "" then return { type = "image", url = url } end
        end
        return { type = "none" }
    end
    local s = tostring(icon)
    if s == "" then return { type = "none" } end
    if string.sub(s, 1, 5) == "text:" then
        return { type = "text", text = string.sub(s, 6) }
    end
    if string.find(s, "https?://", 1, true) then
        return { type = "image", url = s }
    end
    if string.find(s, "rbxasset", 1, true) then
        return { type = "image", url = s }
    end
    if string.match(s, "^%d+$") then
        return { type = "image", url = "rbxassetid://" .. s }
    end
    return { type = "text", text = s }
end

local function applyIconToContainer(container, iconInfo, size, color, textSize)
    for _, child in container:GetChildren() do
        if child.Name == "_DynIcon" then child:Destroy() end
    end
    if iconInfo.type == "none" then return nil end
    if iconInfo.type == "image" then
        local img = Instance.new("ImageLabel")
        img.Name = "_DynIcon"
        img.BackgroundTransparency = 1
        img.Size = size or UDim2.new(0, 20, 0, 20)
        img.Image = iconInfo.url
        img.ImageColor3 = color or THEME.Text
        img.ScaleType = Enum.ScaleType.Fit
        img.Parent = container
        return img
    end
    if iconInfo.type == "text" then
        local txt = Instance.new("TextLabel")
        txt.Name = "_DynIcon"
        txt.BackgroundTransparency = 1
        txt.Size = size or UDim2.new(0, 20, 0, 20)
        txt.Text = iconInfo.text
        txt.TextColor3 = color or THEME.Accent
        txt.TextSize = textSize or 14
        txt.Font = FONTS.Bold
        txt.TextScaled = true
        txt.Parent = container
        return txt
    end
    return nil
end

-- ═══════════════════════════════════════
--  Watermark动画
-- ═══════════════════════════════════════
local function tweenWatermarkIn(gui)
    if gui:IsA("CanvasGroup") then
        gui.GroupTransparency = 1
        local sc = gui:FindFirstChildOfClass("UIScale")
        if not sc then
            sc = Instance.new("UIScale")
            sc.Parent = gui
        end
        sc.Scale = 0.96
        task.defer(function()
            if not gui.Parent then return end
            tw(gui, TweenInfo.new(0.42, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { GroupTransparency = 0 })
            tw(sc, TweenInfo.new(0.42, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Scale = 1 })
        end)
        return
    end
    local sc = gui:FindFirstChildOfClass("UIScale")
    if not sc then
        sc = Instance.new("UIScale")
        sc.Parent = gui
    end
    sc.Scale = 0.88
    gui.BackgroundTransparency = 1
    for _, d in gui:GetDescendants() do
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            d.TextTransparency = 1
        end
    end
    task.defer(function()
        if not gui.Parent then return end
        tw(gui, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 0 })
        tw(sc, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 })
        for _, d in gui:GetDescendants() do
            if d:IsA("TextLabel") or d:IsA("TextButton") then
                tw(d, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { TextTransparency = 0 })
            end
        end
    end)
end

local function tweenWatermarkOutBlocking(gui)
    if not gui or not gui.Parent then return end
    if gui:IsA("CanvasGroup") then
        local t = tw(gui, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { GroupTransparency = 1 })
        t.Completed:Wait()
        task.wait(0.03)
        if gui.Parent then gui:Destroy() end
        return
    end
    local sc = gui:FindFirstChildOfClass("UIScale")
    if not sc then
        sc = Instance.new("UIScale")
        sc.Scale = 1
        sc.Parent = gui
    end
    local ti = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    tw(sc, ti, { Scale = 0.86 })
    for _, d in gui:GetDescendants() do
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            tw(d, ti, { TextTransparency = 1 })
        end
    end
    local t = tw(gui, ti, { BackgroundTransparency = 1 })
    t:Play()
    t.Completed:Wait()
    task.wait(0.03)
    if gui.Parent then gui:Destroy() end
end

