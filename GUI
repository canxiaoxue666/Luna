function UiLib:Show()
	if self.RootGui then
		if self.Window and self._targetWindowSize and self._targetWindowPosition then
			self.Window.Visible = true
			self.Window.AnchorPoint = Vector2.new(0.5, 0.5)
			local tws = self._targetWindowSize.X.Offset
			local ths = self._targetWindowSize.Y.Offset
			local startSize = UDim2.new(
				self._targetWindowSize.X.Scale,
				math.max(math.floor(tws * 0.22), 40),
				self._targetWindowSize.Y.Scale,
				math.max(math.floor(ths * 0.22), 36)
			)
			local cam = Workspace.CurrentCamera
			local yOff = math.floor((cam and cam.ViewportSize.Y or 800) * 0.1 + 0.5)
			local startPos = UDim2.new(0.5, 0, 0, yOff)
			self.Window.Size = startSize
			self.Window.Position = startPos
			self.Window.BackgroundTransparency = self._windowFrameTransparency or 0
			self.Window.GroupTransparency = 1
		end
		self.RootGui.Enabled = true
		if self.Window and self._targetWindowSize and self._targetWindowPosition then
			tween(self.Window, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = self._targetWindowSize,
				Position = self._targetWindowPosition,
				GroupTransparency = 0,
			})
		end
		local wm = self._watermark
		if wm and wm.Parent and wm:IsA("CanvasGroup") then
			wm.GroupTransparency = 1
			tween(wm, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { GroupTransparency = 0 })
		end
		if self._showGui then
			local showBtn = self._showGui:FindFirstChild("ShowUI")
			if showBtn and showBtn:IsA("GuiObject") then
				showBtn.Active = false
				local hideTween = tween(showBtn, ANIM.Normal, {
					BackgroundTransparency = 1,
					ImageTransparency = 1,
					Size = UDim2.new(0, 10, 0, 10)
				})
				hideTween.Completed:Connect(function()
					if self._showGui then
						self._showGui.Enabled = false
					end
					if showBtn and showBtn.Parent then
						showBtn.Size = UDim2.new(0, 44, 0, 44)
						showBtn.BackgroundTransparency = 0
						showBtn.ImageTransparency = 0
						showBtn.Active = true
					end
				end)
			else
				self._showGui.Enabled = false
			end
		end
		self.Visible = true
	end
end

function UiLib:Hide()
	if self.RootGui and self.Window and self.Window.Visible then
		local window = self.Window
		self._targetWindowSize = window.Size
		self._targetWindowPosition = window.Position
		self._targetWindowAnchor = window.AnchorPoint
		local shrinkW = math.max(math.floor(window.Size.X.Offset * 0.22), 40)
		local shrinkH = math.max(math.floor(window.Size.Y.Offset * 0.22), 36)
		local shrinkSize = UDim2.new(window.Size.X.Scale, shrinkW, window.Size.Y.Scale, shrinkH)
		local cam = Workspace.CurrentCamera
		local vps = cam and cam.ViewportSize or Vector2.new(1920, 1080)
		local pad = 18
		local parent = window.Parent
		local pAbs = Vector2.zero
		if parent then
			pcall(function()
				pAbs = (parent :: any).AbsolutePosition
			end)
		end
		local screenCenter = Vector2.new(vps.X - pad - shrinkW * 0.5, pad + shrinkH * 0.5)
		local off = screenCenter - pAbs
		local endPos = UDim2.fromOffset(math.floor(off.X + 0.5), math.floor(off.Y + 0.5))
		local wm = self._watermark
		if wm and wm.Parent and wm:IsA("CanvasGroup") then
			tween(wm, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In), { GroupTransparency = 1 })
		end
		local hideTween = tween(window, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = shrinkSize,
			Position = endPos,
			GroupTransparency = 1,
		})
		hideTween.Completed:Connect(function()
			if self.Window then
				self.Window.Visible = false
			end
			if self._showGui then
				local showBtn = self._showGui:FindFirstChild("ShowUI")
				self._showGui.Enabled = true
				if showBtn and showBtn:IsA("GuiObject") then
					local camNow = Workspace.CurrentCamera
					local vps = camNow and camNow.ViewportSize or Vector2.new(1920, 1080)
					local targetX = math.floor(vps.X * 0.5 + 0.5)
					local targetY = math.floor(vps.Y * 0.1 + 0.5)
					local clampFn = self._clampShowButtonOffset
					if type(clampFn) ~= "function" then
						return
					end
					local clampedX, clampedY = clampFn(targetX, targetY)
					showBtn.Position = UDim2.new(0, clampedX, 0, clampedY)
					showBtn.Size = UDim2.new(0, 10, 0, 10)
					showBtn.BackgroundTransparency = 1
					showBtn.ImageTransparency = 1
					tween(showBtn, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
						BackgroundTransparency = 0,
						ImageTransparency = 0,
						Size = UDim2.new(0, 44, 0, 44)
					})
				end
			end
			if self.Window then
				self.Window.AnchorPoint = self._targetWindowAnchor or Vector2.new(0.5, 0.5)
				self.Window.Size = self._targetWindowSize or self.Window.Size
				self.Window.Position = self._targetWindowPosition or self.Window.Position
				self.Window.BackgroundTransparency = self._windowFrameTransparency or 0
				self.Window.GroupTransparency = 0
			end
		end)
		self.Visible = false
	end
end

function UiLib:Toggle()
	if self.Visible then
		self:Hide()
	else
		self:Show()
	end
end

function UiLib:SetTabActive(tabName: string)
	if self._activeTab == tabName then
		return
	end

	cancelTabPageTweens(self)
	self._tabAnimSeq = (self._tabAnimSeq or 0) + 1
	local animSeq = self._tabAnimSeq

	local newPage = self._pages[tabName]
	if not (typeof(newPage) == "Instance" and newPage:IsA("GuiObject")) then
		return
	end

	local firstActivation = self._activeTab == nil

	for name, btn in pairs(self._tabButtons) do
		local active = name == tabName
		if typeof(btn) == "Instance" and btn:IsA("TextButton") then
			tween(btn, ANIM.TabButton, {
				BackgroundColor3 = active and THEME.AccentSoft or THEME.Card,
				BackgroundTransparency = active and 0 or 0.25,
				TextColor3 = active and THEME.Text or THEME.TextSoft,
			})
		else
			self._tabButtons[name] = nil
		end
	end

	local function snapPage(page: GuiObject, visible: boolean, scale: number)
		tabPageEnsureScale(page).Scale = scale
		page.Visible = visible
	end

	if firstActivation then
		for name, page in pairs(self._pages) do
			if typeof(page) == "Instance" and page:IsA("GuiObject") then
				if name == tabName then
					snapPage(page, true, 1)
				else
					snapPage(page, false, 1)
				end
			else
				self._pages[name] = nil
			end
		end
		self._activeTab = tabName
		return
	end

	local outgoingName: string? = nil
	local outgoingPage: GuiObject? = nil
	for name, page in pairs(self._pages) do
		if typeof(page) == "Instance" and page:IsA("GuiObject") and page.Visible and name ~= tabName then
			outgoingName = name
			outgoingPage = page
			break
		end
	end

	for name, page in pairs(self._pages) do
		if typeof(page) == "Instance" and page:IsA("GuiObject") then
			if name ~= tabName and name ~= outgoingName then
				snapPage(page, false, 1)
			end
		else
			self._pages[name] = nil
		end
	end

	local newSc = tabPageEnsureScale(newPage)
	newPage.Visible = false
	newSc.Scale = 0

	if not outgoingPage or outgoingPage == newPage then
		newPage.Visible = true
		newSc.Scale = 0
		registerTabTween(self, tween(newSc, ANIM.TabGrow, { Scale = 1 }))
		self._activeTab = tabName
		return
	end

	local oldSc = tabPageEnsureScale(outgoingPage)
	if oldSc.Scale < 0.02 then
		oldSc.Scale = 1
	end
	outgoingPage.Visible = true

	local shrinkTw = tween(oldSc, ANIM.TabShrink, { Scale = 0 })
	registerTabTween(self, shrinkTw)

	shrinkTw.Completed:Connect(function(playbackState: Enum.PlaybackState)
		if playbackState ~= Enum.PlaybackState.Completed then
			return
		end
		if animSeq ~= self._tabAnimSeq then
			return
		end
		outgoingPage.Visible = false
		oldSc.Scale = 1
		newPage.Visible = true
		newSc.Scale = 0
		local growTw = tween(newSc, ANIM.TabGrow, { Scale = 1 })
		registerTabTween(self, growTw)
	end)

	self._activeTab = tabName
end

