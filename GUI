        end)

        local optionBtns = {}

        local function getMultiOrdered()
            local sel = {}
            if not selectedMap then return sel end
            for _, v in ipairs(values) do
                if selectedMap[v] then table.insert(sel, v) end
            end
            return sel
        end

        local function refreshHeader()
            if multi then
                local list = getMultiOrdered()
                local c = #list
                if c == 0 then vl.Text = "None"
                elseif c <= maxDisplay then vl.Text = table.concat(list, ", ")
                else vl.Text = list[1] .. " +" .. tostring(c - 1) end
            else
                vl.Text = tostring(selected)
            end
        end

        local function refreshOptStyle(ob, sel)
            ob.BackgroundColor3 = sel and THEME.AccentDark or THEME.Bg2
            ob.TextColor3 = sel and THEME.Text or THEME.TextSoft
        end

        local function setOpen(flag)
            open = flag
            if searchFrame then searchFrame.Visible = enableSearch and flag end
            if flag and enableSearch and searchBox then searchBox.Text = "" end
            local vh = visCount > 0 and (visCount * 24 - 3) or 0
            optHolder.Size = UDim2.new(1, -12, 0, flag and vh or 0)
