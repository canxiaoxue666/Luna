local function moonSerializeValue(v: any): any
	if v == nil then
		return nil
	end
	local vt = typeof(v)
	if vt == "Color3" then
		local c = v :: Color3
		return { _moon = "Color3", R = c.R, G = c.G, B = c.B }
	end
	if vt == "EnumItem" then
		local e = v :: EnumItem
		return { _moon = "Enum", et = tostring(e.EnumType), n = e.Name }
	end
	if vt == "boolean" or vt == "number" or vt == "string" then
		return v
	end
	if type(v) ~= "table" then
		return tostring(v)
	end
	if v.kind == "key" and typeof(v.code) == "EnumItem" then
		return { kind = "key", code = moonSerializeValue(v.code) }
	end
	if v.kind == "mouse" and typeof(v.code) == "EnumItem" then
		return { kind = "mouse", code = moonSerializeValue(v.code) }
	end
	local len = #v
	local isArray = len > 0
	if isArray then
		for k in pairs(v) do
			if type(k) ~= "number" or k < 1 or k > len or math.floor(k) ~= k then
				isArray = false
				break
			end
		end
	end
	if isArray then
		local t = {}
		for i = 1, len do
			t[i] = moonSerializeValue(v[i])
		end
		return t
	end
	local out = {}
	for k, x in pairs(v) do
		out[tostring(k)] = moonSerializeValue(x)
	end
	return out
end

local function moonDeserializeValue(v: any): any
	if v == nil then
		return nil
	end
	if type(v) == "table" and v._moon == "Color3" then
		return Color3.new(v.R or 0, v.G or 0, v.B or 0)
	end
	if type(v) == "table" and v._moon == "Enum" then
		local et = v.et
		local n = v.n
		local bucket = (Enum :: any)[et]
		if type(bucket) == "table" and n then
			return bucket[n]
		end
		return nil
	end
	if type(v) == "table" and v.kind == "key" then
		local code = moonDeserializeValue(v.code)
		if typeof(code) == "EnumItem" and code.EnumType == Enum.KeyCode then
			return { kind = "key", code = code }
		end
		return nil
	end
	if type(v) == "table" and v.kind == "mouse" then
		local code = moonDeserializeValue(v.code)
		if typeof(code) == "EnumItem" and code.EnumType == Enum.UserInputType then
			return { kind = "mouse", code = code }
		end
		return nil
	end
	if type(v) == "table" then
		local arr = true
		local maxk = 0
		for k in pairs(v) do
			if type(k) ~= "number" then
				arr = false
				break
			end
			if k > maxk then
				maxk = k
			end
		end
		if arr and maxk > 0 then
			local t = {}
			for i = 1, maxk do
				t[i] = moonDeserializeValue(v[i])
			end
			return t
		end
	end
	return v
end

local function configEnsureFolder(folder: string)
	if type(folder) ~= "string" or folder == "" then
		return
	end
	if isfolder and makefolder and not isfolder(folder) then
		pcall(makefolder, folder)
	end
end

local function configReadFile(path: string): (boolean, string?)
	local ok, data = pcall(function()
		if not readfile then
			return nil
		end
		return readfile(path)
	end)
	if ok and type(data) == "string" then
		return true, data
	end
	return false, nil
end

local function configWriteFile(path: string, data: string): boolean
	if not writefile then
		return false
	end
	local ok = pcall(writefile, path, data)
	return ok == true
end

function UiLib:_registerConfigEntry(id: string, get: () -> any, set: (any) -> ())
	if type(id) ~= "string" or id == "" or type(get) ~= "function" or type(set) ~= "function" then
		return
	end
	self._configEntries = self._configEntries or {}
	local list = self._configEntries
	for i = #list, 1, -1 do
		if list[i].Id == id then
			table.remove(list, i)
		end
	end
	table.insert(list, { Id = id, Get = get, Set = set })
end

function UiLib:RegisterConfigEntry(entry: { Id: string, Get: () -> any, Set: (any) -> () })
	if type(entry) ~= "table" or type(entry.Id) ~= "string" then
		return
	end
	self:_registerConfigEntry(entry.Id, entry.Get, entry.Set)
end

function UiLib:ExportConfigTable(): { [string]: any }
	local out: { [string]: any } = {}
	for _, e in ipairs(self._configEntries or {}) do
		local ok, v = pcall(e.Get)
		if ok and v ~= nil then
			out[e.Id] = moonSerializeValue(v)
		end
	end
	return { _moonCfg = 1, entries = out }
end

function UiLib:ImportConfigTable(root: any): (boolean, string?)
	if type(root) ~= "table" then
		return false, "not_table"
	end
	local map = root
	if type(root.entries) == "table" then
		map = root.entries
	end
	for _, e in ipairs(self._configEntries or {}) do
		local raw = map[e.Id]
		if raw ~= nil then
			local dv = moonDeserializeValue(raw)
			pcall(e.Set, dv)
		end
	end
	return true, nil
end

function UiLib:GetConfigJson(): string
	local ok, s = pcall(function()
		return HttpService:JSONEncode(self:ExportConfigTable())
	end)
	if ok and type(s) == "string" then
		return s
	end
	return "{}"
end

function UiLib:SetConfigJson(json: string): (boolean, string?)
	local ok, data = pcall(function()
		return HttpService:JSONDecode(json)
	end)
	if not ok or type(data) ~= "table" then
		return false, "json"
	end
	return self:ImportConfigTable(data)
end

function UiLib:GetConfigFilePath(): string?
	return self._configFilePath
end

function UiLib:SaveConfigToFile(path: string?): (boolean, string?)
	local p = path or self._configFilePath
	if type(p) ~= "string" or p == "" then
		return false, "no_path"
	end
	local folder = string.match(p, "^(.*)/[^/]+$")
	if folder and folder ~= "" then
		configEnsureFolder(folder)
	end
	local json = self:GetConfigJson()
	if configWriteFile(p, json) then
		return true, nil
	end
	return false, "writefile"
end

function UiLib:LoadConfigFromFile(path: string?): (boolean, string?)
	local p = path or self._configFilePath
	if type(p) ~= "string" or p == "" then
		return false, "no_path"
	end
	local okR, data = configReadFile(p)
	if not okR or not data then
		return false, "readfile"
	end
	return self:SetConfigJson(data)
end

function UiLib:InstallConfigHub(opts: any?): any
	if self._configHubInstalled then
		return self._configHubHandle
	end
	opts = opts or {}
	local tabTitle = opts.TabTitle or opts.Title or "Config"
	local folder = opts.Folder or "MoonLua"
	local profileDefault = opts.ProfileDefault or "default"

	self._configFolder = folder
	self._configHubInstalled = true

	local tabApi = self:CreateTab(tabTitle)

	local statusLbl = tabApi:Label({
		Title = opts.StatusDefault or "Config: add opts.ConfigId on controls, or RegisterConfigEntry.",
	})

	local profileInput = tabApi:Input({
		Title = opts.ProfileTitle or "Profile",
		Placeholder = opts.ProfilePlaceholder or "default",
		Default = profileDefault,
		Callback = function() end,
	})

	local function profilePath(): string
		local name = tostring(profileInput:Get()):gsub("[^%w%-_%.]", "_")
		if name == "" then
			name = "default"
		end
		return folder .. "/" .. name .. ".json"
	end

	local function setStatus(text: string)
		if statusLbl and statusLbl.SetText then
			statusLbl:SetText(text)
		end
	end

	local function refreshPathHint()
		self._configFilePath = profilePath()
	end

	refreshPathHint()

	tabApi:Button({
		Title = opts.TitleSave or "Save to file",
		Callback = function()
			refreshPathHint()
			local p = profilePath()
			self._configFilePath = p
			local ok, err = self:SaveConfigToFile(p)
			if ok then
				setStatus("Saved: " .. p)
				UiLib.Notify({ Title = "Config", Content = "Saved", Type = "success" })
			else
				setStatus("Save failed: " .. tostring(err))
				UiLib.Notify({ Title = "Config", Content = "Save failed", Type = "error" })
			end
		end,
	})

	tabApi:Button({
		Title = opts.TitleLoad or "Load from file",
		Callback = function()
			refreshPathHint()
			local p = profilePath()
			self._configFilePath = p
			local okR, _ = configReadFile(p)
			if not okR then
				setStatus("No file: " .. p)
				UiLib.Notify({ Title = "Config", Content = "File not found", Type = "error" })
				return
			end
			local ok, err = self:LoadConfigFromFile(p)
			if ok then
				setStatus("Loaded: " .. p)
				UiLib.Notify({ Title = "Config", Content = "Loaded", Type = "success" })
			else
				setStatus("Load failed: " .. tostring(err))
				UiLib.Notify({ Title = "Config", Content = "Load failed", Type = "error" })
			end
		end,
	})

	tabApi:Button({
		Title = opts.TitleCopy or "Copy JSON",
		Callback = function()
			local json = self:GetConfigJson()
			if setclipboard then
				pcall(setclipboard, json)
				setStatus("JSON copied (" .. tostring(#json) .. " bytes)")
				UiLib.Notify({ Title = "Config", Content = "Copied", Type = "success" })
			else
				setStatus("setclipboard unavailable")
				UiLib.Notify({ Title = "Config", Content = "Clipboard unavailable", Type = "error" })
			end
		end,
	})

	tabApi:Button({
		Title = opts.TitlePaste or "Paste JSON",
		Callback = function()
			if not getclipboard then
				setStatus("getclipboard unavailable")
				return
			end
			local okc, clip = pcall(getclipboard)
			if not okc or type(clip) ~= "string" or clip == "" then
				setStatus("Clipboard empty")
				return
			end
			local ok, err = self:SetConfigJson(clip)
			if ok then
				setStatus("Imported from clipboard")
				UiLib.Notify({ Title = "Config", Content = "Imported", Type = "success" })
			else
				setStatus("Import failed: " .. tostring(err))
				UiLib.Notify({ Title = "Config", Content = "Import failed", Type = "error" })
			end
		end,
	})

	if type(opts.Entries) == "table" then
		for _, e in ipairs(opts.Entries) do
			if type(e) == "table" and type(e.Id) == "string" and type(e.Get) == "function" and type(e.Set) == "function" then
				self:RegisterConfigEntry(e)
			end
		end
	end

	if opts.AutoLoad ~= false then
		task.defer(function()
			refreshPathHint()
			local p = profilePath()
			self._configFilePath = p
			local okR, _ = configReadFile(p)
			if okR then
				local ok = self:LoadConfigFromFile(p)
				if ok then
					setStatus("Auto-loaded: " .. p)
				else
					setStatus("Auto-load parse failed")
				end
			else
				setStatus("No saved profile (ok)")
			end
		end)
	end

	self._configHubHandle = {
		TabTitle = tabTitle,
		ProfileInput = profileInput,
		Status = statusLbl,
		SetStatus = setStatus,
		ProfilePath = profilePath,
		Save = function()
			return self:SaveConfigToFile(profilePath())
		end,
		Load = function()
			return self:LoadConfigFromFile(profilePath())
		end,
		ExportJson = function()
			return self:GetConfigJson()
		end,
		ImportJson = function(json: string)
			return self:SetConfigJson(json)
		end,
	}
	return self._configHubHandle
end

