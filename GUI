	local function clampShowButtonOffset(x: number, y: number)
		local viewport = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
		local inset = GuiService:GetGuiInset()
		local halfW = showBtn.AbsoluteSize.X / 2
		local halfH = showBtn.AbsoluteSize.Y / 2
		local minX = (inset and inset.X or 0) + halfW
		local minY = (inset and inset.Y or 0) + halfH
		local clampedX = math.clamp(x, minX, viewport.X - halfW)
		local clampedY = math.clamp(y, minY, viewport.Y - halfH)
		return clampedX, clampedY
	end

	titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = window.Position
		end
	end)

	showBtn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			showDragging = true
			showDragStart = Vector2.new(input.Position.X, input.Position.Y)
			showStartPos = showBtn.Position
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
			showDragging = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			window.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
		if showDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local inputPos = Vector2.new(input.Position.X, input.Position.Y)
			local delta = inputPos - showDragStart
			local targetX = showStartPos.X.Offset + delta.X
			local targetY = showStartPos.Y.Offset + delta.Y
			local clampedX, clampedY = clampShowButtonOffset(targetX, targetY)
			showBtn.Position = UDim2.new(0, clampedX, 0, clampedY)
		end
	end)

	if opts.Watermark ~= false then
		self:CreateWatermark({
			Position = opts.WatermarkPosition or UDim2.new(0.8, 0, 0, 10)
		})
	end

	-- 启动动画保持
	window.BackgroundTransparency = 1
	window.Size = UDim2.new(
		self._targetWindowSize.X.Scale, math.floor(self._targetWindowSize.X.Offset * 0.78),
		self._targetWindowSize.Y.Scale, math.floor(self._targetWindowSize.Y.Offset * 0.78)
	)
	window.Position = UDim2.new(
		self._targetWindowPosition.X.Scale, self._targetWindowPosition.X.Offset,
		self._targetWindowPosition.Y.Scale, self._targetWindowPosition.Y.Offset + 16
	)
	tween(window, TweenInfo.new(0.34, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = self._targetWindowSize,
		Position = self._targetWindowPosition,
		BackgroundTransparency = THEME.WindowBgTransparency
	})

	return self
end

-- Show / Hide / Toggle 方法
function UiLib:Show()
	if self.RootGui then
		if self.Window and self._targetWindowSize and self._targetWindowPosition then
			self.Window.Visible = true
			local startSize = UDim2.new(
				self._targetWindowSize.X.Scale, math.floor(self._targetWindowSize.X.Offset * 0.78),
				self._targetWindowSize.Y.Scale, math.floor(self._targetWindowSize.Y.Offset * 0.78)
			)
			local shiftX = math.floor((self._targetWindowSize.X.Offset - startSize.X.Offset) * 0.5)
			local shiftY = math.floor((self._targetWindowSize.Y.Offset - startSize.Y.Offset) * 0.5)
			local startPos = UDim2.new(
				self._targetWindowPosition.X.Scale, self._targetWindowPosition.X.Offset - shiftX,
				self._targetWindowPosition.Y.Scale, self._targetWindowPosition.Y.Offset - shiftY
			)
			self.Window.Size = startSize
			self.Window.Position = startPos
			self.Window.BackgroundTransparency = 1
		end
		self.RootGui.Enabled = true
		if self.Window and self._targetWindowSize and self._targetWindowPosition then
			tween(self.Window, TweenInfo.new(0.38, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = self._targetWindowSize,
				Position = self._targetWindowPosition,
				BackgroundTransparency = THEME.WindowBgTransparency
			})
		end
		if self._showGui then
			local showBtn = self._showGui:FindFirstChild("ShowUI")
			if showBtn and showBtn:IsA("GuiObject") then
				showBtn.Active = false
				local hideTween = tween(showBtn, ANIM.Normal, {
					BackgroundTransparency = 1,
					ImageTransparency = 1,
					Size = UDim2.new(0, 10, 0, 10)
				})
				hideTween.Completed:Connect(function()
					if self._showGui then self._showGui.Enabled = false end
					if showBtn and showBtn.Parent then
						showBtn.Size = UDim2.new(0, 44, 0, 44)
						showBtn.BackgroundTransparency = 0.15
						showBtn.ImageTransparency = 0
						showBtn.Active = true
					end
				end)
			else
				self._showGui.Enabled = false
			end
		end
		self.Visible = true
	end
end

function UiLib:Hide()
	if self.RootGui and self.Window and self.Window.Visible then
		local window = self.Window
		self._targetWindowSize = window.Size
		self._targetWindowPosition = window.Position
		local shrinkSize = UDim2.new(
			window.Size.X.Scale, math.floor(window.Size.X.Offset * 0.3),
			window.Size.Y.Scale, math.floor(window.Size.Y.Offset * 0.3)
		)
		local shiftX = math.floor((window.Size.X.Offset - shrinkSize.X.Offset) * 0.5)
		local shiftY = math.floor((window.Size.Y.Offset - shrinkSize.Y.Offset) * 0.5)
		local vanishPos = UDim2.new(
			window.Position.X.Scale, window.Position.X.Offset - shiftX - math.floor(window.Size.X.Offset * 0.12),
			window.Position.Y.Scale, window.Position.Y.Offset - shiftY - math.floor(window.Size.Y.Offset * 0.12)
		)
		local hideTween = tween(window, TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
			Size = shrinkSize,
			Position = vanishPos,
			BackgroundTransparency = 1
		})
		hideTween.Completed:Connect(function()
			if self.Window then self.Window.Visible = false end
			if self._showGui then
				local showBtn = self._showGui:FindFirstChild("ShowUI")
				self._showGui.Enabled = true
				if showBtn and showBtn:IsA("GuiObject") then
					local topLeft = window.AbsolutePosition
					local targetX = math.floor(topLeft.X + 22)
					local targetY = math.floor(topLeft.Y + 22)
					local clampedX, clampedY = clampShowButtonOffset(targetX, targetY)
					showBtn.Position = UDim2.new(0, clampedX, 0, clampedY)
					showBtn.Size = UDim2.new(0, 10, 0, 10)
					showBtn.BackgroundTransparency = 1
					showBtn.ImageTransparency = 1
					tween(showBtn, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
						BackgroundTransparency = 0.15,
						ImageTransparency = 0,
						Size = UDim2.new(0, 44, 0, 44)
					})
				end
			end
			if self.Window then
				self.Window.Size = self._targetWindowSize or self.Window.Size
				self.Window.Position = self._targetWindowPosition or self.Window.Position
				self.Window.BackgroundTransparency = THEME.WindowBgTransparency
			end
		end)
		self.Visible = false
	end
end

function UiLib:Toggle()
	if self.Visible then self:Hide() else self:Show() end
end

function UiLib:SetTabActive(tabName: string)
	for name, btn in pairs(self._tabButtons) do
		local active = name == tabName
		tween(btn, ANIM.Fast, {
			BackgroundColor3 = active and THEME.AccentSoft or THEME.Card,
			BackgroundTransparency = active and 0 or THEME.CardTransparency
		})
		btn.TextColor3 = active and THEME.Text or THEME.TextSoft
	end
	for name, page in pairs(self._pages) do
		page.Visible = name == tabName
	end
	self._activeTab = tabName
end

