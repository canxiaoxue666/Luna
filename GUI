    self.Theme = THEME
    self.Visible = true
    self._connections = {}

    local root = opts.Parent or ensurePlayerGui()
    if typeof(root) ~= "Instance" then root = CoreGui end

    local sg = Instance.new("ScreenGui")
    sg.Name = opts.Name or "vortex_" .. math.random(100000, 999999)
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.ResetOnSpawn = false
    sg.Parent = root
    self.RootGui = sg

    -- 主窗口
    local win = Instance.new("Frame")
    win.Name = "Main"
    win.AnchorPoint = Vector2.new(0.5, 0.5)
    win.Position = opts.Position or UDim2.new(0.5, 0, 0.5, 0)
    win.Size = opts.Size or UDim2.new(0, 540, 0, 400)
    win.BackgroundColor3 = THEME.Bg
    win.ClipsDescendants = false
    win.Parent = sg
    self.Window = win

    -- 背景纹理感（用多个半透明叠加模拟噪点感）
    local texOverlay = Instance.new("ImageLabel")
    texOverlay.Name = "Noise"
    texOverlay.Size = UDim2.new(1, 0, 1, 0)
    texOverlay.BackgroundTransparency = 1
    texOverlay.Image = "rbxassetid://101568243558680"
    texOverlay.ImageTransparency = 0.92
    texOverlay.ImageColor3 = THEME.AccentDark
    texOverlay.ScaleType = Enum.ScaleType.Tile
    texOverlay.TileSize = UDim2.new(0, 80, 0, 80)
    texOverlay.ZIndex = 0
    texOverlay.Parent = win

    -- 缩放适配
    local uiScale = Instance.new("UIScale")
    uiScale.Scale = 1
    uiScale.Parent = win
    self._uiScale = uiScale
    self._targetWindowSize = win.Size
    self._targetWindowPosition = win.Position

    local function applyScale()
        if opts.Responsive == false then uiScale.Scale = 1 return end
        local vp = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
        local bx = win.Size.X.Offset > 0 and win.Size.X.Offset or 540
        local by = win.Size.Y.Offset > 0 and win.Size.Y.Offset or 400
        local fit = math.min(vp.X / bx, vp.Y / by)
        uiScale.Scale = math.clamp(fit * 0.88, UserInputService.TouchEnabled and 0.6 or 0.75, 1.1)
    end
    applyScale()
    local cam = Workspace.CurrentCamera
    if cam then
        table.insert(self._connections, cam:GetPropertyChangedSignal("ViewportSize"):Connect(applyScale))
    end

    -- 紫色渐变边框
    mkCorner(win, 14)
    local mainStroke = mkStroke(win, THEME.StrokeLight, 1.8, 0)
    local borderGrad = Instance.new("UIGradient")
    borderGrad.Color = purpleGradient()
    borderGrad.Rotation = 45
    borderGrad.Parent = mainStroke

    -- 外发光
