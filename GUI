	window.BackgroundTransparency = THEME.WindowBgTransparency   -- 主窗口半透明
	window.Parent = screenGui

	local windowImage = Instance.new("ImageLabel")
	windowImage.Name = "BackgroundImage"
	windowImage.BackgroundTransparency = 1
	windowImage.Size = UDim2.new(1, 0, 1, 0)
	windowImage.Position = UDim2.new(0, 0, 0, 0)
	windowImage.Image = "rbxassetid://101568243558680"
	windowImage.ImageTransparency = 0.92   -- 略微提升图案透明度，更柔和
	windowImage.ImageColor3 = THEME.TextSoft
	windowImage.ScaleType = Enum.ScaleType.Fit
	windowImage.ZIndex = 0
	windowImage.Parent = window

	local uiScale = Instance.new("UIScale")
	uiScale.Scale = 1
	uiScale.Parent = window
	self._uiScale = uiScale
	self._targetWindowSize = window.Size
	self._targetWindowPosition = window.Position

	local function getViewportSize()
		local cam = Workspace.CurrentCamera
		if cam then
			return cam.ViewportSize
		end
		return Vector2.new(1920, 1080)
	end

	local function applyResponsiveScale()
		if opts.Responsive == false then
			uiScale.Scale = 1
			return
		end
		local viewport = getViewportSize()
		local baseX = window.Size.X.Offset > 0 and window.Size.X.Offset or 620
		local baseY = window.Size.Y.Offset > 0 and window.Size.Y.Offset or 430
		local fitScale = math.min(viewport.X / baseX, viewport.Y / baseY)
		local minScale = opts.MinScale or (UserInputService.TouchEnabled and 0.65 or 0.78)
		local maxScale = opts.MaxScale or 1.15
		uiScale.Scale = math.clamp(fitScale * 0.92, minScale, maxScale)
	end

	applyResponsiveScale()
	local cam = Workspace.CurrentCamera
	if cam then
		table.insert(self._connections, cam:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsiveScale))
	end
	table.insert(self._connections, Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		applyResponsiveScale()
		local currentCam = Workspace.CurrentCamera
		if currentCam then
			table.insert(self._connections, currentCam:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsiveScale))
		end
	end))

	createCorner(window, 18)
	local borderPalette = ColorSequence.new({
		ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 79, 131)),
		ColorSequenceKeypoint.new(0.18, Color3.fromRGB(255, 148, 78)),
