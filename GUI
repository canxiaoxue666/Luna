    -- ===== Slider：现代圆点拖拽 =====
    function api:Slider(opts)
        opts = opts or {}
        local title = opts.Title or "Slider"
        local min = opts.Min or 0
        local max = opts.Max or 100
        local value = math.clamp(opts.Default or min, min, max)
        local step = opts.Step or 1
        local stepStr = tostring(step)
        local dotIdx = string.find(stepStr, "%.")
        local decimals = dotIdx and (#stepStr - dotIdx) or 0

        local function norm(n)
            if decimals <= 0 then return math.floor(n + 0.5) end
            local m = 10 ^ decimals
            return math.floor(n * m + 0.5) / m
        end
        local function fmt(n)
            local f = norm(n)
            if decimals <= 0 then return tostring(f) end
            local s = string.format("%." .. decimals .. "f", f)
            return s:gsub("0+$", ""):gsub("%.$", "")
        end

        local card = Instance.new("Frame")
        card.Size = UDim2.new(1, 0, 0, 52)
        card.BackgroundColor3 = THEME.Card
        card.BackgroundTransparency = 0.4
        card.Parent = page
        mkCorner(card, 9)

        local tl = Instance.new("TextLabel")
        tl.BackgroundTransparency = 1
        tl.Position = UDim2.new(0, 10, 0, 6)
        tl.Size = UDim2.new(1, -70, 0, 14)
        tl.TextXAlignment = Enum.TextXAlignment.Left
        tl.Text = title
        tl.Font = Enum.Font.GothamMedium
        tl.TextSize = 11
        tl.TextColor3 = THEME.TextSoft
        tl.Parent = card

        local vl = Instance.new("TextLabel")
        vl.BackgroundTransparency = 1
        vl.Position = UDim2.new(1, -58, 0, 6)
        vl.Size = UDim2.new(0, 48, 0, 14)
        vl.TextXAlignment = Enum.TextXAlignment.Right
        vl.Font = Enum.Font.GothamBold
        vl.TextSize = 11
        vl.TextColor3 = THEME.AccentBright
        vl.Parent = card

        local bar = Instance.new("Frame")
        bar.Position = UDim2.new(0, 10, 1, -18)
        bar.Size = UDim2.new(1, -20, 0, 4)
        bar.BackgroundColor3 = Color3.fromRGB(35, 26, 52)
        bar.Parent = card
        mkCorner(bar, 999)

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(0, 0, 1, 0)
        fill.BackgroundColor3 = THEME.Accent
        fill.Parent = bar
        mkCorner(fill, 999)

        -- 圆点指示器
        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, 12, 0, 12)
        dot.AnchorPoint = Vector2.new(0.5, 0.5)
        dot.BackgroundColor3 = THEME.Text
        dot.Parent = bar
        mkCorner(dot, 999)

        -- 发光效果
        local dotGlow = Instance.new("UIStroke")
        dotGlow.Color = THEME.Accent
        dotGlow.Thickness = 3
        dotGlow.Transparency = 0.4
        dotGlow.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        dotGlow.Parent = dot

        local hitbox = Instance.new("TextButton")
        hitbox.BackgroundTransparency = 1
        hitbox.Text = ""
        hitbox.AutoButtonColor = false
        hitbox.Position = UDim2.new(0, 0, 0.5, -14)
        hitbox.Size = UDim2.new(1, 0, 0, 28)
        hitbox.ZIndex = 5
        hitbox.Parent = bar

        local dragging = false
        local activeInput

        local function setByX(mx)
            local sx = bar.AbsolutePosition.X
            local w = bar.AbsoluteSize.X
            local a = math.clamp((mx - sx) / w, 0, 1)
            local raw = min + (max - min) * a
            local snapped = math.floor(raw / step + 0.5) * step
            value = norm(math.clamp(snapped, min, max))
            local pct = (value - min) / (max - min)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            dot.Position = UDim2.new(pct, 0, 0.5, 0)
            vl.Text = fmt(value)
            if opts.Callback then opts.Callback(value) end
        end

        local function updateVisual()
            local pct = (value - min) / (max - min)
            fill.Size = UDim2.new(pct, 0, 1, 0)
            dot.Position = UDim2.new(pct, 0, 0.5, 0)
            value = norm(value)
            vl.Text = fmt(value)
        end
        updateVisual()

        hitbox.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                activeInput = i
                setByX(i.Position.X)
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if not dragging then return end
            if activeInput and i ~= activeInput then return end
            if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
                setByX(i.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if not dragging then return end
            if activeInput and i ~= activeInput then return end
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = false
                activeInput = nil
            end
        end)
        return { Set = function(_, v) value = math.clamp(v, min, max); updateVisual() end, Get = function() return value end }
    end

