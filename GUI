        self:CreateWatermark({Position = opts.WatermarkPosition or UDim2.new(0.82, 0, 0, 12)})
    end

    -- 开场动画
    win.BackgroundTransparency = 1
    win.Size = UDim2.new(
        self._targetWindowSize.X.Scale,
        math.floor(self._targetWindowSize.X.Offset * 0.82),
        self._targetWindowSize.Y.Scale,
        math.floor(self._targetWindowSize.Y.Offset * 0.82)
    )
    win.Position = UDim2.new(
        self._targetWindowPosition.X.Scale,
        self._targetWindowPosition.X.Offset,
        self._targetWindowPosition.Y.Scale,
        self._targetWindowPosition.Y.Offset + 20
    )
    tw(win, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = self._targetWindowSize,
        Position = self._targetWindowPosition,
        BackgroundTransparency = 0
    })

    return self
end

function UiLib:Show()
    if not self.RootGui then return end
    if self.Window and self._targetWindowSize and self._targetWindowPosition then
        self.Window.Visible = true
        self.Window.Size = UDim2.new(
            self._targetWindowSize.X.Scale,
            math.floor(self._targetWindowSize.X.Offset * 0.8),
            self._targetWindowSize.Y.Scale,
            math.floor(self._targetWindowSize.Y.Offset * 0.8)
        )
        self.Window.BackgroundTransparency = 1
    end
    self.RootGui.Enabled = true
    if self.Window and self._targetWindowSize then
        tw(self.Window, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = self._targetWindowSize,
            Position = self._targetWindowPosition,
            BackgroundTransparency = 0
        })
    end
    if self._showGui then
        self._showGui.Enabled = false
    end
    self.Visible = true
end

function UiLib:Hide()
    if not self.RootGui or not self.Window or not self.Window.Visible then return end
    local w = self.Window
    self._targetWindowSize = w.Size
    self._targetWindowPosition = w.Position
    local ss = UDim2.new(w.Size.X.Scale, math.floor(w.Size.X.Offset * 0.25), w.Size.Y.Scale, math.floor(w.Size.Y.Offset * 0.25))
    tw(w, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
        Size = ss, BackgroundTransparency = 1
    }).Completed:Connect(function()
        w.Visible = false
        w.Size = self._targetWindowSize
        w.Position = self._targetWindowPosition
        w.BackgroundTransparency = 0
        if self._showGui then
            self._showGui.Enabled = true
        end
    end)
    self.Visible = false
end

function UiLib:Toggle()
    if self.Visible then self:Hide() else self:Show() end
end

function UiLib:SetTabActive(tabName)
    for name, btn in pairs(self._tabButtons) do
        local active = name == tabName
        if active then
            tw(btn, ANIM.Fast, {BackgroundColor3 = THEME.AccentDark, BackgroundTransparency = 0})
            btn.TextColor3 = THEME.Text
            -- 激活指示线
            local line = btn:FindFirstChild("ActiveLine")
            if line then line.Visible = true end
        else
            tw(btn, ANIM.Fast, {BackgroundColor3 = THEME.Card, BackgroundTransparency = 0.5})
            btn.TextColor3 = THEME.TextMuted
            local line = btn:FindFirstChild("ActiveLine")
            if line then line.Visible = false end
        end
    end
    for name, page in pairs(self._pages) do
        page.Visible = name == tabName
    end
    self._activeTab = tabName
end

