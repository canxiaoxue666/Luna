function UiLib:CreateWatermark(opts)
    opts = opts or {}
    if self._watermark and self._watermark.Parent then
        local old = self._watermark
        self._watermark = nil
        tweenWatermarkOutBlocking(old)
    end
    local frame = Instance.new("CanvasGroup")
    frame.Name = "PurpleWatermark"
    frame.BorderSizePixel = 0
    frame.GroupTransparency = 1
    if opts.Position then
        frame.AnchorPoint = Vector2.new(0, 0)
        frame.Position = opts.Position
    else
        frame.AnchorPoint = Vector2.new(1, 0)
        frame.Position = UDim2.new(1, -10, 0, 10)
    end
    frame.Size = UDim2.new(0, 220, 0, 28)
    frame.BackgroundTransparency = 1
    frame.Parent = self.RootGui
    createCorner(frame, self._opts.WatermarkCornerRadius or 14)
    -- 无描边 - 紫色Dark风格
    local backdrop = Instance.new("Frame")
    backdrop.Name = "WmBackdrop"
    backdrop.Size = UDim2.new(1, 0, 1, 0)
    backdrop.BackgroundColor3 = self._opts.WindowColor or THEME.Bg
    backdrop.BackgroundTransparency = math.min(self._windowFrameTransparency or 0, 0.45)
    backdrop.BorderSizePixel = 0
    backdrop.ZIndex = 0
    backdrop.Parent = frame
    createCorner(backdrop, self._opts.WatermarkCornerRadius or 14)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 10, 0, 0)
    label.Size = UDim2.new(1, -16, 1, 0)
    label.ZIndex = 1
    label.Font = FONTS.Default
    label.TextSize = 12
    label.TextColor3 = self._opts.TextColor or THEME.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = "FPS: 0 | Ping: -- ms | 00:00"
    label.Parent = frame
    local dragState = { active = false, start = Vector2.zero, startPos = frame.Position }
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragState.active = true
            dragState.start = input.Position
            dragState.startPos = frame.Position
        end
    end)
    table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragState.active = false
        end
    end))
    table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
        if dragState.active and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragState.start
            frame.Position = UDim2.new(
                dragState.startPos.X.Scale, dragState.startPos.X.Offset + delta.X,
                dragState.startPos.Y.Scale, dragState.startPos.Y.Offset + delta.Y
            )
        end
    end))
    local fpsCounter, fpsValue, fpsTick = 0, 0, os.clock()
    local pingTick, pingText = 0, "-- ms"
    table.insert(self._connections, RunService.RenderStepped:Connect(function()
        fpsCounter += 1
        local now = os.clock()
        if now - fpsTick >= 0.5 then
            fpsValue = math.floor((fpsCounter / (now - fpsTick)) + 0.5)
            fpsCounter = 0
            fpsTick = now
        end
        if now - pingTick >= 0.25 then
            pingTick = now
            local ok, text = pcall(function()
                return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
            end)
            if ok and text then
                local n = tonumber(string.match(tostring(text), "%d+%.?%d*"))
                pingText = n and string.format("%d ms", math.floor(n + 0.5)) or "-- ms"
            else
                pingText = "-- ms"
            end
        end
        if label.Parent then
            label.Text = string.format("FPS:%3d | Ping:%7s | %s",
                math.clamp(fpsValue, 0, 999),
                pingText,
                os.date("%H:%M"))
        end
    end))
    self._watermark = frame
    tweenWatermarkIn(frame)
    return frame
end

