		textLabel.Size = UDim2.new(1, -24, 1, -16)
		textLabel.TextXAlignment = Enum.TextXAlignment.Left
		textLabel.TextYAlignment = Enum.TextYAlignment.Top
		textLabel.Font = Enum.Font.Gotham
		textLabel.TextSize = 13
		textLabel.TextColor3 = THEME.TextSoft
		textLabel.TextWrapped = true
		textLabel.Text = opts.Text or "Paragraph"
		textLabel.Parent = card

		createPadding(card, 12)

		return {
			SetText = function(_, t) textLabel.Text = tostring(t) end,
			GetText = function() return textLabel.Text end,
		}
	end

	-- 新增控件 RadioGroup
	function api:RadioGroup(opts)
		opts = opts or {}
		local options = opts.Options or {}
		local defaultValue = opts.Default or options[1]
		local selected = defaultValue

		local card = Instance.new("Frame")
		card.Size = UDim2.new(1, 0, 0, 0)
		card.AutomaticSize = Enum.AutomaticSize.Y
		card.BackgroundColor3 = THEME.Card
		card.BackgroundTransparency = THEME.CardTransparency
		card.Parent = page
		createCorner(card, 12)
		createStroke(card, THEME.Stroke, 1, 0.45)
		createPadding(card, 8)
		createList(card, 6)

		local buttons = {}
		local titleLabel = Instance.new("TextLabel")
		titleLabel.BackgroundTransparency = 1
		titleLabel.Size = UDim2.new(1, 0, 0, 22)
		titleLabel.TextXAlignment = Enum.TextXAlignment.Left
		titleLabel.Font = Enum.Font.GothamMedium
		titleLabel.TextSize = 13
		titleLabel.TextColor3 = THEME.Text
		titleLabel.Text = opts.Title or "Radio Group"
		titleLabel.Parent = card

		for _, opt in ipairs(options) do
			local radioBtn = Instance.new("TextButton")
			radioBtn.Name = opt
			radioBtn.Size = UDim2.new(1, 0, 0, 30)
			radioBtn.BackgroundColor3 = THEME.Bg2
			radioBtn.BackgroundTransparency = 0.3
			radioBtn.Text = opt
			radioBtn.TextColor3 = THEME.TextSoft
			radioBtn.Font = Enum.Font.Gotham
			radioBtn.TextSize = 12
			radioBtn.AutoButtonColor = false
			radioBtn.Parent = card
			createCorner(radioBtn, 8)
			createStroke(radioBtn, THEME.Stroke, 1, 0.3)

			local dot = Instance.new("Frame")
			dot.AnchorPoint = Vector2.new(0, 0.5)
			dot.Position = UDim2.new(0, 8, 0.5, 0)
			dot.Size = UDim2.new(0, 10, 0, 10)
			dot.BackgroundColor3 = THEME.Accent
			dot.BackgroundTransparency = 1
			dot.Visible = false
			createCorner(dot, 999)
			dot.Parent = radioBtn

			radioBtn.MouseButton1Click:Connect(function()
				selected = opt
				for _, b in ipairs(buttons) do
					local isSel = b.Button.Text == opt
					b.dot.Visible = isSel
					b.Button.BackgroundColor3 = isSel and THEME.AccentSoft or THEME.Bg2
					b.Button.TextColor3 = isSel and THEME.Text or THEME.TextSoft
				end
				if opts.Callback then opts.Callback(selected) end
			end)

			table.insert(buttons, {Button = radioBtn, dot = dot})
			if opt == defaultValue then
				dot.Visible = true
				radioBtn.BackgroundColor3 = THEME.AccentSoft
				radioBtn.TextColor3 = THEME.Text
			end
		end

		return {
			Set = function(_, value)
				selected = value
				for _, b in ipairs(buttons) do
					local isSel = b.Button.Text == value
					b.dot.Visible = isSel
					b.Button.BackgroundColor3 = isSel and THEME.AccentSoft or THEME.Bg2
					b.Button.TextColor3 = isSel and THEME.Text or THEME.TextSoft
				end
			end,
			Get = function() return selected end,
		}
	end

	return api
end

function UiLib:Destroy()
	if self._isDestroying then return end
	if self.Window and self.RootGui and self.RootGui.Enabled then
		self._isDestroying = true
		if self._showGui then self._showGui.Enabled = false end
		local finalSize = UDim2.new(
			self.Window.Size.X.Scale, math.floor(self.Window.Size.X.Offset * 0.3),
			self.Window.Size.Y.Scale, math.floor(self.Window.Size.Y.Offset * 0.3)
		)
		local finalPos = UDim2.new(
			self.Window.Position.X.Scale, self.Window.Position.X.Offset,
			self.Window.Position.Y.Scale, self.Window.Position.Y.Offset + 24
		)
		local closeTween = tween(self.Window, TweenInfo.new(0.46, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
			Position = finalPos,
			Size = finalSize,
			BackgroundTransparency = 1
		})
		closeTween.Completed:Connect(function()
			if self._connections then
				for _, con in ipairs(self._connections) do
					if con and con.Disconnect then con:Disconnect() end
				end
				self._connections = nil
			end
			if self.RootGui then self.RootGui:Destroy() end
			if self._showGui then self._showGui:Destroy() end
		end)
		return
	end
	if self._connections then
		for _, con in ipairs(self._connections) do
			if con and con.Disconnect then con:Disconnect() end
		end
		self._connections = nil
	end
	if self.RootGui then self.RootGui:Destroy() end
	if self._showGui then self._showGui:Destroy() end
end

