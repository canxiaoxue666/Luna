    Bounce = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
}

local function tw(instance, info, props)
    local t = TweenService:Create(instance, info, props)
    t:Play()
    return t
end

local function mkCorner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r)
    c.Parent = parent
    return c
end

local function mkStroke(parent, color, thick, trans)
    local s = Instance.new("UIStroke")
    s.Color = color
    s.Thickness = thick or 1
    s.Transparency = trans or 0
    s.Parent = parent
    return s
end

local function mkPad(parent, l, t, r, b)
    local p = Instance.new("UIPadding")
    p.PaddingLeft = UDim.new(0, l or 0)
    p.PaddingTop = UDim.new(0, t or 0)
    p.PaddingRight = UDim.new(0, r or 0)
    p.PaddingBottom = UDim.new(0, b or 0)
    p.Parent = parent
    return p
end

local function mkList(parent, pad, align)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, pad or 0)
    l.FillDirection = Enum.FillDirection.Vertical
    l.HorizontalAlignment = align or Enum.HorizontalAlignment.Left
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

local function ensurePlayerGui()
    return game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
end

-- 紫色渐变序列
local function purpleGradient()
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0.00, Color3.fromRGB(139, 92, 246)),
        ColorSequenceKeypoint.new(0.25, Color3.fromRGB(168, 85, 247)),
        ColorSequenceKeypoint.new(0.50, Color3.fromRGB(192, 132, 252)),
        ColorSequenceKeypoint.new(0.75, Color3.fromRGB(109, 40, 217)),
        ColorSequenceKeypoint.new(1.00, Color3.fromRGB(139, 92, 246)),
    })
end

function UiLib:CreateWatermark(opts)
    opts = opts or {}
    if self._watermark and self._watermark.Parent then
        self._watermark:Destroy()
    end

    local frame = Instance.new("Frame")
    frame.Name = "VortexWM"
    frame.AnchorPoint = Vector2.new(0.5, 0)
    frame.Position = opts.Position or UDim2.new(0.82, 0, 0, 12)
    frame.Size = UDim2.new(0, 0, 0, 26)
    frame.AutomaticSize = Enum.AutomaticSize.X
    frame.BackgroundColor3 = THEME.Bg2
    frame.BackgroundTransparency = 0.15
    frame.Parent = self.RootGui
    mkCorner(frame, 6)
    mkStroke(frame, THEME.Stroke, 1, 0.5)

    -- 左侧紫色竖条装饰
    local accentBar = Instance.new("Frame")
    accentBar.Size = UDim2.new(0, 3, 1, -8)
    accentBar.Position = UDim2.new(0, 4, 0.5, 0)
    accentBar.AnchorPoint = Vector2.new(0, 0.5)
    accentBar.BackgroundColor3 = THEME.Accent
    accentBar.Parent = frame
    mkCorner(accentBar, 4)

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0, 14, 0, 0)
    label.Size = UDim2.new(1, -20, 1, 0)
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 11
    label.TextColor3 = THEME.TextSoft
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = "vortex | -- fps -- ms"
    label.Parent = frame

    local drag = false, dragStart, startPos
    frame.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true
            dragStart = i.Position
            startPos = frame.Position
        end
    end)
    table.insert(self._connections, UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end))
    table.insert(self._connections, UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end))

    local fc, fv, ft, pt, ptText = 0, 0, os.clock(), 0, "-- ms"
    table.insert(self._connections, RunService.RenderStepped:Connect(function()
        fc += 1
        local n = os.clock()
        if n - ft >= 0.5 then
            fv = math.floor(fc / (n - ft) + 0.5)
            fc, ft = 0, n
        end
        if n - pt >= 0.3 then
            pt = n
            local ok, txt = pcall(function()
                return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
            end)
            if ok and txt then
                local num = tonumber(string.match(tostring(txt), "%d+%.?%d*"))
                ptText = num and string.format("%dms", math.floor(num + 0.5)) or "-- ms"
            else
                ptText = "-- ms"
            end
        end
        if label.Parent then
            label.Text = string.format("vortex  %d fps  %s", fv, ptText)
        end
    end))
    self._watermark = frame
    return frame
end

function UiLib:_getNotifyTargetPositions()
    local cards = self._notifyCards
    local out = {}
    if not cards then return out end
    local acc = 6
    for i = #cards, 1, -1 do
        local c = cards[i]
        if c and c.Parent then
            local h = math.max(c.AbsoluteSize.Y, 44)
            out[c] = UDim2.new(0, 0, 1, -acc - h)
            acc += h + 6
        end
    end
    return out
end

function UiLib:_tweenNotifyStackToTargets(except)
    local targets = self:_getNotifyTargetPositions()
    for c, tgt in pairs(targets) do
        if (not except or c ~= except) and c.Parent then
            c.AnchorPoint = Vector2.new(0, 1)
            TweenService:Create(c, TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = tgt}):Play()
        end
    end
end

function UiLib:Notify(opts)
    opts = opts or {}
    local title = opts.Title or "Notice"
    local content = opts.Content or ""
    local duration = opts.Duration or 3.5
    local kind = opts.Type or "info"

    local holder = self._notifyHolder
    if not holder then
        holder = Instance.new("ScreenGui")
        holder.Name = "VortexNotify_" .. math.random(100000, 999999)
        holder.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        holder.ResetOnSpawn = false
        holder.Parent = self.RootGui
        local container = Instance.new("Frame")
        container.Name = "C"
        container.AnchorPoint = Vector2.new(1, 1)
        container.Position = UDim2.new(1, -16, 1, -16)
        container.Size = UDim2.new(0, 280, 1, -32)
        container.BackgroundTransparency = 1
        container.ClipsDescendants = true
        container.Parent = holder
        mkPad(container, 4)
        self._notifyHolder = holder
        self._notifyContainer = container
        self._notifyCards = {}
    end

    local kindColor = kind == "success" and THEME.Success or (kind == "error" and THEME.Error or THEME.Accent)

    local card = Instance.new("Frame")
    card.AnchorPoint = Vector2.new(0, 1)
    card.BackgroundColor3 = THEME.Bg2
    card.Size = UDim2.new(1, -6, 0, 0)
    card.AutomaticSize = Enum.AutomaticSize.Y
    card.BackgroundTransparency = 1
    card.Position = UDim2.new(0, 60, 1, -10)
    card.Parent = self._notifyContainer
    local sc = Instance.new("UIScale")
    sc.Scale = 0.85
    sc.Parent = card
    mkCorner(card, 10)
    mkStroke(card, THEME.Stroke, 1, 0.4)
    mkPad(card, 10, 10, 10, 10)

    -- 顶部颜色线
    local topLine = Instance.new("Frame")
    topLine.Size = UDim2.new(1, 0, 0, 2)
    topLine.Position = UDim2.new(0, 0, 0, 0)
    topLine.BackgroundColor3 = kindColor
    topLine.Parent = card
    mkCorner(topLine, 2)

    local wrap = Instance.new("Frame")
    wrap.BackgroundTransparency = 1
    wrap.Size = UDim2.new(1, 0, 0, 0)
    wrap.AutomaticSize = Enum.AutomaticSize.Y
    wrap.Position = UDim2.new(0, 0, 0, 6)
    wrap.Parent = card
    mkList(wrap, 3)

    local tl = Instance.new("TextLabel")
    tl.BackgroundTransparency = 1
    tl.Size = UDim2.new(1, 0, 0, 16)
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 12
    tl.TextColor3 = kindColor
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.Text = title
    tl.Parent = wrap

    local cl = Instance.new("TextLabel")
    cl.BackgroundTransparency = 1
    cl.Size = UDim2.new(1, 0, 0, 0)
    cl.AutomaticSize = Enum.AutomaticSize.Y
    cl.TextWrapped = true
    cl.TextXAlignment = Enum.TextXAlignment.Left
    cl.Font = Enum.Font.Gotham
    cl.TextSize = 11
    cl.TextColor3 = THEME.TextSoft
    cl.Text = content
    cl.Parent = wrap

    table.insert(self._notifyCards, card)

    task.defer(function()
        if not card.Parent then return end
        local targets = self:_getNotifyTargetPositions()
        local tp = targets[card]
        if not tp then return end
        card.AnchorPoint = Vector2.new(0, 1)
        for c, tgt in pairs(targets) do
            if c ~= card and c.Parent then
                TweenService:Create(c, TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = tgt}):Play()
            end
        end
        card.Position = UDim2.new(tp.X.Scale, tp.X.Offset + 50, tp.Y.Scale, tp.Y.Offset)
        TweenService:Create(card, TweenInfo.new(0.32, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = tp, BackgroundTransparency = 0.08}):Play()
        TweenService:Create(sc, TweenInfo.new(0.32, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
    end)

    task.delay(duration, function()
        if not card.Parent then return end
        local lp = UDim2.new(card.Position.X.Scale, card.Position.X.Offset + 40, card.Position.Y.Scale, card.Position.Y.Offset)
        local lt = TweenService:Create(card, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Position = lp, BackgroundTransparency = 1})
        TweenService:Create(sc, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Scale = 0.8}):Play()
        lt:Play()
        lt.Completed:Wait()
        for i = #self._notifyCards, 1, -1 do
            if self._notifyCards[i] == card then table.remove(self._notifyCards, i) break end
        end
        card:Destroy()
        self:_tweenNotifyStackToTargets()
    end)
end

function UiLib.new(opts)
    opts = opts or {}
