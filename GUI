		optionsHolder.Parent = card
		local optionsList = listLayout(optionsHolder, 4)
		optionsList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			optionsHolder.CanvasSize = UDim2.new(0,0,0,optionsList.AbsoluteContentSize.Y)
		end)

		local optionBtns = {}

		local function containsValue(list, target)
			for _, v in ipairs(list) do if v == target then return true end end
			return false
		end

		local function refreshAllMultiChoices()
			if not multi then return end
			for ix, ov in ipairs(values) do
				local bt = optionBtns[ix]
				if bt then refreshOptionStyle(bt, selectedMap and selectedMap[ov] == true) end
			end
		end

		local function applySearchFilter()
			if not searchBox then return end
			local ql = string.lower(searchBox.Text or "")
			for idx, optVal in ipairs(values) do
				local bt = optionBtns[idx]
				if bt then
					bt.Visible = ql == "" or string.find(string.lower(tostring(optVal)), ql, 1, true) ~= nil
				end
			end
			optionsHolder.CanvasPosition = Vector2.zero
		end

		local function setOpen(flag)
			open = flag
			if searchFrame then searchFrame.Visible = enableSearch and open end
			if open and enableSearch and searchBox then
				searchBox.Text = ""
				applySearchFilter()
			end
			local visibleHeight = visibleCount>0 and (visibleCount*30-4) or 0
			optionsHolder.Size = UDim2.new(1,-16,0, open and visibleHeight or 0)
			local targetHeight = open and (42+searchExtra+visibleCount*30+10) or 42
			tween(card, ANIM.Normal, {Size = UDim2.new(1,0,0,targetHeight)})
			arrow.Text = flag and "^" or "v"
		end

		local function rebuildOptionButtons()
			for _, oldBtn in ipairs(optionBtns) do if oldBtn and oldBtn.Parent then oldBtn:Destroy() end end
			optionBtns = {}
			for idx, option in ipairs(values) do
				local opt = Instance.new("TextButton")
				opt.Size = UDim2.new(1,0,0,26)
				opt.BackgroundColor3 = THEME.Bg2
				opt.BackgroundTransparency = 0.2
				opt.Text = tostring(option)
				opt.TextColor3 = THEME.TextSoft
				opt.Font = Enum.Font.Gotham
				opt.TextSize = 12
				opt.AutoButtonColor = false
				opt.Parent = optionsHolder
				corner(opt, 7)
				optionBtns[idx] = opt

				if multi then refreshOptionStyle(opt, selectedMap[option] == true) end
				opt.MouseEnter:Connect(function()
					if multi and selectedMap[option] then return end
					tween(opt, ANIM.Fast, {BackgroundColor3 = Color3.fromRGB(36,40,52), TextColor3 = THEME.Text})
				end)
				opt.MouseLeave:Connect(function()
					if multi then refreshOptionStyle(opt, selectedMap[option] == true); return end
					tween(opt, ANIM.Fast, {BackgroundColor3 = THEME.Bg2, TextColor3 = THEME.TextSoft})
				end)
				opt.MouseButton1Click:Connect(function()
					if multi then
						if selectedMap[option] then selectedMap[option] = nil else selectedMap[option] = true end
						refreshOptionStyle(opt, selectedMap[option] == true)
						refreshHeaderLabel()
						if opts.Callback then task.spawn(opts.Callback, getMultiSelectedOrdered()) end
						return
					end
					selected = option
					refreshHeaderLabel()
					setOpen(false)
					if opts.Callback then task.spawn(opts.Callback, selected) end
				end)
			end
		end
		rebuildOptionButtons()

		if searchBox then searchBox:GetPropertyChangedSignal("Text"):Connect(applySearchFilter) end
		btn.MouseButton1Click:Connect(function() setOpen(not open) end)

		if multi then refreshHeaderLabel() refreshAllMultiChoices() end

		return {
			Set = function(_, val)
				if multi then
					selectedMap = {}
					if type(val) == "table" then for _, v in ipairs(val) do selectedMap[v] = true end
					elseif val ~= nil then selectedMap[val] = true end
					refreshAllMultiChoices() refreshHeaderLabel()
					if opts.Callback then task.spawn(opts.Callback, getMultiSelectedOrdered()) end
				else
					selected = val refreshHeaderLabel()
					if opts.Callback then task.spawn(opts.Callback, selected) end
				end
			end,
			Get = function() return multi and getMultiSelectedOrdered() or selected end,
			SetValues = function(_, newValues)
				if type(newValues) ~= "table" then return end
				values = newValues
				visibleCount = math.min(#values, 4)
				if multi then
					local nextMap = {}
					for _, v in ipairs(values) do if selectedMap and selectedMap[v] then nextMap[v] = true end end
					selectedMap = nextMap
				else if not containsValue(values, selected) then selected = values[1] or "None" end end
				rebuildOptionButtons()
				refreshHeaderLabel()
				applySearchFilter()
			end
		}
	end

