		type KeybindBinding = { kind: "key", code: Enum.KeyCode } | { kind: "mouse", code: Enum.UserInputType }

		local function normalizeDefault(def: any): KeybindBinding?
			if def == false then
				return nil
			end
			if def == nil then
				return { kind = "key", code = Enum.KeyCode.RightShift }
			end
			if typeof(def) == "EnumItem" then
				if def.EnumType == Enum.KeyCode and def ~= Enum.KeyCode.Unknown then
					return { kind = "key", code = def }
				end
				if def.EnumType == Enum.UserInputType then
					local t = def :: Enum.UserInputType
					if
						t == Enum.UserInputType.MouseButton1
						or t == Enum.UserInputType.MouseButton2
						or t == Enum.UserInputType.MouseButton3
					then
						return { kind = "mouse", code = t }
					end
				end
			end
			return { kind = "key", code = Enum.KeyCode.RightShift }
		end

		local binding: KeybindBinding? = normalizeDefault(opts.Default)
		local waitingForKey = false
		local toggleLatch = false
		local holdActive = false

		local card = Instance.new("Frame")
