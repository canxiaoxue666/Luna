                ob.Parent = optHolder
                mkCorner(ob, 6)
                optionBtns[idx] = ob
                if multi then refreshOptStyle(ob, selectedMap[opt]) end
                ob.MouseEnter:Connect(function()
                    if multi and selectedMap[opt] then return end
                    tw(ob, ANIM.Fast, {BackgroundColor3 = THEME.CardHover, TextColor3 = THEME.Text})
                end)
                ob.MouseLeave:Connect(function()
                    if multi then refreshOptStyle(ob, selectedMap[opt]) return end
                    tw(ob, ANIM.Fast, {BackgroundColor3 = THEME.Bg2, TextColor3 = THEME.TextSoft})
                end)
                ob.MouseButton1Click:Connect(function()
                    if multi then
                        selectedMap[opt] = not selectedMap[opt]
                        refreshOptStyle(ob, selectedMap[opt])
                        refreshHeader()
                        if opts.Callback then task.spawn(opts.Callback, getMultiOrdered()) end
                    else
                        selected = opt
                        refreshHeader()
                        setOpen(false)
                        if opts.Callback then task.spawn(opts.Callback, selected) end
                    end
                end)
            end
        end
        rebuild()

        if searchBox then
            searchBox:GetPropertyChangedSignal("Text"):Connect(function()
                local q = string.lower(searchBox.Text or "")
                for idx, v in ipairs(values) do
                    local b = optionBtns[idx]
                    if b then b.Visible = q == "" or string.find(string.lower(tostring(v)), q, 1, true) ~= nil end
                end
                optHolder.CanvasPosition = Vector2.zero
            end)
        end

        btn.MouseButton1Click:Connect(function() setOpen(not open) end)
        if multi then refreshHeader() end

        return {
            Set = function(_, v)
                if multi then
                    selectedMap = {}
                    if type(v) == "table" then for _, x in ipairs(v) do selectedMap[x] = true end
                    elseif v then selectedMap[v] = true end
                    rebuild()
                    refreshHeader()
                    if opts.Callback then task.spawn(opts.Callback, getMultiOrdered()) end
                else
                    selected = v
                    refreshHeader()
                    if opts.Callback then task.spawn(opts.Callback, selected) end
                end
            end,
            Get = function() return multi and getMultiOrdered() or selected end,
            SetValues = function(_, nv)
                if type(nv) ~= "table" then return end
                values = nv
                visCount = math.min(#values, 4)
                if multi then
                    local nm = {}
                    for _, v in ipairs(values) do if selectedMap and selectedMap[v] then nm[v] = true end end
                    selectedMap = nm
                else
                    local found = false
                    for _, v in ipairs(values) do if v == selected then found = true; break end end
                    if not found then selected = values[1] or "None" end
                end
                rebuild()
                refreshHeader()
            end
        }
    end

    -- ===== Colorpicker =====
    function api:Colorpicker(opts)
        opts = opts or {}
        local title = opts.Title or "Color"
        local color = opts.Default or Color3.fromRGB(168, 85, 247)
        local hue, sat, val = color:ToHSV()
        local expanded = false

        local card = Instance.new("Frame")
        card.Size = UDim2.new(1, 0, 0, 36)
        card.BackgroundColor3 = THEME.Card
        card.BackgroundTransparency = 0.4
        card.ClipsDescendants = true
        card.Parent = page
        mkCorner(card, 9)

        local tl = Instance.new("TextLabel")
        tl.BackgroundTransparency = 1
        tl.Position = UDim2.new(0, 10, 0, 0)
        tl.Size = UDim2.new(1, -72, 0, 36)
        tl.TextXAlignment = Enum.TextXAlignment.Left
        tl.Font = Enum.Font.GothamMedium
        tl.TextSize = 11
        tl.TextColor3 = THEME.TextSoft
        tl.Text = title
        tl.Parent = card

        local preview = Instance.new("TextButton")
        preview.AnchorPoint = Vector2.new(1, 0.5)
        preview.Position = UDim2.new(1, -28, 0.5, 0)
        preview.Size = UDim2.new(0, 28, 0, 20)
        preview.BackgroundColor3 = color
        preview.AutoButtonColor = false
        preview.Text = ""
        preview.Parent = card
        mkCorner(preview, 6)
        mkStroke(preview, THEME.Stroke, 1, 0.3)

        local arrow = Instance.new("TextLabel")
        arrow.BackgroundTransparency = 1
        arrow.AnchorPoint = Vector2.new(1, 0.5)
        arrow.Position = UDim2.new(1, -8, 0.5, 0)
        arrow.Size = UDim2.new(0, 12, 0, 12)
        arrow.Text = "▾"
        arrow.Font = Enum.Font.Gotham
        arrow.TextSize = 9
        arrow.TextColor3 = THEME.TextMuted
        arrow.Parent = card

        local headerBtn = Instance.new("TextButton")
        headerBtn.BackgroundTransparency = 1
        headerBtn.Size = UDim2.new(1, 0, 0, 36)
        headerBtn.Text = ""
        headerBtn.AutoButtonColor = false
        headerBtn.Parent = card

        local panel = Instance.new("Frame")
        panel.BackgroundTransparency = 1
        panel.Position = UDim2.new(0, 0, 0, 38)
        panel.Size = UDim2.new(1, 0, 0, 140)
        panel.Parent = card

        local svMap = Instance.new("ImageLabel")
        svMap.Position = UDim2.new(0, 8, 0, 4)
        svMap.Size = UDim2.new(0, 140, 0, 132)
        svMap.Image = "rbxassetid://4155801252"
        svMap.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        svMap.ScaleType = Enum.ScaleType.Stretch
        svMap.BorderSizePixel = 0
        svMap.Parent = panel
        mkCorner(svMap, 8)
        mkStroke(svMap, THEME.Stroke, 1, 0.4)

        local hGrad = Instance.new("UIGradient")
        hGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.166, Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.666, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 0, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
        })
        hGrad.Rotation = 90
        hGrad.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.02), NumberSequenceKeypoint.new(1, 0.02)})

        local hueBar = Instance.new("Frame")
        hueBar.Position = UDim2.new(0, 156, 0, 4)
        hueBar.Size = UDim2.new(0, 8, 0, 132)
        hueBar.BackgroundColor3 = Color3.new(1, 1, 1)
        hueBar.Parent = panel
        mkCorner(hueBar, 999)
        mkStroke(hueBar, THEME.Stroke, 1, 0.5)
        hGrad.Parent = hueBar

        local mapCursor = Instance.new("Frame")
        mapCursor.AnchorPoint = Vector2.new(0.5, 0.5)
        mapCursor.Size = UDim2.new(0, 10, 0, 10)
        mapCursor.BackgroundColor3 = Color3.new(1, 1, 1)
        mapCursor.Parent = svMap
        mkCorner(mapCursor, 999)
        mkStroke(mapCursor, Color3.new(0, 0, 0), 1, 0.15)

        local hueCursor = Instance.new("Frame")
        hueCursor.AnchorPoint = Vector2.new(0.5, 0.5)
        hueCursor.Size = UDim2.new(1, 5, 0, 4)
        hueCursor.BackgroundColor3 = Color3.new(1, 1, 1)
        hueCursor.Parent = hueBar
        mkCorner(hueCursor, 999)

        -- 右侧颜色信息
        local infoX = 176
        local infoLabels = {}
        for i, prefix in ipairs({"HEX", "R", "G", "B"}) do
            local lb = Instance.new("TextLabel")
            lb.BackgroundTransparency = 1
            lb.Position = UDim2.new(0, infoX, 0, 8 + (i - 1) * 30)
            lb.Size = UDim2.new(1, -infoX - 8, 0, 14)
            lb.TextXAlignment = Enum.TextXAlignment.Left
            lb.Font = Enum.Font.Gotham
            lb.TextSize = 10
            lb.TextColor3 = THEME.TextMuted
            lb.Text = prefix
            lb.Parent = panel
            local val = Instance.new("TextLabel")
            val.BackgroundTransparency = 1
            val.Position = UDim2.new(0, infoX, 0, 22 + (i - 1) * 30)
            val.Size = UDim2.new(1, -infoX - 8, 0, 12)
            val.TextXAlignment = Enum.TextXAlignment.Left
            val.Font = Enum.Font.GothamBold
            val.TextSize = 11
            val.TextColor3 = THEME.TextSoft
            val.Parent = panel
            infoLabels[i] = val
        end

        local function updateBars()
            local out = Color3.fromHSV(hue, sat, val)
            svMap.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
            preview.BackgroundColor3 = out
            mapCursor.Position = UDim2.new(sat, 0, 1 - val, 0)
            hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
            infoLabels[1].Text = "#" .. out:ToHex()
            infoLabels[2].Text = tostring(math.floor(out.R * 255 + 0.5))
            infoLabels[3].Text = tostring(math.floor(out.G * 255 + 0.5))
            infoLabels[4].Text = tostring(math.floor(out.B * 255 + 0.5))
            if opts.Callback then opts.Callback(out) end
        end

        local function setExpanded(flag)
            expanded = flag
            arrow.Text = expanded and "▴" or "▾"
            tw(card, ANIM.Normal, {Size = UDim2.new(1, 0, 0, expanded and 180 or 36)})
        end

        local function bindMap(map)
            local dragging, heartCon
            local function set(mp)
                local rx = math.clamp((mp.X - map.AbsolutePosition.X) / map.AbsoluteSize.X, 0, 1)
                local ry = math.clamp((mp.Y - map.AbsolutePosition.Y) / map.AbsoluteSize.Y, 0, 1)
                sat, val = rx, 1 - ry
                updateBars()
            end
            map.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    set(i.Position - GuiService:GetGuiInset())
                    if heartCon then heartCon:Disconnect() end
                    heartCon = RunService.Heartbeat:Connect(function()
                        if dragging then set(UserInputService:GetMouseLocation() - GuiService:GetGuiInset()) end
                    end)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                    if heartCon then heartCon:Disconnect(); heartCon = nil end
                end
            end)
        end

        local function bindHue(bar)
            local dragging, heartCon
            local function set(mp)
                hue = math.clamp((mp.Y - bar.AbsolutePosition.Y) / bar.AbsoluteSize.Y, 0, 1)
                updateBars()
            end
            bar.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    set(i.Position - GuiService:GetGuiInset())
                    if heartCon then heartCon:Disconnect() end
                    heartCon = RunService.Heartbeat:Connect(function()
                        if dragging then set(UserInputService:GetMouseLocation() - GuiService:GetGuiInset()) end
                    end)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                    if heartCon then heartCon:Disconnect(); heartCon = nil end
                end
            end)
        end

        bindMap(svMap)
        bindHue(hueBar)
        headerBtn.MouseButton1Click:Connect(function() setExpanded(not expanded) end)
        updateBars()

        return {
            Set = function(_, c) hue, sat, val = c:ToHSV(); updateBars() end,
            Get = function() return Color3.fromHSV(hue, sat, val) end
        }
    end

    -- ===== Separator 分隔线 =====
    function api:Separator(opts)
        opts = opts or {}
        local sep = Instance.new("Frame")
        sep.Size = UDim2.new(1, 0, 0, 1)
        sep.BackgroundColor3 = THEME.Stroke
        sep.BackgroundTransparency = 0.4
        sep.Parent = page
        if opts.Text then
            local lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.new(0, 0, 0, 0)
            lbl.AutomaticSize = Enum.AutomaticSize.XY
            lbl.Position = UDim2.new(0.5, 0, 0, -7)
            lbl.AnchorPoint = Vector2.new(0.5, 0)
            lbl.Font = Enum.Font.GothamMedium
            lbl.TextSize = 10
            lbl.TextColor3 = THEME.TextMuted
            lbl.Text = " " .. opts.Text .. " "
            lbl.BackgroundColor3 = THEME.Bg
            lbl.Parent = page
            mkCorner(lbl, 4)
        end
        return sep
    end

    return api
end

function UiLib:Destroy()
    if self._isDestroying then return end
    if self.Window and self.RootGui and self.RootGui.Enabled then
        self._isDestroying = true
        if self._showGui then self._showGui.Enabled = false end
        local fs = UDim2.new(self.Window.Size.X.Scale, math.floor(self.Window.Size.X.Offset * 0.2),
            self.Window.Size.Y.Scale, math.floor(self.Window.Size.Y.Offset * 0.2))
        tw(self.Window, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            Size = fs, BackgroundTransparency = 1
        }).Completed:Connect(function()
            for _, c in ipairs(self._connections or {}) do if c and c.Disconnect then c:Disconnect() end end
            self._connections = nil
            if self.RootGui then self.RootGui:Destroy() end
            if self._showGui then self._showGui:Destroy() end
        end)
        return
    end
    for _, c in ipairs(self._connections or {}) do if c and c.Disconnect then c:Disconnect() end end
    if self.RootGui then self.RootGui:Destroy() end
    if self._showGui then self._showGui:Destroy() end
end

