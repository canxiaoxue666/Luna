            searchBox.Text = ""
            searchBox.TextColor3 = THEME.Text
            searchBox.TextSize = 11
            searchBox.TextXAlignment = Enum.TextXAlignment.Left
            searchBox.Parent = searchFrame
            mkCorner(searchBox, 6)
            mkStroke(searchBox, THEME.Stroke, 1, 0.4)
            mkPad(searchBox, 8, 0, 4, 0)
        end

        local optHolder = Instance.new("ScrollingFrame")
        optHolder.Position = UDim2.new(0, 6, 0, 38 + searchExtra)
        optHolder.Size = UDim2.new(1, -12, 0, 0)
        optHolder.BackgroundTransparency = 1
        optHolder.BorderSizePixel = 0
        optHolder.CanvasSize = UDim2.new(0, 0, 0, 0)
        optHolder.AutomaticCanvasSize = Enum.AutomaticSize.Y
        optHolder.ScrollBarThickness = 2
        optHolder.ScrollBarImageColor3 = THEME.TextMuted
