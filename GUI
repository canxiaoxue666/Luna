				local relX = math.clamp((mousePos.X - map.AbsolutePosition.X) / map.AbsoluteSize.X, 0, 1)
				local relY = math.clamp((mousePos.Y - map.AbsolutePosition.Y) / map.AbsoluteSize.Y, 0, 1)
