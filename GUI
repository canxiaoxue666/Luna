		dragHitbox.AnchorPoint = Vector2.new(0, 0.5)
		dragHitbox.Position = UDim2.new(0, 0, 0.5, 0)
		dragHitbox.Size = UDim2.new(1, 0, 0, 22)
		dragHitbox.ZIndex = 5
		dragHitbox.Parent = bar

		local fill = Instance.new("Frame")
		fill.Size = UDim2.new(0, 0, 1, 0)
		fill.BackgroundColor3 = THEME.Accent
		fill.Parent = bar
		createCorner(fill, 999)

		local fillTween: Tween? = nil
		local function tweenFillTo(percent: number)
			local p = math.clamp(percent, 0, 1)
			local target = UDim2.new(p, 0, 1, 0)
			if fillTween then
				fillTween:Cancel()
			end
			fillTween = TweenService:Create(
				fill,
				TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{ Size = target }
			)
			fillTween:Play()
		end

		local dragging = false
		local activeInput: InputObject?

		local function valueToPercent(v: number): number
			local span = max - min
			if span == 0 then
				return 0
			end
			return (v - min) / span
		end

		local function setByX(mouseX: number)
			local startX = bar.AbsolutePosition.X
			local width = bar.AbsoluteSize.X
			if width <= 0 then
				return
			end
			local alpha = math.clamp((mouseX - startX) / width, 0, 1)
			local raw = min + (max - min) * alpha
			local snapped = math.floor(raw / step + 0.5) * step
			value = normalizeNumber(math.clamp(snapped, min, max))
			tweenFillTo(valueToPercent(value))
			valueLabel.Text = formatValue(value)
			if opts.Callback then
				opts.Callback(value)
			end
		end

		local function updateVisual()
			value = normalizeNumber(value)
			tweenFillTo(valueToPercent(value))
			valueLabel.Text = formatValue(value)
		end
		updateVisual()

		local function isDragInput(input: InputObject): boolean
			return input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch
		end

		dragHitbox.InputBegan:Connect(function(input)
			if not isDragInput(input) then
				return
			end
			dragging = true
			activeInput = input
			setByX(input.Position.X)
		end)

		UserInputService.InputChanged:Connect(function(input)
			if not dragging then
				return
			end
			if input.UserInputType == Enum.UserInputType.MouseMovement then
				local mousePos = UserInputService:GetMouseLocation()
				setByX(mousePos.X)
				return
			end
			if activeInput and input ~= activeInput then
				return
			end
			if input.UserInputType ~= Enum.UserInputType.Touch then
				return
			end
			setByX(input.Position.X)
		end)

		UserInputService.InputEnded:Connect(function(input)
			if not dragging then
				return
			end
			if activeInput and input ~= activeInput then
				return
			end
			if not isDragInput(input) then
				return
			end
			dragging = false
			activeInput = nil
		end)

		local sApi = {
			Set = function(_, val)
				value = math.clamp(val, min, max)
				updateVisual()
			end,
			Get = function()
				return value
			end,
		}
		registerConfigIfAny(opts, sApi)
		return sApi
	end

	function api:Input(opts)
		api._embedColorTarget = nil
		opts = opts or {}
		local title = opts.Title or "Input"
		local card = Instance.new("Frame")
		card.Size = UDim2.new(1, 0, 0, 42)
		card.BackgroundColor3 = THEME.Card
		card.Parent = page
		createCorner(card, 12)
		createStroke(card, THEME.Stroke, 1, 0.4)

		local titleLabel = Instance.new("TextLabel")
		titleLabel.BackgroundTransparency = 1
		titleLabel.Position = UDim2.new(0, 12, 0, 0)
		titleLabel.Size = UDim2.new(0, 120, 1, 0)
		titleLabel.TextXAlignment = Enum.TextXAlignment.Left
		titleLabel.Font = FONTS.Default
		titleLabel.TextSize = 13
		titleLabel.TextColor3 = THEME.Text
		titleLabel.Text = title
		titleLabel.Parent = card

		local box = Instance.new("TextBox")
		box.AnchorPoint = Vector2.new(1, 0.5)
		box.Position = UDim2.new(1, -10, 0.5, 0)
