local notifyStack = {
	_holder = nil :: ScreenGui?,
	_container = nil :: Frame?,
	_cards = {} :: { Frame },
}

local function notifyGetTargetPositions(): { [Instance]: UDim2 }
	local cards = notifyStack._cards
	local out: { [Instance]: UDim2 } = {}
	local gap = 8
	local padBottom = 4
	local acc = padBottom
	for idx = #cards, 1, -1 do
		local c = cards[idx]
		if c and c.Parent then
			local h = c.AbsoluteSize.Y
			if h < 24 then
				h = 72
			end
			local safeH = math.max(h, 48)
			out[c] = UDim2.new(0, 0, 1, -acc - safeH)
			acc += safeH + gap
		end
	end
	return out
end

local function notifyTweenStackToTargets(except: Frame?)
	local targets = notifyGetTargetPositions()
	for c, tgt in pairs(targets) do
		if (not except or c ~= except) and c.Parent then
			c.AnchorPoint = Vector2.new(0, 1)
			TweenService:Create(
				c,
				TweenInfo.new(0.26, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
				{ Position = tgt }
			):Play()
		end
	end
end

local function notifyEnsureChrome()
	if notifyStack._holder and notifyStack._holder.Parent then
		return
	end
	if notifyStack._holder then
		pcall(function()
			notifyStack._holder:Destroy()
		end)
		notifyStack._holder = nil
		notifyStack._container = nil
		notifyStack._cards = {}
	end
	local holder = Instance.new("ScreenGui")
	holder.Name = "ModernUiNotify"
	holder.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	holder.ResetOnSpawn = false
	holder.IgnoreGuiInset = true
	holder.DisplayOrder = 999999
	holder.Parent = ensurePlayerGui()

	local container = Instance.new("Frame")
	container.Name = "Container"
	container.AnchorPoint = Vector2.new(1, 1)
	container.Position = UDim2.new(1, -18, 1, -18)
	container.Size = UDim2.new(0, 320, 1, -36)
	container.BackgroundTransparency = 1
	container.ClipsDescendants = true
	container.Parent = holder

	createPadding(container, 4)

	notifyStack._holder = holder
	notifyStack._container = container
	notifyStack._cards = {}
end

function UiLib:CreateWatermark(opts)
	opts = opts or {}

	local existingGlobal = nil
	pcall(function()
		existingGlobal = CoreGui:FindFirstChild("MoonLuaWatermark", true)
	end)
	if existingGlobal and (existingGlobal:IsA("CanvasGroup") or existingGlobal:IsA("Frame")) then
		self._watermark = existingGlobal
		return existingGlobal
	end

	if self._watermark and self._watermark.Parent then
		local oldWm = self._watermark
		self._watermark = nil
		tweenWatermarkOutBlocking(oldWm)
	end

	local frame = Instance.new("CanvasGroup")
	frame.Name = "MoonLuaWatermark"
	frame.BorderSizePixel = 0
	frame.GroupTransparency = 1
	if opts.Position then
		frame.AnchorPoint = Vector2.new(0, 0)
		frame.Position = opts.Position
	else
		frame.AnchorPoint = Vector2.new(1, 0)
		frame.Position = UDim2.new(1, -10, 0, 10)
	end
	frame.Size = UDim2.new(0, 200, 0, 30)
	local win = self.Window
	local winBg = (win and win.BackgroundColor3) or THEME.Bg
	local winTrans = self._windowFrameTransparency
	if winTrans == nil then
		winTrans = 0
	end
	frame.BackgroundTransparency = 1
	frame.Parent = self.RootGui
	createCorner(frame, 18)
	createStroke(frame, THEME.Stroke, 2.2, 0)

	local backdrop = Instance.new("Frame")
	backdrop.Name = "WatermarkBackdrop"
	backdrop.AnchorPoint = Vector2.new(0, 0)
	backdrop.Position = UDim2.new(0, 0, 0, 0)
	backdrop.Size = UDim2.new(1, 0, 1, 0)
	backdrop.BackgroundColor3 = winBg
	backdrop.BackgroundTransparency = math.min(winTrans, 0.52)
	backdrop.BorderSizePixel = 0
	backdrop.ZIndex = 0
	backdrop.Parent = frame
	createCorner(backdrop, 18)

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 8, 0, 0)
	label.Size = UDim2.new(1, -14, 1, 0)
	label.ZIndex = 1
	label.Font = FONTS.Default
	label.TextSize = 12
	label.TextColor3 = THEME.Text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "FPS:   0 | Ping:   -- ms | 00:00"
	label.Parent = frame

	local drag = false
	local dragStart = Vector2.zero
	local startPos = frame.Position

	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			drag = true
			dragStart = input.Position
			startPos = frame.Position
		end
	end)

	table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			drag = false
		end
	end))

	table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
		if drag and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end))

	local fpsCounter = 0
	local fpsValue = 0
	local fpsTick = os.clock()
	local pingTick = 0
	local pingText = "-- ms"

	table.insert(self._connections, RunService.RenderStepped:Connect(function()
		fpsCounter += 1
		local now = os.clock()
		local elapsed = now - fpsTick
		if elapsed >= 0.5 then
			fpsValue = math.floor((fpsCounter / elapsed) + 0.5)
			fpsCounter = 0
			fpsTick = now
		end
		if now - pingTick >= 0.25 then
			pingTick = now
			local ok, text = pcall(function()
				return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
			end)
			if ok and text then
				local numeric = tonumber(string.match(tostring(text), "%d+%.?%d*"))
				if numeric then
					pingText = string.format("%d ms", math.floor(numeric + 0.5))
				else
					pingText = "-- ms"
				end
			else
				pingText = "-- ms"
			end
		end
		if label.Parent then
			local fpsDisp = math.clamp(fpsValue, 0, 999)
			local p = tostring(pingText)
			if #p > 7 then
				p = string.sub(p, 1, 7)
			end
			local pingDisp = string.format("%7s", p)
			label.Text = string.format("FPS:%3d | Ping:%s | %s", fpsDisp, pingDisp, os.date("%H:%M"))
		end
	end))

	self._watermark = frame
	tweenWatermarkIn(frame)
	return frame
end

function UiLib.Notify(a, b)
	local opts
	if b ~= nil then
		opts = b
	elseif typeof(a) == "table" then
		opts = a
	else
		opts = {}
	end
	opts = opts or {}
	local title = opts.Title or "通知"
	local content = opts.Content or ""
	local duration = opts.Duration or 3
	local kind = opts.Type or "info"

	notifyEnsureChrome()

	local card = Instance.new("Frame")
	card.AnchorPoint = Vector2.new(0, 1)
	card.BackgroundColor3 = THEME.Card
	card.Size = UDim2.new(1, -8, 0, 0)
	card.AutomaticSize = Enum.AutomaticSize.Y
	card.BackgroundTransparency = 1
	card.Position = UDim2.new(0, 80, 1, -12)
	card.Parent = notifyStack._container

	local cardScale = Instance.new("UIScale")
	cardScale.Scale = 0.88
	cardScale.Parent = card

	createCorner(card, 12)
	createStroke(card, THEME.Stroke, 1, 0.35)
	createPadding(card, 10)

	local row = Instance.new("Frame")
	row.BackgroundTransparency = 1
	row.Size = UDim2.new(1, 0, 0, 0)
	row.AutomaticSize = Enum.AutomaticSize.Y
	row.Parent = card

	local rowLayout = Instance.new("UIListLayout")
	rowLayout.FillDirection = Enum.FillDirection.Horizontal
	rowLayout.Padding = UDim.new(0, 10)
	rowLayout.VerticalAlignment = Enum.VerticalAlignment.Top
	rowLayout.Parent = row

	local leftImage = Instance.new("ImageLabel")
	leftImage.BackgroundTransparency = 1
	leftImage.Size = UDim2.new(0, 42, 0, 42)
	leftImage.Image = "rbxassetid://117840249597764"
	leftImage.ScaleType = Enum.ScaleType.Crop
	leftImage.Parent = row
	createCorner(leftImage, 10)
	createStroke(leftImage, THEME.Stroke, 1, 0.25)

	local contentWrap = Instance.new("Frame")
	contentWrap.BackgroundTransparency = 1
	contentWrap.Size = UDim2.new(1, -52, 0, 0)
	contentWrap.AutomaticSize = Enum.AutomaticSize.Y
	contentWrap.Parent = row
	createList(contentWrap, 4)

	local titleLabel = Instance.new("TextLabel")
	titleLabel.BackgroundTransparency = 1
	titleLabel.Size = UDim2.new(1, 0, 0, 20)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.Font = FONTS.Default
	titleLabel.TextSize = 14
	titleLabel.Text = title
	titleLabel.TextColor3 = kind == "success" and THEME.Success or (kind == "error" and THEME.Error or THEME.Text)
	titleLabel.Parent = contentWrap

	local contentLabel = Instance.new("TextLabel")
	contentLabel.BackgroundTransparency = 1
	contentLabel.Size = UDim2.new(1, 0, 0, 18)
	contentLabel.AutomaticSize = Enum.AutomaticSize.Y
	contentLabel.TextWrapped = true
	contentLabel.TextXAlignment = Enum.TextXAlignment.Left
	contentLabel.TextYAlignment = Enum.TextYAlignment.Top
	contentLabel.Font = FONTS.Default
	contentLabel.TextSize = 13
	contentLabel.Text = content
	contentLabel.TextColor3 = THEME.TextSoft
	contentLabel.Parent = contentWrap

	table.insert(notifyStack._cards, card)

	task.defer(function()
		if not card.Parent then
			return
		end
		local snapshot = {}
		for _, c in ipairs(notifyStack._cards) do
			if c ~= card and c.Parent then
				snapshot[c] = c.Position
			end
		end

		local targets = notifyGetTargetPositions()
		local targetPos = targets[card]
		if not targetPos then
			return
		end

		card.AnchorPoint = Vector2.new(0, 1)

		for c, tgt in pairs(targets) do
			if c ~= card and c.Parent and snapshot[c] then
				c.Position = snapshot[c]
				TweenService:Create(
					c,
					TweenInfo.new(0.26, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
					{ Position = tgt }
				):Play()
			end
		end

		card.Position =
			UDim2.new(targetPos.X.Scale, targetPos.X.Offset + 64, targetPos.Y.Scale, targetPos.Y.Offset)
		TweenService:Create(
			card,
			TweenInfo.new(0.34, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Position = targetPos, BackgroundTransparency = 0.05}
		):Play()
		TweenService:Create(
			cardScale,
			TweenInfo.new(0.34, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Scale = 1}
		):Play()
	end)

	task.delay(duration, function()
		if not card.Parent then
			return
		end
		local leavePos = UDim2.new(
			card.Position.X.Scale,
			card.Position.X.Offset + 56,
			card.Position.Y.Scale,
			card.Position.Y.Offset
		)
		local leaveTween = TweenService:Create(
			card,
			TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
			{Position = leavePos, BackgroundTransparency = 1}
		)
		TweenService:Create(
			cardScale,
			TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
			{Scale = 0.78}
		):Play()
		leaveTween:Play()
		leaveTween.Completed:Wait()
		for i = #notifyStack._cards, 1, -1 do
			if notifyStack._cards[i] == card then
				table.remove(notifyStack._cards, i)
				break
			end
		end
		card:Destroy()
		notifyTweenStackToTargets()
	end)
end

local announcementGui: ScreenGui? = nil

function UiLib.ShowAnnouncement(str: string, closeButtonText: string?)
	local bodyText = typeof(str) == "string" and str or tostring(str)
	local buttonLabel = "Close"
	if closeButtonText ~= nil and typeof(closeButtonText) == "string" and closeButtonText ~= "" then
		buttonLabel = closeButtonText
	end
	if announcementGui and announcementGui.Parent then
		pcall(function()
			announcementGui:Destroy()
		end)
	end
	announcementGui = nil

	local holder = Instance.new("ScreenGui")
	holder.Name = "ModernUiAnnouncement"
	holder.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	holder.ResetOnSpawn = false
	holder.IgnoreGuiInset = true
	holder.DisplayOrder = 1000001
	holder.Parent = ensurePlayerGui()
	announcementGui = holder

	local root = Instance.new("CanvasGroup")
	root.Name = "AnnouncementRoot"
	root.Size = UDim2.new(1, 0, 1, 0)
	root.Position = UDim2.new(0, 0, 0, 0)
	root.BackgroundTransparency = 1
	root.BorderSizePixel = 0
	root.GroupTransparency = 1
	root.Parent = holder

	local dismissing = false
	local function finishDestroy()
		if announcementGui == holder then
			announcementGui = nil
		end
		if holder.Parent then
			holder:Destroy()
		end
	end

	local function dismiss()
		if dismissing or not root.Parent then
			return
		end
		dismissing = true
		local tw = TweenService:Create(root, ANIM.Normal, { GroupTransparency = 1 })
		tw:Play()
		tw.Completed:Wait()
		finishDestroy()
	end

	local overlay = Instance.new("TextButton")
	overlay.Name = "Dim"
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3 = Color3.new(0, 0, 0)
