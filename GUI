			if opts.Callback then
				task.spawn(opts.Callback, box.Text, enterPressed)
			end
		end)

		local inApi = {
			Set = function(_, val)
				box.Text = tostring(val)
			end,
			Get = function()
				return box.Text
			end,
		}
		registerConfigIfAny(opts, inApi)
		return inApi
	end

	function api:Dropdown(opts)
		api._embedColorTarget = nil
		opts = opts or {}
		local title = opts.Title or "Dropdown"
		local values = opts.Values or {}
		local multi = opts.Multi == true
		local maxDisplay = opts.MaxDisplay or 2
		local selected
		local selectedMap = nil
		if multi then
			selectedMap = {}
			if type(opts.Default) == "table" then
				for _, v in ipairs(opts.Default) do
					selectedMap[v] = true
				end
			elseif opts.Default ~= nil then
				selectedMap[opts.Default] = true
			end
		else
			selected = opts.Default or values[1] or "None"
		end

		local open = false
		local visibleCount = math.min(#values, 4)
		local enableSearch = opts.Search ~= false
		local searchExtra = enableSearch and 36 or 0

		local card = Instance.new("Frame")
		card.Size = UDim2.new(1, 0, 0, 42)
		card.BackgroundColor3 = THEME.Card
		card.ClipsDescendants = true
		card.Parent = page
		createCorner(card, 12)
		createStroke(card, THEME.Stroke, 1, 0.4)

		local btn = Instance.new("TextButton")
		btn.BackgroundTransparency = 1
		btn.Size = UDim2.new(1, 0, 0, 42)
		btn.Text = ""
		btn.AutoButtonColor = false
		btn.Parent = card

		local titleLabel = Instance.new("TextLabel")
		titleLabel.BackgroundTransparency = 1
		titleLabel.Position = UDim2.new(0, 12, 0, 0)
		titleLabel.Size = UDim2.new(0.5, 0, 0, 42)
		titleLabel.TextXAlignment = Enum.TextXAlignment.Left
		titleLabel.Font = FONTS.Default
		titleLabel.TextSize = 13
		titleLabel.TextColor3 = THEME.Text
		titleLabel.Text = title
		titleLabel.Parent = card

		local valueLabel = Instance.new("TextLabel")
		valueLabel.BackgroundTransparency = 1
		valueLabel.Position = UDim2.new(0.5, 0, 0, 0)
		valueLabel.Size = UDim2.new(0.5, -26, 0, 42)
		valueLabel.TextXAlignment = Enum.TextXAlignment.Right
		valueLabel.Font = FONTS.Default
		valueLabel.TextSize = 12
		valueLabel.TextColor3 = THEME.TextSoft
		if multi then
			valueLabel.Text = "None"
		else
			valueLabel.Text = tostring(selected)
		end
		valueLabel.Parent = card

		local function getMultiSelectedOrdered()
			local sel = {}
			if not selectedMap then
				return sel
			end
			for _, v in ipairs(values) do
				if selectedMap[v] then
					table.insert(sel, v)
				end
			end
			return sel
		end

		local function refreshHeaderLabel()
			if multi then
				local list = getMultiSelectedOrdered()
				local count = #list
				if count == 0 then
					valueLabel.Text = "None"
					return
				end
				if count <= maxDisplay then
					local parts = {}
					for i = 1, count do
						parts[i] = tostring(list[i])
					end
					valueLabel.Text = table.concat(parts, ", ")
				else
					valueLabel.Text = tostring(list[1]) .. " +" .. tostring(count - 1)
				end
				return
			end
			valueLabel.Text = tostring(selected)
		end

		local function refreshOptionChosenStyle(optBtn, selectedNow)
			optBtn.BackgroundColor3 = selectedNow and THEME.AccentSoft or THEME.Bg2
			optBtn.TextColor3 = selectedNow and THEME.Text or THEME.TextSoft
		end

		local arrow = Instance.new("TextLabel")
		arrow.BackgroundTransparency = 1
		arrow.AnchorPoint = Vector2.new(1, 0.5)
		arrow.Position = UDim2.new(1, -10, 0, 21)
		arrow.Size = UDim2.new(0, 14, 0, 14)
		arrow.Text = "v"
		arrow.Font = FONTS.Default
		arrow.TextSize = 12
		arrow.TextColor3 = THEME.TextSoft
		arrow.Parent = card

		local searchFrame = Instance.new("Frame")
		searchFrame.Name = "DropdownSearch"
		searchFrame.Position = UDim2.new(0, 8, 0, 46)
		searchFrame.Size = UDim2.new(1, -16, 0, 28)
		searchFrame.BackgroundTransparency = 1
		searchFrame.Visible = false
		searchFrame.ClipsDescendants = true
		searchFrame.Parent = card

		local searchBox
		if enableSearch then
			searchBox = Instance.new("TextBox")
			searchBox.Name = "Search"
			searchBox.Size = UDim2.new(1, 0, 1, 0)
			searchBox.BackgroundColor3 = THEME.Bg2
			searchBox.BorderSizePixel = 0
			searchBox.ClearTextOnFocus = false
			searchBox.Font = FONTS.Default
			searchBox.PlaceholderColor3 = THEME.TextSoft
			searchBox.PlaceholderText = opts.SearchPlaceholder or "搜索..."
			searchBox.Text = ""
			searchBox.TextColor3 = THEME.Text
			searchBox.TextSize = 12
			searchBox.TextXAlignment = Enum.TextXAlignment.Left
			searchBox.Parent = searchFrame

			createCorner(searchBox, 7)
			createStroke(searchBox, THEME.Stroke, 1, 0.35)

			local sp = Instance.new("UIPadding")
			sp.PaddingLeft = UDim.new(0, 8)
			sp.PaddingRight = UDim.new(0, 6)
			sp.Parent = searchBox
		end

		local optionsHolder = Instance.new("ScrollingFrame")
		optionsHolder.Position = UDim2.new(0, 8, 0, 44 + searchExtra)
		optionsHolder.Size = UDim2.new(1, -16, 0, 0)
		optionsHolder.BackgroundTransparency = 1
		optionsHolder.BorderSizePixel = 0
		optionsHolder.CanvasSize = UDim2.new(0, 0, 0, 0)
		optionsHolder.AutomaticCanvasSize = Enum.AutomaticSize.Y
		optionsHolder.ScrollBarThickness = 3
		optionsHolder.ScrollBarImageColor3 = THEME.TextSoft
		optionsHolder.ScrollBarImageTransparency = 0.45
		optionsHolder.ScrollingDirection = Enum.ScrollingDirection.Y
		optionsHolder.Parent = card
		local optionsList = createList(optionsHolder, 4)
		optionsList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			optionsHolder.CanvasSize = UDim2.new(0, 0, 0, optionsList.AbsoluteContentSize.Y)
		end)

		local optionBtns = {}

		local function containsValue(list, target)
			for _, v in ipairs(list) do
				if v == target then
					return true
				end
			end
			return false
		end

		local function refreshAllMultiChoices()
			if not multi then
				return
			end
			for ix, ov in ipairs(values) do
				local bt = optionBtns[ix]
				if bt then
					refreshOptionChosenStyle(bt, selectedMap and selectedMap[ov] == true)
				end
			end
		end

		local function applySearchFilter()
			if not searchBox then
				return
			end
			local ql = string.lower(searchBox.Text or "")
			for idx, optVal in ipairs(values) do
				local bt = optionBtns[idx]
				if bt then
					if ql == "" then
						bt.Visible = true
					else
						local label = string.lower(tostring(optVal))
						bt.Visible = string.find(label, ql, 1, true) ~= nil
					end
				end
			end
			optionsHolder.CanvasPosition = Vector2.zero
		end

		local function setOpen(flag: boolean)
			open = flag
			if searchFrame then
				searchFrame.Visible = enableSearch and flag == true or false
			end
			if flag and enableSearch and searchBox then
				searchBox.Text = ""
				applySearchFilter()
			end
			local visibleHeight = visibleCount > 0 and (visibleCount * 30 - 4) or 0
			optionsHolder.Size = UDim2.new(1, -16, 0, flag and visibleHeight or 0)
			local targetHeight =
				open and (42 + searchExtra + (visibleCount * 30) + 10) or 42
			tween(card, ANIM.Normal, {Size = UDim2.new(1, 0, 0, targetHeight)})
			arrow.Text = flag and "^" or "v"
		end

		local function rebuildOptionButtons()
			for _, oldBtn in ipairs(optionBtns) do
				if oldBtn and oldBtn.Parent then
					oldBtn:Destroy()
				end
			end
			optionBtns = {}

			for idx, option in ipairs(values) do
				local opt = Instance.new("TextButton")
				opt.Size = UDim2.new(1, 0, 0, 26)
				opt.BackgroundColor3 = THEME.Bg2
				opt.Text = tostring(option)
				opt.TextColor3 = THEME.TextSoft
				opt.Font = FONTS.Default
				opt.TextSize = 12
				opt.AutoButtonColor = false
				opt.Parent = optionsHolder
				createCorner(opt, 7)

				optionBtns[idx] = opt

				if multi then
					refreshOptionChosenStyle(opt, selectedMap[option] == true)
				end

				opt.MouseEnter:Connect(function()
					if multi and selectedMap[option] then
						return
					end
					tween(opt, ANIM.Fast, {BackgroundColor3 = Color3.fromRGB(36, 40, 52), TextColor3 = THEME.Text})
				end)
				opt.MouseLeave:Connect(function()
					if multi then
						refreshOptionChosenStyle(opt, selectedMap[option] == true)
						return
					end
					tween(opt, ANIM.Fast, {BackgroundColor3 = THEME.Bg2, TextColor3 = THEME.TextSoft})
				end)
				opt.MouseButton1Click:Connect(function()
					if multi then
						if selectedMap[option] then
							selectedMap[option] = nil
						else
							selectedMap[option] = true
						end
						refreshOptionChosenStyle(opt, selectedMap[option] == true)
						refreshHeaderLabel()
						if opts.Callback then
							task.spawn(opts.Callback, getMultiSelectedOrdered())
						end
						return
					end
					selected = option
					refreshHeaderLabel()
					setOpen(false)
					if opts.Callback then
						task.spawn(opts.Callback, selected)
					end
				end)
			end
		end
		rebuildOptionButtons()

		if searchBox then
			searchBox:GetPropertyChangedSignal("Text"):Connect(applySearchFilter)
		end

		btn.MouseButton1Click:Connect(function()
			setOpen(not open)
		end)

		if multi then
			refreshHeaderLabel()
			refreshAllMultiChoices()
		end

		local ddApi = {
			Set = function(_, val)
				if multi then
					selectedMap = {}
					if type(val) == "table" then
						for _, v in ipairs(val) do
							selectedMap[v] = true
						end
					elseif val ~= nil then
						selectedMap[val] = true
					end
					refreshAllMultiChoices()
					refreshHeaderLabel()
					if opts.Callback then
						task.spawn(opts.Callback, getMultiSelectedOrdered())
					end
					return
				end
				selected = val
				refreshHeaderLabel()
				if opts.Callback then
					task.spawn(opts.Callback, selected)
				end
			end,
			Get = function()
				if multi then
					return getMultiSelectedOrdered()
				end
				return selected
			end,
			SetValues = function(_, newValues)
				if type(newValues) ~= "table" then
					return
				end
				values = newValues
				visibleCount = math.min(#values, 4)
				if multi then
					local nextMap = {}
					for _, v in ipairs(values) do
						if selectedMap and selectedMap[v] then
							nextMap[v] = true
						end
					end
					selectedMap = nextMap
				else
					if not containsValue(values, selected) then
						selected = values[1] or "None"
					end
				end
				rebuildOptionButtons()
				refreshHeaderLabel()
				applySearchFilter()
			end,
		}
		registerConfigIfAny(opts, ddApi)
		return ddApi
	end

	function api:Colorpicker(opts)
		opts = opts or {}
		local row = api._embedColorTarget
		if row ~= nil and type(row) == "table" and type(row.Colorpicker) == "function" then
			return row:Colorpicker(opts)
		end
		return colorPickerCore(opts)
	end

	return api
end

function UiLib:Destroy()
	if self._isDestroying then
		return
	end
	if self.Window and self.RootGui and self.RootGui.Enabled then
		self._isDestroying = true
		if self._showGui then
			self._showGui.Enabled = false
		end
		local window = self.Window
		self._targetWindowAnchor = window.AnchorPoint
		local fw = math.max(math.floor(window.Size.X.Offset * 0.1), 36)
		local fh = math.max(math.floor(window.Size.Y.Offset * 0.1), 28)
		local finalSize = UDim2.new(window.Size.X.Scale, fw, window.Size.Y.Scale, fh)
		local cam = Workspace.CurrentCamera
		local vps = cam and cam.ViewportSize or Vector2.new(1920, 1080)
		local pad = 18
		local parent = window.Parent
		local pAbs = Vector2.zero
		if parent then
			pcall(function()
				pAbs = (parent :: any).AbsolutePosition
			end)
		end
		local screenCenter = Vector2.new(vps.X - pad - fw * 0.5, pad + fh * 0.5)
		local off = screenCenter - pAbs
		local endPos = UDim2.fromOffset(math.floor(off.X + 0.5), math.floor(off.Y + 0.5))
		local closeTween = tween(window, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = finalSize,
			Position = endPos,
			GroupTransparency = 1,
		})
		closeTween.Completed:Connect(function()
			if self._connections then
				for _, con in ipairs(self._connections) do
					if con and con.Disconnect then
						con:Disconnect()
					end
				end
				self._connections = nil
			end
			if self._watermark and self._watermark.Parent then
				local wm = self._watermark
				self._watermark = nil
				pcall(tweenWatermarkOutBlocking, wm)
			end
			if self.RootGui then
				self.RootGui:Destroy()
			end
			if self._showGui then
				self._showGui:Destroy()
			end
		end)
		return
	end
	if self._connections then
		for _, con in ipairs(self._connections) do
			if con and con.Disconnect then
				con:Disconnect()
			end
		end
		self._connections = nil
	end
	if self._watermark and self._watermark.Parent then
		local wm = self._watermark
		self._watermark = nil
		pcall(tweenWatermarkOutBlocking, wm)
	end
	if self.RootGui then
		self.RootGui:Destroy()
	end
	if self._showGui then
		self._showGui:Destroy()
	end
end

UiLib.Theme = THEME
UiLib.Anim = ANIM
UiLib.Fonts = FONTS
pcall(setfpscap, math.huge)
return UiLib
