		local function formatBinding(b: KeybindBinding?): string
			if not b then
				return "None"
			end
			if b.kind == "key" then
				return b.code.Name
			end
			return b.code.Name
		end

		local function bindingMatchesInput(input: InputObject, b: KeybindBinding): boolean
			if b.kind == "key" then
				return input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == b.code
			end
			return input.UserInputType == b.code
		end

		local function updateKeyLabel()
