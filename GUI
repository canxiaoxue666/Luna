				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
					local inset = GuiService:GetGuiInset()
					local inputPos = Vector2.new(input.Position.X, input.Position.Y)
					set(inputPos - inset)
					if heartCon then heartCon:Disconnect() end
					heartCon = RunService.Heartbeat:Connect(function()
						if dragging then
							local inset = GuiService:GetGuiInset()
							set(UserInputService:GetMouseLocation() - inset)
						end
					end)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
					if heartCon then heartCon:Disconnect() heartCon = nil end
