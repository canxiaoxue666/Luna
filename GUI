local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local GuiService = game:GetService("GuiService")
local Workspace = game:GetService("Workspace")
local Stats = game:GetService("Stats")

local UiLib = {}
UiLib.__index = UiLib

local THEME = {
	Bg = Color3.fromRGB(15, 17, 22),
	BgTransparency = 0.18,
	Bg2 = Color3.fromRGB(21, 24, 31),
	Bg2Transparency = 0.15,
	Card = Color3.fromRGB(28, 32, 41),
	CardTransparency = 0.2,
	Accent = Color3.fromRGB(109, 141, 255),
	AccentSoft = Color3.fromRGB(81, 107, 198),
	Text = Color3.fromRGB(236, 240, 247),
	TextSoft = Color3.fromRGB(153, 162, 179),
	Stroke = Color3.fromRGB(44, 49, 62),
	StrokeTransparency = 0.25,
	Success = Color3.fromRGB(89, 194, 133),
	Error = Color3.fromRGB(220, 88, 98),

	WindowBgTransparency = 0.12,
	TitleBarTransparency = 0.1,
}

local ANIM = {
	Fast = TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	Normal = TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
	Slow = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
}

local function tween(instance, info, props)
	local t = TweenService:Create(instance, info, props)
	t:Play()
	return t
end

local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function stroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Thickness = thickness
	s.Transparency = transparency or THEME.StrokeTransparency
	s.Parent = parent
	return s
end

local function padding(parent, px)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, px)
	p.PaddingBottom = UDim.new(0, px)
	p.PaddingLeft = UDim.new(0, px)
	p.PaddingRight = UDim.new(0, px)
	p.Parent = parent
	return p
end

local function listLayout(parent, gap, alignment)
	local l = Instance.new("UIListLayout")
	l.Padding = UDim.new(0, gap)
	l.FillDirection = Enum.FillDirection.Vertical
	l.HorizontalAlignment = alignment or Enum.HorizontalAlignment.Left
	l.SortOrder = Enum.SortOrder.LayoutOrder
	l.Parent = parent
	return l
end

local function ensurePlayerGui()
	local player = game:GetService("Players").LocalPlayer
	if player then
		return player:WaitForChild("PlayerGui")
	end
	return CoreGui
end

-- 水印
function UiLib:CreateWatermark(opts)
	opts = opts or {}
	local existing
	pcall(function() existing = CoreGui:FindFirstChild("MoonLuaWatermark", true) end)
	if existing and existing:IsA("Frame") then
		self._watermark = existing
		return existing
	end
	if self._watermark and self._watermark.Parent then self._watermark:Destroy() end

	local frame = Instance.new("Frame")
	frame.Name = "MoonLuaWatermark"
	frame.AnchorPoint = Vector2.new(0.5, 0)
	frame.Position = opts.Position or UDim2.new(0.8, 0, 0, 10)
	frame.Size = UDim2.new(0, 150, 0, 30)
	frame.BackgroundColor3 = THEME.Bg2
	frame.BackgroundTransparency = THEME.Bg2Transparency
	frame.Parent = self.RootGui
	corner(frame, 9)
	stroke(frame, THEME.Stroke, 1, 0.35)

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 8, 0, 0)
	label.Size = UDim2.new(1, -14, 1, 0)
	label.Font = Enum.Font.GothamSemibold
	label.TextSize = 12
	label.TextColor3 = THEME.Text
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "FPS: -- | Ping: -- ms"
	label.Parent = frame

	local drag, dragStart, startPos = false, Vector2.zero, frame.Position

	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			drag = true
			dragStart = input.Position
			startPos = frame.Position
		end
	end)
	table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
	end))
	table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
		if drag and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end))

	local fpsCounter, fpsValue, fpsTick, pingTick, pingText = 0, 0, os.clock(), 0, "-- ms"
	table.insert(self._connections, RunService.RenderStepped:Connect(function()
		fpsCounter += 1
		local now = os.clock()
		if now - fpsTick >= 0.5 then
			fpsValue = math.floor(fpsCounter / (now - fpsTick) + 0.5)
			fpsCounter = 0
			fpsTick = now
		end
		if now - pingTick >= 0.25 then
			pingTick = now
			local ok, text = pcall(function()
				return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
			end)
			if ok and text then
				local num = tonumber(string.match(tostring(text), "%d+%.?%d*"))
				pingText = num and string.format("%d ms", math.floor(num + 0.5)) or "-- ms"
			else
				pingText = "-- ms"
			end
		end
		if label.Parent then
			label.Text = string.format("FPS: %d | Ping: %s", fpsValue, pingText)
		end
	end))

	self._watermark = frame
	return frame
end

-- 通知
function UiLib:_getNotifyTargetPositions()
	local cards = self._notifyCards
	local out = {}
	if not cards then return out end
	local gap, padBottom, acc = 8, 4, 4
	for i = #cards, 1, -1 do
		local c = cards[i]
		if c and c.Parent then
			local h = c.AbsoluteSize.Y
			if h < 24 then h = 72 end
			local safeH = math.max(h, 48)
			out[c] = UDim2.new(0, 0, 1, -acc - safeH)
			acc += safeH + gap
		end
	end
	return out
end

function UiLib:_tweenNotifyStackToTargets(except)
	local targets = self:_getNotifyTargetPositions()
	for c, pos in pairs(targets) do
		if (not except or c ~= except) and c.Parent then
			c.AnchorPoint = Vector2.new(0, 1)
			TweenService:Create(c, TweenInfo.new(0.26, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = pos}):Play()
		end
	end
end

function UiLib:Notify(opts)
	opts = opts or {}
	local title = opts.Title or "通知"
	local content = opts.Content or ""
	local duration = opts.Duration or 3
	local kind = opts.Type or "info"

	if not self._notifyHolder then
		local holder = Instance.new("ScreenGui")
		holder.Name = "ModernUiNotify_" .. math.random(100000, 999999)
		holder.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		holder.ResetOnSpawn = false
		holder.Parent = self.RootGui

		local container = Instance.new("Frame")
		container.Name = "Container"
		container.AnchorPoint = Vector2.new(1, 1)
		container.Position = UDim2.new(1, -18, 1, -18)
		container.Size = UDim2.new(0, 320, 1, -36)
		container.BackgroundTransparency = 1
		container.ClipsDescendants = true
		container.Parent = holder
		padding(container, 4)

		self._notifyHolder = holder
		self._notifyContainer = container
		self._notifyCards = {}
	end

	local card = Instance.new("Frame")
	card.AnchorPoint = Vector2.new(0, 1)
	card.BackgroundColor3 = THEME.Card
	card.BackgroundTransparency = THEME.CardTransparency
	card.Size = UDim2.new(1, -8, 0, 0)
	card.AutomaticSize = Enum.AutomaticSize.Y
	card.Position = UDim2.new(0, 80, 1, -12)
	card.Parent = self._notifyContainer

	local cardScale = Instance.new("UIScale")
	cardScale.Scale = 0.88
	cardScale.Parent = card
	corner(card, 12)
	stroke(card, THEME.Stroke, 1, 0.35)
	padding(card, 10)

	local row = Instance.new("Frame")
	row.BackgroundTransparency = 1
	row.Size = UDim2.new(1, 0, 0, 0)
	row.AutomaticSize = Enum.AutomaticSize.Y
	row.Parent = card

	local rowLayout = Instance.new("UIListLayout")
	rowLayout.FillDirection = Enum.FillDirection.Horizontal
	rowLayout.Padding = UDim.new(0, 10)
	rowLayout.VerticalAlignment = Enum.VerticalAlignment.Top
	rowLayout.Parent = row

	local leftImage = Instance.new("ImageLabel")
	leftImage.BackgroundTransparency = 1
	leftImage.Size = UDim2.new(0, 42, 0, 42)
	leftImage.Image = "rbxassetid://101568243558680"
	leftImage.ScaleType = Enum.ScaleType.Crop
	leftImage.Parent = row
	corner(leftImage, 10)
	stroke(leftImage, THEME.Stroke, 1, 0.25)

	local contentWrap = Instance.new("Frame")
	contentWrap.BackgroundTransparency = 1
	contentWrap.Size = UDim2.new(1, -52, 0, 0)
	contentWrap.AutomaticSize = Enum.AutomaticSize.Y
	contentWrap.Parent = row
	listLayout(contentWrap, 4)

	local titleLabel = Instance.new("TextLabel")
	titleLabel.BackgroundTransparency = 1
	titleLabel.Size = UDim2.new(1, 0, 0, 20)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.Font = Enum.Font.GothamSemibold
	titleLabel.TextSize = 14
	titleLabel.Text = title
	titleLabel.TextColor3 = kind == "success" and THEME.Success or (kind == "error" and THEME.Error or THEME.Text)
	titleLabel.Parent = contentWrap

	local contentLabel = Instance.new("TextLabel")
	contentLabel.BackgroundTransparency = 1
	contentLabel.Size = UDim2.new(1, 0, 0, 18)
	contentLabel.AutomaticSize = Enum.AutomaticSize.Y
	contentLabel.TextWrapped = true
	contentLabel.TextXAlignment = Enum.TextXAlignment.Left
	contentLabel.TextYAlignment = Enum.TextYAlignment.Top
	contentLabel.Font = Enum.Font.Gotham
	contentLabel.TextSize = 13
	contentLabel.Text = content
	contentLabel.TextColor3 = THEME.TextSoft
	contentLabel.Parent = contentWrap

	table.insert(self._notifyCards, card)

	task.defer(function()
		if not card.Parent then return end
		local snapshot = {}
		for _, c in ipairs(self._notifyCards) do
			if c ~= card and c.Parent then snapshot[c] = c.Position end
		end
		local targets = self:_getNotifyTargetPositions()
		local targetPos = targets[card]
		if not targetPos then return end
		card.AnchorPoint = Vector2.new(0, 1)
		for c, tgt in pairs(targets) do
			if c ~= card and c.Parent and snapshot[c] then
				c.Position = snapshot[c]
				TweenService:Create(c, TweenInfo.new(0.26, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = tgt}):Play()
			end
		end
		card.Position = UDim2.new(targetPos.X.Scale, targetPos.X.Offset + 64, targetPos.Y.Scale, targetPos.Y.Offset)
		TweenService:Create(card, TweenInfo.new(0.34, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = targetPos, BackgroundTransparency = THEME.CardTransparency}):Play()
		TweenService:Create(cardScale, TweenInfo.new(0.34, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
	end)

	task.delay(duration, function()
		if not card.Parent then return end
		local leavePos = UDim2.new(card.Position.X.Scale, card.Position.X.Offset + 56, card.Position.Y.Scale, card.Position.Y.Offset)
		local leaveTween = TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Position = leavePos, BackgroundTransparency = 1})
		TweenService:Create(cardScale, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Scale = 0.78}):Play()
		leaveTween:Play()
		leaveTween.Completed:Wait()
		for i = #self._notifyCards, 1, -1 do
			if self._notifyCards[i] == card then table.remove(self._notifyCards, i) break end
		end
		card:Destroy()
		self:_tweenNotifyStackToTargets()
	end)
end

-- 主窗口
function UiLib.new(opts)
	opts = opts or {}
	local self = setmetatable({}, UiLib)
	self.Theme = THEME
	self.Visible = true
	self._connections = {}

	local root = opts.Parent or ensurePlayerGui()
	if typeof(root) ~= "Instance" then root = CoreGui end

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = opts.Name or "ModernUi_" .. math.random(100000, 999999)
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.ResetOnSpawn = false
	screenGui.Parent = root
	self.RootGui = screenGui

	local window = Instance.new("Frame")
	window.Name = "Window"
	window.AnchorPoint = Vector2.new(0.5, 0.5)
	window.Position = opts.Position or UDim2.new(0.5, 0, 0.5, 0)
	window.Size = opts.Size or UDim2.new(0, 620, 0, 430)
	window.BackgroundColor3 = THEME.Bg
	window.BackgroundTransparency = THEME.WindowBgTransparency
	window.Parent = screenGui

	local windowImage = Instance.new("ImageLabel")
	windowImage.BackgroundTransparency = 1
	windowImage.Size = UDim2.new(1, 0, 1, 0)
	windowImage.Image = "rbxassetid://101568243558680"
	windowImage.ImageTransparency = 0.92
	windowImage.ImageColor3 = THEME.TextSoft
	windowImage.ScaleType = Enum.ScaleType.Fit
	windowImage.ZIndex = 0
	windowImage.Parent = window

	local uiScale = Instance.new("UIScale")
	uiScale.Scale = 1
	uiScale.Parent = window
	self._uiScale = uiScale
	self._targetWindowSize = window.Size
	self._targetWindowPosition = window.Position

	local function getViewportSize()
		local cam = Workspace.CurrentCamera
		return cam and cam.ViewportSize or Vector2.new(1920, 1080)
	end

	local function applyResponsiveScale()
		if opts.Responsive == false then uiScale.Scale = 1 return end
		local vp = getViewportSize()
		local fx = window.Size.X.Offset
		local fy = window.Size.Y.Offset
		local fit = math.min(vp.X / fx, vp.Y / fy)
		local min = opts.MinScale or (UserInputService.TouchEnabled and 0.65 or 0.78)
		local max = opts.MaxScale or 1.15
		uiScale.Scale = math.clamp(fit * 0.92, min, max)
	end
	applyResponsiveScale()

	local cam = Workspace.CurrentCamera
	if cam then
		table.insert(self._connections, cam:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsiveScale))
	end
	table.insert(self._connections, Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
		applyResponsiveScale()
		local curCam = Workspace.CurrentCamera
		if curCam then
			table.insert(self._connections, curCam:GetPropertyChangedSignal("ViewportSize"):Connect(applyResponsiveScale))
		end
	end))

	corner(window, 18)
	local borderPalette = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255,79,131)),
		ColorSequenceKeypoint.new(0.18, Color3.fromRGB(255,148,78)),
		ColorSequenceKeypoint.new(0.36, Color3.fromRGB(255,231,92)),
		ColorSequenceKeypoint.new(0.54, Color3.fromRGB(89,232,144)),
		ColorSequenceKeypoint.new(0.72, Color3.fromRGB(91,175,255)),
		ColorSequenceKeypoint.new(0.90, Color3.fromRGB(186,108,255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255,79,131))
	})
	local winStroke = stroke(window, THEME.Stroke, 2.2, 0)
	local borderGrad = Instance.new("UIGradient")
	borderGrad.Color = borderPalette
	borderGrad.Rotation = 25
	borderGrad.Parent = winStroke

	local glowStroke = stroke(window, Color3.fromRGB(255,255,255), 6, 0.55)
	glowStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	local glowGrad = Instance.new("UIGradient")
	glowGrad.Color = borderPalette
	glowGrad.Rotation = 205
	glowGrad.Parent = glowStroke

	TweenService:Create(borderGrad, TweenInfo.new(8, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1), {Rotation = 380}):Play()
	TweenService:Create(glowGrad, TweenInfo.new(10, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1), {Rotation = 560}):Play()
	self.Window = window

	-- 标题栏
	local titleBar = Instance.new("Frame")
	titleBar.Name = "TitleBar"
	titleBar.Size = UDim2.new(1, 0, 0, 54)
	titleBar.BackgroundColor3 = THEME.Bg2
	titleBar.BackgroundTransparency = THEME.TitleBarTransparency
	titleBar.Parent = window
	corner(titleBar, 18)
	stroke(titleBar, THEME.Stroke, 1, 0.5)

	local titleLabel = Instance.new("TextLabel")
	titleLabel.BackgroundTransparency = 1
	titleLabel.Position = UDim2.new(0, 16, 0, 0)
	titleLabel.Size = UDim2.new(1, -90, 1, 0)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.Font = Enum.Font.GothamSemibold
	titleLabel.TextSize = 16
	titleLabel.TextColor3 = THEME.Text
	titleLabel.Text = opts.Title or "Modern UI"
	titleLabel.Parent = titleBar

	local closeBtn = Instance.new("TextButton")
	closeBtn.AnchorPoint = Vector2.new(1, 0.5)
	closeBtn.Position = UDim2.new(1, -13, 0.5, 0)
	closeBtn.Size = UDim2.new(0, 28, 0, 28)
	closeBtn.BackgroundColor3 = Color3.fromRGB(150,60,70)
	closeBtn.Text = "x"
	closeBtn.TextColor3 = THEME.Text
	closeBtn.TextSize = 13
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.AutoButtonColor = false
	closeBtn.Parent = titleBar
	corner(closeBtn, 10)
	closeBtn.MouseEnter:Connect(function() tween(closeBtn, ANIM.Fast, {BackgroundColor3 = Color3.fromRGB(179,70,82)}) end)
	closeBtn.MouseLeave:Connect(function() tween(closeBtn, ANIM.Fast, {BackgroundColor3 = Color3.fromRGB(150,60,70)}) end)
	closeBtn.MouseButton1Click:Connect(function() self:Destroy() end)

	local hideBtn = Instance.new("TextButton")
	hideBtn.AnchorPoint = Vector2.new(1, 0.5)
	hideBtn.Position = UDim2.new(1, -47, 0.5, 0)
	hideBtn.Size = UDim2.new(0, 28, 0, 28)
	hideBtn.BackgroundColor3 = Color3.fromRGB(66,108,180)
	hideBtn.Text = "-"
	hideBtn.TextColor3 = THEME.Text
	hideBtn.TextSize = 16
	hideBtn.Font = Enum.Font.GothamBold
	hideBtn.AutoButtonColor = false
	hideBtn.Parent = titleBar
	corner(hideBtn, 10)
	hideBtn.MouseEnter:Connect(function() tween(hideBtn, ANIM.Fast, {BackgroundColor3 = Color3.fromRGB(90,132,210)}) end)
	hideBtn.MouseLeave:Connect(function() tween(hideBtn, ANIM.Fast, {BackgroundColor3 = Color3.fromRGB(66,108,180)}) end)

	-- 环境判断
	local isPC = not UserInputService.TouchEnabled
	local disableShowBtn = isPC and (opts.DisableShowButtonOnPC ~= false)
	local hotkey = opts.PCHotkey or Enum.KeyCode.RightShift
	local showBtnImage = opts.ShowButtonImage or "rbxassetid://101568243558680"

	-- 悬浮球
	if not disableShowBtn then
		local showGui = Instance.new("ScreenGui")
		showGui.Name = screenGui.Name .. "_ShowButton"
		showGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		showGui.ResetOnSpawn = false
		showGui.IgnoreGuiInset = true
		showGui.DisplayOrder = 999999
		showGui.Enabled = false
		showGui.Parent = root
		self._showGui = showGui

		local showBtn = Instance.new("ImageButton")
		showBtn.Name = "ShowUI"
		showBtn.AnchorPoint = Vector2.new(0.5, 0.5)
		showBtn.Position = UDim2.new(0, 58, 0.5, 0)
		showBtn.Size = UDim2.new(0, 44, 0, 44)
		showBtn.BackgroundColor3 = Color3.fromRGB(27,31,39)
		showBtn.BackgroundTransparency = 0.15
		showBtn.ZIndex = 999999
		showBtn.AutoButtonColor = false
		showBtn.Image = showBtnImage
		showBtn.ImageColor3 = THEME.Text
		showBtn.ScaleType = Enum.ScaleType.Fit
		showBtn.Parent = showGui
		corner(showBtn, 12)
		stroke(showBtn, THEME.Stroke, 1, 0.2)
		self._showBtn = showBtn

		local showDrag, dragStart2, startPos2 = false, Vector2.zero, showBtn.Position
		local function clampShowBtn(x,y)
			local vp = getViewportSize()
			local inset = GuiService:GetGuiInset()
			local hw = showBtn.AbsoluteSize.X/2
			local hh = showBtn.AbsoluteSize.Y/2
			local mx = (inset.X or 0) + hw
			local my = (inset.Y or 0) + hh
			return math.clamp(x, mx, vp.X - hw), math.clamp(y, my, vp.Y - hh)
		end
		self._clampShowBtn = clampShowBtn

		showBtn.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				showDrag = true
				dragStart2 = Vector2.new(input.Position.X, input.Position.Y)
				startPos2 = showBtn.Position
			end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then showDrag = false end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if showDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
				local delta = Vector2.new(input.Position.X, input.Position.Y) - dragStart2
				local tx = startPos2.X.Offset + delta.X
				local ty = startPos2.Y.Offset + delta.Y
				tx, ty = clampShowBtn(tx, ty)
				showBtn.Position = UDim2.new(0, tx, 0, ty)
			end
		end)

		showBtn.MouseButton1Click:Connect(function() self:Show() end)
		hideBtn.MouseButton1Click:Connect(function() self:Hide() end)
	else
		hideBtn.MouseButton1Click:Connect(function() self:Hide() end)
		local keyConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
			if gameProcessed then return end
			if input.KeyCode == hotkey and not self.Visible then
				self:Show()
			end
		end)
		table.insert(self._connections, keyConn)
	end

	-- 窗口拖拽
	local dragging, dragStart, startPos = false, Vector2.zero, window.Position
	titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = window.Position
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			window.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	-- 主体
	local body = Instance.new("Frame")
	body.Name = "Body"
	body.Position = UDim2.new(0,0,0,54)
	body.Size = UDim2.new(1,0,1,-54)
	body.BackgroundTransparency = 1
	body.Parent = window

	local tabList = Instance.new("ScrollingFrame")
	tabList.Name = "TabList"
	tabList.Size = UDim2.new(0,160,1,0)
	tabList.BackgroundTransparency = 1
	tabList.BorderSizePixel = 0
	tabList.ScrollBarThickness = 4
	tabList.ScrollBarImageColor3 = THEME.Stroke
