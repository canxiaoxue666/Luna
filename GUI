	window.BackgroundTransparency = 1
	window.Size = UDim2.new(self._targetWindowSize.X.Scale, math.floor(self._targetWindowSize.X.Offset*0.78), self._targetWindowSize.Y.Scale, math.floor(self._targetWindowSize.Y.Offset*0.78))
	window.Position = UDim2.new(self._targetWindowPosition.X.Scale, self._targetWindowPosition.X.Offset, self._targetWindowPosition.Y.Scale, self._targetWindowPosition.Y.Offset + 16)
	tween(window, TweenInfo.new(0.34, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = self._targetWindowSize,
		Position = self._targetWindowPosition,
		BackgroundTransparency = THEME.WindowBgTransparency
	})

	return self
end

-- Show / Hide
function UiLib:Show()
	if not self.RootGui then return end
	self.RootGui.Enabled = true
	if self.Window then
		self.Window.Visible = true
		if self._targetWindowSize and self._targetWindowPosition then
			local startSize = UDim2.new(
				self._targetWindowSize.X.Scale, math.floor(self._targetWindowSize.X.Offset*0.78),
				self._targetWindowSize.Y.Scale, math.floor(self._targetWindowSize.Y.Offset*0.78)
			)
			local sx = (self._targetWindowSize.X.Offset - startSize.X.Offset)/2
			local sy = (self._targetWindowSize.Y.Offset - startSize.Y.Offset)/2
			self.Window.Size = startSize
			self.Window.Position = UDim2.new(self._targetWindowPosition.X.Scale, self._targetWindowPosition.X.Offset - sx, self._targetWindowPosition.Y.Scale, self._targetWindowPosition.Y.Offset - sy)
			self.Window.BackgroundTransparency = 1
		end
		tween(self.Window, TweenInfo.new(0.38, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = self._targetWindowSize,
			Position = self._targetWindowPosition,
			BackgroundTransparency = THEME.WindowBgTransparency
		})
	end
	if self._showGui and self._showBtn then
		self._showGui.Enabled = false
		local sb = self._showBtn
		sb.Active = false
		local ht = tween(sb, ANIM.Normal, {BackgroundTransparency=1, ImageTransparency=1, Size=UDim2.new(0,10,0,10)})
		ht.Completed:Connect(function()
			if sb and sb.Parent then
				sb.Size = UDim2.new(0,44,0,44)
				sb.BackgroundTransparency = 0.15
				sb.ImageTransparency = 0
				sb.Active = true
			end
		end)
	end
	self.Visible = true
end

function UiLib:Hide()
	if not (self.RootGui and self.Window and self.Window.Visible) then return end
	local window = self.Window
	self._targetWindowSize = window.Size
	self._targetWindowPosition = window.Position
	local shrinkSize = UDim2.new(window.Size.X.Scale, math.floor(window.Size.X.Offset*0.3), window.Size.Y.Scale, math.floor(window.Size.Y.Offset*0.3))
	local shiftX = (window.Size.X.Offset - shrinkSize.X.Offset)*0.5
	local shiftY = (window.Size.Y.Offset - shrinkSize.Y.Offset)*0.5
	local vanishPos = UDim2.new(window.Position.X.Scale, window.Position.X.Offset - shiftX - window.Size.X.Offset*0.12, window.Position.Y.Scale, window.Position.Y.Offset - shiftY - window.Size.Y.Offset*0.12)

	local hideAnim = tween(window, TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
		Size = shrinkSize, Position = vanishPos, BackgroundTransparency = 1
	})
	self.Visible = false

	hideAnim.Completed:Connect(function()
		if self.Window then self.Window.Visible = false end
		if self._showGui and self._showBtn then
			self._showGui.Enabled = true
			local sb = self._showBtn
			local topLeft = window.AbsolutePosition
			local tx, ty = topLeft.X + 22, topLeft.Y + 22
			if self._clampShowBtn then tx, ty = self._clampShowBtn(tx, ty) end
			sb.Position = UDim2.new(0, tx, 0, ty)
			sb.Size = UDim2.new(0,10,0,10)
			sb.BackgroundTransparency = 1
			sb.ImageTransparency = 1
			tween(sb, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0.15, ImageTransparency = 0, Size = UDim2.new(0,44,0,44)
			})
		end
		if self.Window then
			self.Window.Size = self._targetWindowSize
			self.Window.Position = self._targetWindowPosition
			self.Window.BackgroundTransparency = THEME.WindowBgTransparency
		end
	end)
end

function UiLib:Toggle()
	if self.Visible then self:Hide() else self:Show() end
end

-- 标签切换
function UiLib:SetTabActive(tabName)
	for name, btn in pairs(self._tabButtons) do
		local active = name == tabName
		tween(btn, ANIM.Fast, {
			BackgroundColor3 = active and THEME.AccentSoft or THEME.Card,
			BackgroundTransparency = active and 0 or THEME.CardTransparency
		})
		btn.TextColor3 = active and THEME.Text or THEME.TextSoft
	end
	for name, page in pairs(self._pages) do
		page.Visible = name == tabName
	end
	self._activeTab = tabName
end

